// Current language — default EN, persisted to localStorage
let _currentLang = localStorage.getItem('wealthness_lang') || 'en';

function t(key, replacements = {}) {
  const dict = I18N[_currentLang] || I18N.en;
  let str = dict[key] || I18N.en[key] || key;
  Object.keys(replacements).forEach(k => {
    str = str.replace(new RegExp(`\\{${k}\\}`, 'g'), replacements[k]);
  });
  return str;
}

function setLanguage(lang) {
  if(!I18N[lang]) return;
  _currentLang = lang;
  localStorage.setItem('wealthness_lang', lang);
  document.documentElement.lang = lang === 'en' ? 'en' : 'pt-BR';
  applyTranslations();
  updateLangToggles();

  // If we're on the result screen and a protocol was generated,
  // update archetype display + re-render protocol so labels match new language
  if (_ca && document.getElementById('screen-result')?.classList.contains('active')) {
    // Refresh archetype labels
    _ca.name = t(_ca.nameKey || 'arch.sistema_sobrecarregado');
    const archNameEl = document.getElementById('archetype-name');
    if (archNameEl) archNameEl.textContent = _ca.name;

    // Re-render score cards with translated labels
    if (_cs) renderScores(_cs, _ca);

    // If protocol data exists, re-render with new translations for static UI strings
    if (_protocolData) {
      renderProtocol(_protocolData, _ca, _protocolIsElite);
    }
  }
}

function applyTranslations() {
  // data-i18n: set textContent
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    el.textContent = t(key);
  });
  // data-i18n-html: set innerHTML (for strings with <em> etc.)
  document.querySelectorAll('[data-i18n-html]').forEach(el => {
    const key = el.getAttribute('data-i18n-html');
    el.innerHTML = t(key);
  });
}

function updateLangToggles() {
  document.querySelectorAll('[data-lang-btn]').forEach(btn => {
    const lang = btn.getAttribute('data-lang-btn');
    btn.classList.toggle('active', lang === _currentLang);
  });
}



// Map between i18n archetype keys and the shelf keys (which are in Portuguese)
const ARCHETYPE_SHELF_KEYS = {
  'arch.pele_longevidade': 'Pele Longevidade',
  'arch.corpo_retido': 'Corpo Retido',
  'arch.glow_bloqueado': 'Glow Bloqueado',
  'arch.energia_presa': 'Energia Presa',
  'arch.pele_corpo': 'Pele + Corpo',
  'arch.corpo_energia': 'Corpo + Energia',
  'arch.sistema_sobrecarregado': 'Sistema Sobrecarregado'
};
function getArchetypeShelfKey(arch){
  return ARCHETYPE_SHELF_KEYS[arch.nameKey] || arch.name;
}

