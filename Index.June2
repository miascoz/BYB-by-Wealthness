  const axesCtx = buildAxesContext(p.scores, p.topAxes, isEn);
  const fieldRules = isEn ? FIELD_RULES_EN : FIELD_RULES_PT;

  if(isEn){
    return `You are the Beauty Intel by Wealthness system.

