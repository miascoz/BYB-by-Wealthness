<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beauty Intel by Wealthness</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --deep:#31251D; --ocean:#6F655C; --gold:#C8D9C0;
  --white:#E7D9C8; --muted:rgba(231,217,200,0.42); --muted2:rgba(231,217,200,0.1);
  --serif:'Cormorant Garamond',Georgia,serif; --sans:'DM Sans',sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box}
body{background:var(--deep);color:var(--white);font-family:var(--sans);min-height:100vh;overflow-x:hidden}
#app{max-width:430px;margin:0 auto;min-height:100vh}
.screen{display:none;min-height:100vh;flex-direction:column;animation:fadeUp .45s cubic-bezier(.16,1,.3,1)}
.screen.active{display:flex}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

/* LOGO */
.logo-wrap{display:flex;flex-direction:column;gap:10px;align-items:center;text-align:center}
.logo-main{font-family:var(--serif);font-size:20px;font-weight:700;color:var(--white);line-height:1;white-space:nowrap}
.logo-main em{font-style:italic;color:var(--gold)}.logo-main span{display:inline;white-space:nowrap}
.logo-sub{font-size:8px;letter-spacing:2px;color:var(--muted);text-transform:lowercase}

/* PROGRESS */
.progress-bar{margin-top:18px;height:1px;background:var(--muted2);overflow:hidden}
.progress-fill{height:100%;background:var(--gold);transition:width .55s cubic-bezier(.4,0,.2,1)}

/* LAYOUT */
.screen-header{padding:50px 32px 20px}
.screen-body{flex:1;padding:0 32px 24px}
.screen-footer{padding:0 32px 52px}

/* LABELS */
.step-label{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:10px}
.q-title{font-family:var(--serif);font-size:clamp(30px,8vw,42px);line-height:1.1;font-weight:400;color:var(--white);margin-bottom:8px}
.q-title em{font-style:italic;color:var(--gold)}
.q-sub{font-size:13px;color:var(--muted);font-weight:300;line-height:1.6;margin-bottom:28px}
.group-label{font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:10px}
.multi-hint{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:12px}

/* OPTIONS */
.options{display:flex;flex-direction:column;gap:8px}
.option{display:flex;align-items:center;gap:14px;padding:15px 18px;background:rgba(231,217,200,.04);border:1px solid rgba(231,217,200,.1);border-radius:3px;cursor:pointer;transition:all .2s;text-align:left;width:100%;font-family:var(--sans);font-size:14px;color:rgba(231,217,200,.72);font-weight:300;line-height:1.4}
.option:hover{border-color:var(--gold);background:rgba(200,217,192,.07);color:var(--white)}
.option.selected{border-color:var(--gold);background:rgba(200,217,192,.1);color:var(--white)}
.opt-dot{width:16px;height:16px;border-radius:50%;border:1px solid rgba(231,217,200,.22);flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .2s}
.option.selected .opt-dot{background:var(--gold);border-color:var(--gold)}
.opt-dot-inner{width:5px;height:5px;border-radius:50%;background:var(--deep);display:none}
.option.selected .opt-dot-inner{display:block}

/* BTN */
.btn-primary{width:100%;padding:17px 24px;background:var(--gold);color:var(--deep);border:none;font-family:var(--serif);font-size:17px;font-weight:600;cursor:pointer;transition:all .2s;border-radius:2px}
.btn-primary:hover{background:#C8D9C0;transform:translateY(-1px)}
.btn-primary:disabled{opacity:.2;cursor:not-allowed;transform:none}

/* PLAN CARDS */
.plan-cards{display:flex;flex-direction:column;gap:12px}
.plan-card{background:rgba(231,217,200,.04);border:1px solid rgba(231,217,200,.1);border-radius:4px;padding:22px 20px;cursor:pointer;transition:all .25s;text-align:left;width:100%;position:relative;overflow:hidden}
.plan-card:hover{border-color:rgba(200,217,192,.5);background:rgba(200,217,192,.05)}
.plan-card.selected{border-color:var(--gold);background:rgba(200,217,192,.08)}
.plan-eyebrow{font-size:9px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:8px}
.plan-card.selected .plan-eyebrow{color:var(--gold)}
.plan-name{font-family:var(--serif);font-size:26px;font-weight:400;color:var(--white);margin-bottom:8px;line-height:1}
.plan-name em{font-style:italic;color:var(--gold)}
.plan-desc{font-size:12px;color:var(--muted);font-weight:300;line-height:1.6;margin-bottom:14px}
.plan-feats{display:flex;flex-direction:column;gap:5px}
.plan-feat{font-size:11px;color:rgba(231,217,200,.32);display:flex;align-items:flex-start;gap:8px;line-height:1.4}
.plan-card.selected .plan-feat{color:rgba(231,217,200,.52)}
.plan-feat::before{content:'—';color:var(--gold);flex-shrink:0;font-size:10px;margin-top:1px}
.plan-glow{position:absolute;top:0;right:0;width:140px;height:140px;background:radial-gradient(circle,rgba(200,217,192,.08) 0%,transparent 70%);pointer-events:none}

/* WELCOME */
#screen-welcome{min-height:100vh;justify-content:flex-end;position:relative;overflow:hidden;
  background:linear-gradient(180deg,#5E4636 0%,#31251D 55%,#31251D 100%)}
.w-water{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.ripple{position:absolute;border-radius:50%;border:1px solid rgba(231,217,200,.07);animation:ripOut 7s ease-out infinite}
.ripple:nth-child(1){width:100px;height:100px;top:32%;left:58%;animation-delay:0s}
.ripple:nth-child(2){width:180px;height:180px;top:29%;left:52%;animation-delay:1.2s}
.ripple:nth-child(3){width:280px;height:280px;top:25%;left:44%;animation-delay:2.4s}
.ripple:nth-child(4){width:380px;height:380px;top:20%;left:36%;animation-delay:3.6s;opacity:.5}
@keyframes ripOut{0%{transform:scale(.5);opacity:.5}100%{transform:scale(2);opacity:0}}
.w-caustic{position:absolute;top:0;left:0;right:0;height:55%;
  background:radial-gradient(ellipse 55% 35% at 62% 28%,rgba(181,171,160,.22) 0%,transparent 60%),
             radial-gradient(ellipse 35% 25% at 28% 18%,rgba(231,217,200,.07) 0%,transparent 50%);
  animation:caustic 9s ease-in-out infinite alternate;pointer-events:none}
@keyframes caustic{from{opacity:.5;transform:translateX(-6px)}to{opacity:1;transform:translateX(6px)}}
.w-content{position:relative;z-index:2;flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:72px 28px 56px}
.w-brand{display:flex;flex-direction:column;width:fit-content;align-self:center;text-align:center}
.w-title{font-family:var(--serif);font-size:clamp(44px,13vw,58px);line-height:1;font-weight:400;color:var(--white);letter-spacing:-1.5px;white-space:nowrap}
.w-title em{font-style:italic;font-weight:700;color:var(--gold);display:inline}
.w-by{font-size:12px;letter-spacing:3px;color:rgba(231,217,200,.5);text-transform:lowercase;margin-top:10px;margin-bottom:36px;text-align:right}
.w-tags{display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
.w-science{font-size:9px;letter-spacing:3px;color:rgba(231,217,200,.35);text-transform:uppercase;text-align:center;margin-top:10px;font-weight:300}

/* DISCLAIMERS */

/* ── LANGUAGE TOGGLE ────────────────────────────────────────────────────── */
.lang-toggle-welcome{position:absolute;top:24px;right:24px;display:flex;gap:10px;z-index:10}
.lang-toggle-welcome .lang-btn{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;width:48px;padding:8px 0;background:rgba(35,33,31,.5);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(231,217,200,.1);border-radius:4px;cursor:pointer;transition:all .25s}
.lang-toggle-welcome .lang-btn:hover{background:rgba(35,33,31,.75);border-color:rgba(200,217,192,.3)}
.lang-toggle-welcome .lang-btn.active{background:rgba(200,217,192,.15);border-color:var(--gold)}
.lang-toggle-welcome .lang-flag{font-size:18px;line-height:1;display:block;text-align:center}
.lang-toggle-welcome .lang-code{font-size:9px;letter-spacing:1.5px;color:rgba(231,217,200,.55);font-weight:500;font-family:var(--sans);text-align:center;line-height:1}
.lang-toggle-welcome .lang-btn.active .lang-code{color:var(--gold)}

.lang-toggle-mini{position:absolute;top:18px;right:18px;display:flex;gap:6px;z-index:10}
.lang-toggle-mini .lang-btn-mini{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;width:34px;padding:5px 0;background:transparent;border:1px solid rgba(231,217,200,.08);border-radius:3px;cursor:pointer;transition:all .2s}
.lang-toggle-mini .lang-btn-mini:hover{border-color:rgba(200,217,192,.3)}
.lang-toggle-mini .lang-btn-mini.active{border-color:var(--gold);background:rgba(200,217,192,.08)}
.lang-toggle-mini .lang-flag-mini{font-size:13px;line-height:1;text-align:center}
.lang-toggle-mini .lang-code-mini{font-size:8px;letter-spacing:1px;color:rgba(231,217,200,.4);font-weight:500;font-family:var(--sans);line-height:1;text-align:center}
.lang-toggle-mini .lang-btn-mini.active .lang-code-mini{color:var(--gold)}

.screen-header{position:relative}

.welcome-legal-footer{position:absolute;bottom:0;left:0;right:0;padding:10px 24px;background:rgba(35,33,31,.6);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);border-top:1px solid rgba(231,217,200,.05);font-size:9px;line-height:1.5;color:rgba(231,217,200,.38);letter-spacing:.5px;font-weight:300;text-align:center;z-index:3}

.disclaimer-result{margin:8px 32px 0;padding:18px 22px;background:linear-gradient(180deg,rgba(200,217,192,.04) 0%,rgba(200,217,192,.015) 100%);border:1px solid rgba(200,217,192,.2);border-radius:3px;position:relative;overflow:hidden}
.disclaimer-result::before{content:'';position:absolute;top:0;left:0;bottom:0;width:2px;background:linear-gradient(180deg,transparent,var(--gold) 30%,var(--gold) 70%,transparent);opacity:.9}
.disclaimer-result .d-label{font-family:var(--serif);font-size:10px;letter-spacing:2.5px;color:var(--gold);text-transform:uppercase;font-weight:500;margin-bottom:8px;font-style:italic}
.disclaimer-result .d-text{font-size:11px;line-height:1.7;color:rgba(231,217,200,.65);font-weight:300;letter-spacing:.2px}

.disclaimer-footer{padding:20px 32px;margin-top:16px;border-top:1px solid rgba(231,217,200,.05);text-align:center}

/* ── VIRTUAL CALENDAR MODAL ────────────────────────────────────────────── */
.cal-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:var(--deep);z-index:100;overflow-y:auto;display:none;flex-direction:column}
.cal-modal.active{display:flex}
.cal-header{padding:18px 20px 14px;border-bottom:1px solid rgba(231,217,200,.06);display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;background:var(--deep);z-index:10}
.cal-header-title{font-family:var(--serif);font-size:18px;color:var(--white);font-style:italic}
.cal-close{background:transparent;border:none;color:rgba(231,217,200,.5);font-size:22px;cursor:pointer;padding:4px 10px;line-height:1}
.cal-day-tabs{display:flex;gap:4px;padding:14px 14px 8px;overflow-x:auto;-webkit-overflow-scrolling:touch}
.cal-day-tab{flex-shrink:0;padding:10px 14px;background:rgba(231,217,200,.04);border:1px solid rgba(231,217,200,.06);border-radius:4px;cursor:pointer;text-align:center;min-width:50px;color:rgba(231,217,200,.55);font-size:10px;letter-spacing:1px;font-weight:500;position:relative;transition:all .2s}
.cal-day-tab.active{background:rgba(200,217,192,.12);border-color:var(--gold);color:var(--gold)}
.cal-day-tab.today::after{content:'';position:absolute;top:5px;right:5px;width:5px;height:5px;border-radius:50%;background:var(--gold)}
.cal-progress{padding:0 20px 12px;font-size:10px;color:rgba(231,217,200,.4);letter-spacing:1px}
.cal-progress-bar{height:3px;background:rgba(231,217,200,.05);border-radius:2px;overflow:hidden;margin-top:6px}
.cal-progress-fill{height:100%;background:var(--gold);transition:width .4s}
.cal-period{padding:18px 20px 6px}
.cal-period-label{font-family:var(--serif);font-size:11px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.cal-empty{padding:30px 20px;text-align:center;color:rgba(231,217,200,.3);font-style:italic;font-size:13px}
.cal-item{display:flex;align-items:flex-start;gap:12px;padding:12px 0;border-bottom:1px solid rgba(231,217,200,.04)}
.cal-item-check{width:22px;height:22px;border-radius:4px;border:1.5px solid rgba(231,217,200,.2);flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;background:transparent;margin-top:2px}
.cal-item-check.checked{background:var(--gold);border-color:var(--gold)}
.cal-item-check.checked::after{content:'✓';color:var(--deep);font-weight:700;font-size:13px}
.cal-item-content{flex:1}
.cal-item.checked .cal-item-name{text-decoration:line-through;opacity:.4}
.cal-item-name{font-size:14px;color:rgba(231,217,200,.85);margin-bottom:2px}
.cal-item-dose{font-size:11px;color:var(--gold);opacity:.85;margin-bottom:2px}
.cal-item-mode{font-size:10px;color:rgba(231,217,200,.4)}
.cal-clear-btn{margin:18px 20px 30px;padding:10px;background:transparent;color:rgba(231,217,200,.4);border:1px solid rgba(231,217,200,.08);font-size:11px;letter-spacing:1px;cursor:pointer;border-radius:2px;width:calc(100% - 40px)}
.cal-print-footer{padding:16px 20px 30px;font-size:9px;color:rgba(231,217,200,.25);line-height:1.7;text-align:center;letter-spacing:.3px;font-weight:300}


/* ── WHY THIS toggle (per-item explanation) ───────────────────────── */
.why-toggle{display:inline-flex;align-items:center;gap:5px;font-size:11px;color:rgba(231,217,200,.6);letter-spacing:1px;text-transform:uppercase;font-weight:500;cursor:pointer;background:transparent;border:none;padding:10px 0 6px;font-family:var(--sans);transition:color .15s ease}
.why-toggle:hover{color:rgba(231,217,200,.85)}
.why-toggle .chevron{display:inline-block;transition:transform .2s ease;font-size:10px;opacity:.85}
.why-toggle.open .chevron{transform:rotate(180deg)}
.why-content{display:none;padding:10px 0 6px;font-size:13px;color:rgba(231,217,200,.78);line-height:1.6;font-weight:300;border-left:1px solid rgba(231,217,200,.15);padding-left:12px;margin-top:6px}
.why-content.open{display:block;animation:fadeInWhy .25s ease}
@keyframes fadeInWhy{from{opacity:0;transform:translateY(-2px)}to{opacity:1;transform:translateY(0)}}
.why-warning{display:none;margin-top:10px;font-size:11px;color:rgba(230,120,120,.9);line-height:1.55;font-style:italic;padding:8px 12px;background:rgba(220,80,80,.08);border-left:2px solid rgba(220,80,80,.4);border-radius:0 2px 2px 0}
.why-warning.open{display:block;animation:fadeInWhy .25s ease}

.disclaimer-footer .d-text{font-size:9px;line-height:1.75;color:rgba(231,217,200,.28);letter-spacing:.4px;font-weight:300;max-width:560px;margin:0 auto}

.w-tag{padding:5px 13px;border:1px solid rgba(200,217,192,.28);border-radius:100px;font-size:10px;color:rgba(200,217,192,.6);letter-spacing:1.5px;text-transform:uppercase}
.w-headline{font-family:var(--serif);font-size:23px;font-weight:300;color:var(--white);line-height:1.3;margin-top:32px;letter-spacing:-.3px;text-align:center}
.w-tagline{font-family:var(--serif);font-style:italic;font-size:24px;font-weight:300;color:var(--gold);text-align:center;line-height:1.3;letter-spacing:-.2px;margin:auto 36px 32px;padding-top:32px;max-width:460px;align-self:center;position:relative;z-index:2}
.w-tagline::before{content:'';display:block;width:40px;height:1px;background:rgba(200,217,192,.5);margin:0 auto 24px}
.w-strip{background:var(--gold);padding:24px 28px;position:relative;z-index:2;margin-bottom:36px;display:flex;justify-content:space-between;align-items:center;gap:16px}
.w-strip-content{flex:1;min-width:0}
.w-strip-title{font-family:var(--serif);font-size:21px;font-weight:600;color:var(--deep);line-height:1.2;letter-spacing:-.3px;margin-bottom:4px}
.w-strip-title em{font-style:italic}
.w-strip-sub{font-size:10px;color:rgba(35,33,31,.5);letter-spacing:1.5px;text-transform:uppercase;font-weight:500}
.btn-start{flex-shrink:0;padding:13px 22px;background:var(--deep);color:var(--gold);border:none;font-family:var(--serif);font-size:14px;font-weight:600;cursor:pointer;border-radius:2px;white-space:nowrap;font-style:italic}
.btn-start:hover{background:#31251D}
.btn-start{flex-shrink:0;padding:13px 22px;background:var(--deep);color:var(--gold);border:none;font-family:var(--serif);font-size:14px;font-weight:600;cursor:pointer;border-radius:2px;white-space:nowrap;transition:all .2s}
.btn-start:hover{background:#31251D}

/* LOADING */
#screen-loading{justify-content:center;align-items:center;text-align:center;padding:40px;
  background:linear-gradient(175deg,var(--deep) 0%,var(--ocean) 60%,var(--deep) 100%)}
.loading-ring{width:60px;height:60px;border:1.5px solid rgba(231,217,200,.08);border-top-color:var(--gold);border-radius:50%;animation:spin 1.2s linear infinite;margin:0 auto 32px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-title{font-family:var(--serif);font-size:30px;margin-bottom:10px;font-weight:400}
.loading-title em{font-style:italic;color:var(--gold)}
.loading-status{font-size:11px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;min-height:18px}
.loading-tags{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-top:36px}
.loading-tag{padding:5px 14px;border:1px solid rgba(231,217,200,.07);border-radius:100px;font-size:10px;letter-spacing:1px;color:rgba(231,217,200,.18);opacity:0;transition:all .6s;text-transform:uppercase}
.loading-tag.visible{opacity:1;color:var(--gold);border-color:rgba(200,217,192,.3);background:rgba(200,217,192,.05)}

/* RESULT */
#screen-result{background:linear-gradient(175deg,var(--deep) 0%,#6F655C 100%)}
.result-hero{padding:52px 32px 32px;border-bottom:1px solid rgba(231,217,200,.07);position:relative;overflow:hidden}
.result-hero::before{content:'';position:absolute;top:-60px;right:-60px;width:240px;height:240px;background:radial-gradient(circle,rgba(181,171,160,.1) 0%,transparent 70%);pointer-events:none}
.result-archetype-label{font-size:9px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:12px}
.result-archetype-name{font-family:var(--serif);font-size:clamp(34px,9vw,46px);line-height:1.05;font-weight:400;color:var(--white);margin-bottom:16px}
.result-motor-tag{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border:1px solid rgba(231,217,200,.1);border-radius:100px;font-size:11px;color:var(--muted)}
.result-motor-tag::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--gold)}
.result-scores{padding:24px 32px;display:grid;grid-template-columns:1fr 1fr;gap:10px;border-bottom:1px solid rgba(231,217,200,.06)}
.score-card{background:rgba(231,217,200,.04);border:1px solid rgba(231,217,200,.07);padding:14px 16px;border-radius:3px}
.score-card.dominant{background:rgba(200,217,192,.07);border-color:rgba(200,217,192,.25)}
.score-label{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:6px}
.score-value{font-family:var(--serif);font-size:28px;color:var(--white);line-height:1}
.score-card.dominant .score-value{color:var(--gold)}
.score-bar{height:2px;background:rgba(231,217,200,.07);border-radius:2px;margin-top:10px;overflow:hidden}
.score-bar-fill{height:100%;background:var(--gold);border-radius:2px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}
.result-protocol{padding:28px 32px}
.protocol-title{font-family:var(--serif);font-size:12px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:24px;font-weight:400}
.protocol-loading{display:flex;align-items:center;gap:12px;color:var(--muted);font-size:13px}
.protocol-spinner{width:14px;height:14px;border:1px solid rgba(231,217,200,.1);border-top-color:var(--gold);border-radius:50%;animation:spin .9s linear infinite;flex-shrink:0}
.result-footer{padding:0 32px 60px;margin-top:8px}
.btn-restart{width:100%;padding:14px;background:transparent;color:var(--muted);border:1px solid rgba(231,217,200,.1);font-family:var(--sans);font-size:11px;letter-spacing:2px;cursor:pointer;border-radius:2px;transition:all .2s;text-transform:uppercase}
.btn-restart:hover{border-color:rgba(231,217,200,.3);color:var(--white)}
.error-box{padding:16px;background:rgba(255,60,60,.06);border:1px solid rgba(255,60,60,.25);border-radius:3px;font-size:13px;color:#FF8888;line-height:1.5;display:none;margin-bottom:16px}
#paid-layer{margin:0 32px 8px}
</style>
</head>
<body>
<div id="app">

<!-- WELCOME -->
