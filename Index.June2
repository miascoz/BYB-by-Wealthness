// Helper: get the right shelf based on objective
function getShelfForObjective(objective){
  return SHELVES[objective] || SHELVES.skin;
}

// Helper: format shelf as readable text for the AI prompt
function formatShelfForPrompt(shelf, includeAdvanced = false){
  let out = '';
  for(const [category, items] of Object.entries(shelf)){
    if(!includeAdvanced && (category.includes('advanced') || category.includes('peptides'))) continue;
    out += `\n## ${category.toUpperCase()}\n`;
    items.forEach((item, i) => out += `${i+1}. ${item}\n`);
  }
  return out;
}

function formatLongevityForPrompt(){
  const isEn = (typeof _currentLang !== 'undefined') && _currentLang === 'en';
  // Translate tier names per language so the AI doesn't copy English labels
  const tierLabels = isEn
    ? { base: 'LONGEVITY BASE', intermediate: 'LONGEVITY INTERMEDIATE', advanced: 'LONGEVITY ADVANCED' }
    : { base: 'LONGEVIDADE BASE', intermediate: 'LONGEVIDADE INTERMEDIÁRIA', advanced: 'LONGEVIDADE AVANÇADA' };
  let out = '';
  for(const [tier, items] of Object.entries(SHELVES.longevity)){
    const label = tierLabels[tier] || tier.toUpperCase();
    out += `\n## ${label}\n`;
    items.forEach((item, i) => out += `${i+1}. ${item}\n`);
  }
  return out;
}




