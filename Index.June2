    <div class="w-headline" data-i18n-html="w.headline">Pele. Gordura. Mais músculo.</div>
  </div>
  <div class="w-tagline" data-i18n-html="w.tagline">A transformação externa<br>começa por dentro.</div>
  <div class="w-strip">
    <div class="w-strip-content">
      <div class="w-strip-title" data-i18n-html="w.strip.title">Personalizado pra <em>você</em></div>
      <div class="w-strip-sub" data-i18n="w.strip.sub">em menos de 60 segundos</div>
    </div>
    <button class="btn-start" data-i18n="w.start" onclick="startOnboarding()">Começar →</button>
  </div>
  <div class="welcome-legal-footer" data-i18n="w.legal">
    Educational and informational only. Not medical advice. Consult a qualified healthcare provider before starting any protocol.
  </div>
</div>

<!-- SLIDE 1 — About You -->
<div class="screen" id="screen-0">
  <div class="screen-header">
    <div class="logo-wrap"><div class="logo-main"><span>Beauty Intel</span></div><div class="logo-sub">by Wealthness</div></div>
    <div class="progress-bar"><div class="progress-fill" style="width:16%"></div></div>
    <div class="lang-toggle-mini">
      <button class="lang-btn-mini" data-lang-btn="en" onclick="setLanguage('en')"><span class="lang-flag-mini">🇺🇸</span><span class="lang-code-mini">EN</span></button>
      <button class="lang-btn-mini" data-lang-btn="pt" onclick="setLanguage('pt')"><span class="lang-flag-mini">🇧🇷</span><span class="lang-code-mini">PT</span></button>
    </div>
  </div>
  <div class="screen-content">
    <div class="step-label" data-i18n="s1.label">Sobre Você · 1 de 6</div>
