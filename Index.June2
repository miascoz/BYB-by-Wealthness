  <div class="cal-progress" id="cal-progress-text"></div>
  <div class="cal-progress-bar"><div class="cal-progress-fill" id="cal-progress-fill" style="width:0%"></div></div>
  <div id="cal-day-content"></div>
  <button class="cal-clear-btn" onclick="clearCalendarMarks()" data-i18n="cal.clear">Limpar</button>
</div>

