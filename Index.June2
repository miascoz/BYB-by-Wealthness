const BYB_SHELVES = {"skin":[{"categoria":"SKIN — Routines","nome":"Skincare base matinal","dose":"limpeza suave + hidratante + FPS 50+","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"limpeza pH 5.5-6.5, hidratante, FPS 30-50+ broad-spectrum aplicado generosamente","ciclo":"contínuo","observacao":"FPS diário é a intervenção anti-aging mais validada; SPF 30+ é o padrão internacional","fonte":"✅ Krutmann 2021 (Photodermatol Photoimmunol Photomed); CMAJ 2020 SR; AAD/Canadian Dermatology Association guidelines","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Skincare noturno","dose":"limpeza + ativos + hidratante reparador","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"limpeza dupla se usou maquiagem/FPS resistente à água; ativos noturnos; hidratante","ciclo":"contínuo","observacao":"Ativos noturnos (retinol/peptídeos) não enfrentam UV; dupla limpeza tem evidência para remoção de FPS resistente","fonte":"✅ J Cosmet Dermatol 2020 (Takagi, dupla limpeza); revisão Mona Dermatology","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Hidratação interna","dose":"30-35 ml/kg de água + 1g de sal Celta/Himalaia no primeiro copo","frequencia":"diario","periodo":"manha","dias_semana":"diario","modo":"1g de sal no primeiro copo em jejum + água ao longo do dia; mais em dias quentes/treino","ciclo":"contínuo","observacao":"Hidratação dietética melhora hidratação cutânea principalmente em quem consome <2L/dia","fonte":"✅ Palma 2015 Clin Cosmet Investig Dermatol; Ann Dermatol 2024 (Korean RCT, n=43)","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Sono restaurador","dose":"7-9 horas","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"blackout total, 18-20°C, horário fixo de deitar; sem telas 1h antes","ciclo":"contínuo","observacao":"Pico de GH em sono profundo (primeiros 90min) impulsiona síntese de colágeno","fonte":"✅ Van Cauter 2000 (GH/sleep); Sleep Foundation/NIH","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Sol matinal","dose":"10-20 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"primeiras 2h após acordar; sem proteção solar nesse momento; pele e olhos expostos (não olhar direto)","ciclo":"contínuo","observacao":"Luz matinal eleva cortisol >50% e suprime melatonina, sincronizando ritmo circadiano","fonte":"✅ Scheer/Buijs 1999 J Clin Endocrinol Metab 84:3395; Jung/Lockley/Czeisler 2010 J Biol Rhythms","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Higiene digital noturna","dose":"1h sem telas antes de dormir","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"substituir por leitura/alongamento; se necessário usar filtro de luz azul (>460nm)","ciclo":"contínuo","observacao":"Luz azul (460-480nm) ativa ipRGCs/melanopsina e suprime melatonina","fonte":"✅ SLEEP Advances 2020 (Höhn meta); Frontiers Neurology 2025 SR; Nature Sci Rep 2019 (melanopic irradiance)","evidence":"validated"},{"categoria":"SKIN — Routines","nome":"Mouth taping (fita na boca durante o sono)","dose":"1 fita 3M Micropore vertical","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"aplicar fita vertical pequena sobre os lábios antes de dormir; testar tolerância gradual","ciclo":"contínuo após adaptação 1-2 semanas","observacao":"Apenas com via nasal desobstruída; NÃO usar com obstrução nasal/OSA moderada-severa — risco de asfixia/aspiração","fonte":"⚠️ Rhee 2025 PLOS One systematic review (10 estudos, n=213); benefício apenas em ronco/OSA leve","evidence":"promising"},{"categoria":"SKIN — Routines","nome":"Caminhada pós-refeição","dose":"10-15 min","frequencia":"2-3x/dia","periodo":"tarde","dias_semana":"diario","modo":"ritmo leve a moderado iniciando 15min após cada refeição principal","ciclo":"contínuo","observacao":"Reduz pico glicêmico pós-prandial; controle glicêmico reduz glicação cutânea","fonte":"✅ Engeroff 2023 Sports Med meta-análise (PMC10036272); Buffey 2022; Nutrients 2022 (PMC8912639)","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Vitamina C tópica (L-ascórbico)","dose":"10-20%","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"aplicar em pele seca antes do FPS; pH <3.5 essencial; combinar com vitamina E 1% + ácido ferúlico 0.5%","ciclo":"contínuo","observacao":"Concentrações >20% não aumentam benefício; combo C+E+ferulic dobra fotoproteção (4x→8x)","fonte":"✅ Lin/Pinnell 2005 J Invest Dermatol; Murray/Pinnell 2008 JAAD","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Niacinamida tópica","dose":"2-10%","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"compatível com vitamina C e retinol; iniciar em 2-5% para tolerância","ciclo":"contínuo","observacao":"Eficácia validada em barreira, sebo, PIH e antienvelhecimento","fonte":"✅ Fitzpatrick 2004 (Cosmet Dermatol); revisão Cosmoderma 2024 (PMC11047333)","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Ácido hialurônico tópico","dose":"0.1-2%","frequencia":"2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"aplicar em pele úmida; baixo peso molecular (20-300 kDa) penetra a estrato córneo","ciclo":"contínuo","observacao":"Alto PM (1000-1400 kDa) hidrata superfície; baixo PM penetra dermis","fonte":"✅ Essendoubi 2016 Skin Res Technol (Raman, PMID 25877232); Giardina 2023 JOJDC 5(3):555665","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Retinol","dose":"0.1-0.5%","frequencia":"3-5x/sem","periodo":"noite","dias_semana":"seg,qua,sex","modo":"aplicar em pele seca 20-30 min após limpeza; iniciar 2x/sem e escalar; FPS obrigatório de dia","ciclo":"contínuo após adaptação","observacao":"0.3% comparável a 1% com menos irritação; mais bem tolerado que tretinoína","fonte":"✅ Babamiri/Nassab 2010 JCD (3 retinols vs tretinoínas); meta-revisão Adv Ther 2022","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Ácido azelaico tópico","dose":"15-20%","frequencia":"1-2x/dia","periodo":"noite","dias_semana":"diario","modo":"aplicar em pele limpa; 15% gel para rosácea, 20% creme para melasma/PIH","ciclo":"contínuo","observacao":"FDA-aprovado para rosácea papulopustular; 20% supera hidroquinona 2% em melasma; seguro na gravidez","fonte":"✅ King 2023 J Cosmet Dermatol (PMID 37550898, SR 43 RCTs); revisão Pharmaceutics PMC12472904","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"BHA — ácido salicílico tópico","dose":"1-2%","frequencia":"2-3x/sem","periodo":"noite","dias_semana":"ter,qui,sab","modo":"aplicar em pele limpa e seca; evitar combinar com retinol no mesmo dia","ciclo":"contínuo","observacao":"2% tão eficaz quanto BP 5% em acne inflamatória, com menos irritação","fonte":"✅ Liu 2025 J Cosmet Dermatol (PMID 40682377); Bhatia 2014 J Drugs Dermatol (PMID 24918557)","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Matrixyl — Palmitoil pentapeptídeo-4 tópico","dose":"3-8%","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"após limpeza, antes do hidratante; pode combinar com vitamina C","ciclo":"contínuo","observacao":"Estimula matriz extracelular (colágeno I, III, fibronectina)","fonte":"✅ Robinson/Bissett 2005 Int J Cosmet Sci 27(3):155-160 (RCT split-face, n=93); Errante 2017 Cosmetics 4(2):16","evidence":"validated"},{"categoria":"SKIN — Topical Basics","nome":"Argireline — Acetil hexapeptídeo-8 tópico","dose":"5-10%","frequencia":"2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"aplicar nas áreas de expressão (testa, glabela, pés-de-galinha)","ciclo":"contínuo","observacao":"Eficácia modesta; resultados inferiores ao Botox; penetração cutânea limitada por tamanho molecular","fonte":"⚠️ MDPI Int J Mol Sci 2025 (PMC AH-8 review); Wang 2013 Am J Clin Dermatol; Ann Dermatol 2019 (PMID limited evidence)","evidence":"promising"},{"categoria":"SKIN — Topical Advanced","nome":"Tretinoína (ácido retinóico)","dose":"0.025-0.05%","frequencia":"3-5x/sem","periodo":"noite","dias_semana":"seg,ter,qua,qui,sex","modo":"requer prescrição; pele seca e limpa; iniciar 2x/sem; FPS rigoroso de dia","ciclo":"contínuo após adaptação 4-8 semanas","observacao":"0.05% padrão-ouro Kligman 1986; 0.1% similar eficácia mas mais irritante; gestação contraindicada","fonte":"✅ Kligman 1986 JAAD 15:836; Griffiths/Voorhees 1995 Arch Dermatol (PMID 7544967); Olsen 1997 JAAD","evidence":"validated"},{"categoria":"SKIN — Topical Advanced","nome":"GHK-Cu peptídeo tópico","dose":"2%","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"após limpeza, antes do hidratante","ciclo":"contínuo","observacao":"Aumento médio de 28% na densidade dérmica de colágeno em 3 meses","fonte":"✅ Leyden 2002 (Cosmet Dermatol photoaging trial); NEEL 2023 (IRB-approved 21-woman gel study)","evidence":"validated"},{"categoria":"SKIN — Topical Advanced","nome":"Ácido glicólico (AHA)","dose":"8-15%","frequencia":"1-2x/sem","periodo":"noite","dias_semana":"seg,sex","modo":"renovação celular; rotacionar com retinol (não usar mesmo dia); FPS obrigatório","ciclo":"contínuo","observacao":"Peels profissionais 30-70% mostram eficácia em fotodano; uso doméstico 5-15% para manutenção","fonte":"✅ Sharad 2013 (PMID review); Newman 1996 (50% peel 4 weeks); Stiller 1996 (8% cream 22wk RCT)","evidence":"validated"},{"categoria":"SKIN — Topical Advanced","nome":"Retinaldeído tópico","dose":"0.05-0.1%","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"intermediário entre retinol e tretinoína; menos irritante que tretinoína","ciclo":"contínuo","observacao":"1 etapa de conversão a ácido retinóico = mais potente que retinol; 0.1% mostra maior eficácia que 0.05%","fonte":"✅ Saurat 1995 (PMID 7798613, n=229); Kwon 2018 J Cosmet Dermatol (PMID, n=40 RCT); JCD 2024 PMC12928007 (n=56 split-face)","evidence":"validated"},{"categoria":"SKIN — Topical Advanced","nome":"Bakuchiol tópico","dose":"0.5-1%","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"alternativa vegetal ao retinol; pode usar AM/PM; seguro na gravidez (consultar médico)","ciclo":"contínuo","observacao":"Não-inferior a retinol 0.5% em 12 semanas (rugas e hiperpigmentação); melhor tolerado","fonte":"✅ Dhaliwal 2019 BJD RCT (n=44, PMID 30041421); revisão Multidirectional Activity (PMC9328396)","evidence":"validated"},{"categoria":"SKIN — Topical Advanced","nome":"Snail mucin (mucina de caracol)","dose":"filtrato 70-96%","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"aplicar em pele limpa antes de hidratante; bem tolerado","ciclo":"contínuo","observacao":"Evidência mais robusta em wound healing; estudos em anti-aging têm formulações multi-ingrediente","fonte":"⚠️ Gugliandolo 2021 (mice wound, PMC8402640); Cryptomphalus aspersa estudos (Addor); revisão JID 2026 (joid.my5hzr63)","evidence":"promising"},{"categoria":"SKIN — Devices","nome":"LED vermelho/NIR (fotobiomodulação)","dose":"10-20 min","frequencia":"5-7x/sem","periodo":"manha","dias_semana":"diario","modo":"15-30cm da pele; 630-660nm (vermelho) + 810-850nm (NIR); pele limpa","ciclo":"contínuo","observacao":"Citocromo c oxidase mitocondrial; mecanismo distinto da sauna IR (que é térmica)","fonte":"✅ Leal-Junior 2015 (meta-análise PBM); Avci 2013 Semin Cutan Med Surg; Wunsch/Matuschka 2014 JCD","evidence":"validated"},{"categoria":"SKIN — Devices","nome":"Microcorrente facial","dose":"5-10 min","frequencia":"3-5x/sem","periodo":"noite","dias_semana":"seg,qua,sex,sab","modo":"após hidratante; movimentos para cima; intensidade <1000 µA","ciclo":"contínuo","observacao":"Estudo 30 sujeitos mostrou 18-21% redução de rugas; evidência clínica moderada","fonte":"⚠️ Kim 2015a/b (Authorea PMC review); Wanitphakdeedecha 2015; resultados >com combo LED+microcurrent","evidence":"promising"},{"categoria":"SKIN — Devices","nome":"Microagulhamento 0.25-0.5mm + EGF/PDRN/GHK-Cu tópico","dose":"1 sessão completa","frequencia":"1x/quinzenal","periodo":"noite","dias_semana":"qui","modo":"aplicar EGF/PDRN/GHK-Cu IMEDIATAMENTE após o microagulhamento; assepsia rigorosa","ciclo":"quinzenal","observacao":"Combinação tem evidência RCT robusta; usar isolado ou com soro sem ativos seguros pós-procedimento","fonte":"✅ Lynch 2025 RCT PDGF + microneedling; PMC8882957 meta-análise dermaroller + PRP/TCA","evidence":"validated"},{"categoria":"SKIN — Devices","nome":"Gua sha facial","dose":"5-10 min","frequencia":"5x/sem","periodo":"manha","dias_semana":"seg,ter,qua,qui,sex","modo":"com óleo facial; movimentos lentos para cima e fora; pressão moderada","ciclo":"contínuo","observacao":"RCT 34 mulheres mostrou redução 2.23-2.40mm em contorno facial e tônus muscular em 8 semanas","fonte":"✅ Ahn 2025 J Cosmet Dermatol (RCT, PMID 40439289, PMC12121324)","evidence":"validated"},{"categoria":"SKIN — Devices","nome":"Rolo de jade gelado","dose":"3-5 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"rolo guardado na geladeira; aplicar em rosto limpo logo após acordar","ciclo":"contínuo","observacao":"Vasoconstrição local temporária + desinchaço matinal; sem efeito em colágeno","fonte":"⚠️ Ahn 2025 (RCT mostrou maior ganho de elasticidade no grupo facial roller vs gua sha)","evidence":"promising"},{"categoria":"SKIN — Devices","nome":"Radiofrequência portátil facial","dose":"10-15 min","frequencia":"2x/sem","periodo":"noite","dias_semana":"seg,qui","modo":"movimentos circulares no rosto; gel condutor; ~40°C; evitar contorno dos olhos","ciclo":"contínuo","observacao":"Dispositivos profissionais > caseiros; estudos home-use mostram melhora moderada em 8-12 semanas","fonte":"✅ Ai 2024 J Cosmet Dermatol (PMID 37942722, home RF 8 semanas, n=22); Sadick/Harth 2016 JCLT","evidence":"validated"},{"categoria":"SKIN — Devices","nome":"Massagem facial manual","dose":"5-10 min","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"após skincare; movimentos linfáticos do centro para fora; pressão leve","ciclo":"contínuo","observacao":"Drenagem linfática local; melhor evidência em facial roller para elasticidade (R2 +8.6%)","fonte":"✅ Ahn 2025 J Cosmet Dermatol RCT (facial roller mostrou ganho de elasticidade R2 8.6%, R7 7.5%)","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Colágeno hidrolisado + Vitamina C","dose":"2.5-10g colágeno + 500mg vit C","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"em jejum, em água/café; peptídeos de baixo PM (Gly-Pro-Hyp)","ciclo":"contínuo, mínimo 12 semanas","observacao":"Meta-análise 14 estudos n=967: melhora hidratação e elasticidade em 12 semanas","fonte":"✅ Dewi 2023 Cureus (DOI 10.7759/cureus.50231, 14 RCTs n=967); De Miranda 2021","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Ômega-3 EPA/DHA","dose":"1-2g (EPA+DHA combinados)","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição que contenha gordura","ciclo":"contínuo","observacao":"Anti-inflamatório; reduz lesões inflamatórias e não-inflamatórias em acne","fonte":"✅ Guertler 2024 J Cosmet Dermatol (n=60 RCT 16wk); Khayef 2012 Lipids Health Dis (n=13, 2g EPA+DHA 10wk)","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Vitamina D3","dose":"2000-5000 UI","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; ajustar dose conforme 25(OH)D (alvo 40-60 ng/mL)","ciclo":"contínuo","observacao":"2000 UI eleva 25(OH)D >20 ng/mL em >99% dos adultos; 5000 UI/dia mostrou benefício adjuvante em dermatite atópica","fonte":"✅ Nutrients 2024 (PMC10857599, 2000 UI review); Sánchez-Armendáriz 2018 Int J Dermatol (5000 UI RCT AD)","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Zinco quelado (picolinato/gluconato)","dose":"15-30 mg elementar","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"com refeição (evitar estômago vazio); >40mg adicionar 2mg cobre","ciclo":"contínuo (reavaliar a cada 3 meses)","observacao":"30 mg = dose padrão em RCT de acne inflamatória; modestamente eficaz vs antibióticos","fonte":"✅ Dreno 2001 (PMID 11586012, n=332 vs minocycline); Bhatia 2014; revisão Drugs Dermatol","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Astaxantina","dose":"4-12 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa (lipossolúvel)","ciclo":"contínuo","observacao":"Meta-análise: melhora elasticidade (SMD 0.77, p=0.009) e hidratação (SMD 0.53, p=0.03)","fonte":"✅ MDPI Nutrients 2021 SR meta (PMC8472736); Tominaga 2017 J Clin Biochem Nutr (n=59 RCT, 6/12 mg 16wk)","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"CoQ10 ubiquinol","dose":"100-200 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; ubiquinol > ubiquinona em idosos","ciclo":"contínuo","observacao":"RCT brasileiro n=41 mulheres 60-76 anos: melhora viscoelasticidade, eritema, colágeno em 12 semanas (200mg ótimo)","fonte":"✅ JAAD 2023 (article 44265, RCT n=41 100/200mg 12wk)","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Vitamina C oral","dose":"500-1000 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"lipossomal para melhor biodisponibilidade; com refeição","ciclo":"contínuo","observacao":"Cofator essencial para hidroxilação de prolina/lisina no colágeno; absorção decai >500mg","fonte":"✅ NIH Office of Dietary Supplements; Pullar 2017 Nutrients 9(8):866 (PMID 28805671); Shaw 2017 AJCN","evidence":"validated"},{"categoria":"SKIN — Nutrition","nome":"Glutationa lipossomal","dose":"250-500 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"em jejum 30 min antes de comer; forma lipossomal/sublingual essencial (oral comum tem baixa biodisponibilidade)","ciclo":"contínuo","observacao":"Oral 500mg/dia x 4 semanas reduziu índice de melanina em RCT; oral comum é largamente degradada no TGI","fonte":"⚠️ Arjinpathana/Asawanonda 2007 RCT (n=60 oral 500mg 4wk); Watanabe (split-face topical GSSG RCT 10wk); Weschawalit RCT","evidence":"promising"},{"categoria":"SKIN — Nutrition","nome":"Resveratrol oral","dose":"75-500 mg (trans-resveratrol)","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; piperina aumenta biodisponibilidade significativamente","ciclo":"contínuo","observacao":"Biodisponibilidade oral baixa; piperina aumenta AUC 229% e Cmax 1544% em modelo animal","fonte":"⚠️ Walle 2004 Drug Metab Dispos (alta absorção, baixa biodisponibilidade); Johnson 2011 Mol Nutr Food Res (piperina); Lallemand 2026 RCT 75mg 2x/dia","evidence":"promising"},{"categoria":"SKIN — Biohacking","nome":"Sauna infravermelha (heat therapy)","dose":"15-30 min","frequencia":"3-4x/sem","periodo":"tarde","dias_semana":"seg,qua,sex,sab","modo":"60-80°C; hidratar com eletrólitos antes e depois; evitar nas 2h antes do sono","ciclo":"contínuo","observacao":"Mecanismo HSP/termogênese — distinto de LED (fotobiomodulação)","fonte":"✅ Laukkanen 2015 JAMA Intern Med (KIHD n=2315, 4-7x/sem -63% morte súbita); Patrick 2017 Mayo Clin Proc","evidence":"validated"},{"categoria":"SKIN — Biohacking","nome":"Cold plunge facial","dose":"30 seg - 2 min","frequencia":"3-7x/sem","periodo":"manha","dias_semana":"diario","modo":"rosto submerso em água a 5-10°C; manter respiração calma; máximo 20 seg por ciclo inicial","ciclo":"contínuo","observacao":"Reflexo do mergulho (trigeminal→vago): bradicardia + vasoconstrição local; evitar se arritmia/cardiopatia","fonte":"✅ StatPearls Physiology Diving Reflex (NBK538245); European J Cardiovasc Med 2025","evidence":"validated"},{"categoria":"SKIN — Biohacking","nome":"Banho frio corporal","dose":"2-3 min","frequencia":"3x/sem","periodo":"manha","dias_semana":"seg,qua,sex","modo":"água a 10-15°C; respiração calma; entrada gradual","ciclo":"contínuo","observacao":"Norepinefrina sistêmica, ativação de BAT, dopamina; diferente do cold plunge facial (efeito local)","fonte":"✅ Šrámek 2000 Eur J Appl Physiol; Soberg 2021 Cell Rep Med","evidence":"validated"},{"categoria":"SKIN — Biohacking","nome":"Jejum intermitente 14-16h","dose":"janela alimentar 8-10h","frequencia":"diario","periodo":"noite","dias_semana":"diario","modo":"fechar 20h, abrir 10-12h; eletrólitos durante; ÚNICO jejum por dia","ciclo":"contínuo","observacao":"Aumento de autofagia em humanos demonstrado em obesidade 6 meses","fonte":"✅ Bensalem 2025 J Physiol (PMID 40345145, n=121 6mo iTRE); Sutton 2018 Cell Metab eTRF","evidence":"validated"},{"categoria":"SKIN — Biohacking","nome":"Respiração nasal diurna","dose":"consciente durante atividades","frequencia":"diario","periodo":"tarde","dias_semana":"diario","modo":"boca fechada durante exercício leve e atividades de baixa intensidade","ciclo":"contínuo","observacao":"Aumenta NO nasal >50% vs respiração oral; melhora recuperação muscular pós-exercício","fonte":"✅ Yasuda 1997 (PMID 9504133); Lundberg 1995/2002 Eur Respir J; MDPI Sports 2025 (PMC12567944)","evidence":"validated"},{"categoria":"SKIN — Biohacking","nome":"Caminhada pós-refeição","dose":"10-15 min","frequencia":"2-3x/dia","periodo":"tarde","dias_semana":"diario","modo":"ritmo leve a moderado iniciando 10-15min após cada refeição principal","ciclo":"contínuo","observacao":"Reduz pico glicêmico pós-prandial; controle glicêmico cutâneo previne glicação","fonte":"✅ Engeroff 2023 Sports Med meta-análise (PMC10036272, 8 RCTs); Buffey 2022 Sports Med","evidence":"validated"},{"categoria":"SKIN — Peptides Advanced","nome":"BPC-157","dose":"250-500 mcg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"subcutâneo em jejum; supervisão médica obrigatória","ciclo":"6-8 semanas, pausa 4 semanas","observacao":"Off-label sem aprovação FDA; evidência humana muito limitada; ~200 estudos quase todos do mesmo grupo (Sikiric)","fonte":"⚠️ opss.org review; STAT News 2026 (research limitations); WADA Prohibited List S0; FDA não-aprovado","evidence":"promising"},{"categoria":"SKIN — Peptides Advanced","nome":"GHK-Cu injetável","dose":"1-2 mg","frequencia":"3x/sem","periodo":"noite","dias_semana":"seg,qua,sex","modo":"subcutâneo; combinar com tópico 2% diário para sinergia; supervisão médica","ciclo":"ciclos 6-8 semanas","observacao":"Tópico tem RCT robusto; injetável é off-label, sem RCT humano de longo prazo","fonte":"⚠️ Tópico ✅ Leyden 2002/NEEL 2023; injetável sem RCT humano publicado","evidence":"validated"},{"categoria":"SKIN — Peptides Advanced","nome":"TB-500 (Thymosin Beta-4)","dose":"2-2.5 mg","frequencia":"2x/sem","periodo":"noite","dias_semana":"ter,sex","modo":"subcutâneo; supervisão médica","ciclo":"6-8 semanas, depois pausa 4 semanas","observacao":"Off-label; evidência majoritariamente pré-clínica; sem RCT humano publicado para uso cosmético","fonte":"⚠️ Dados pré-clínicos; sem aprovação FDA; sem estudos humanos publicados para pele","evidence":"promising"},{"categoria":"SKIN — Peptides Advanced","nome":"Epitalon (Epithalon)","dose":"5-10 mg","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"subcutâneo ao anoitecer; supervisão médica","ciclo":"20 dias, repetir 1-2x/ano","observacao":"Off-label; evidência humana muito limitada; quase toda pesquisa do grupo Khavinson (Rússia), com replicação ocidental mínima","fonte":"⚠️ Khavinson 2002+ (animal lifespan signal mixed); Cognitive Vitality ADDF review (replicação limitada); PMC9037278 (oocyte aging)","evidence":"promising"},{"categoria":"SKIN — Peptides Advanced","nome":"CJC-1295 + Ipamorelin","dose":"100-300 mcg cada","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"subcutâneo antes de dormir (em jejum noturno); supervisão médica obrigatória; monitorar IGF-1","ciclo":"12 semanas, pausa 4 semanas","observacao":"Off-label; nenhum aprovado pela FDA; CJC-1295 com dados de Teichman 2006 J Clin Endocrinol Metab","fonte":"⚠️ Teichman 2006 JCEM (CJC-1295 PK humano); FDA não-aprovado; investigacional","evidence":"promising"},{"categoria":"SKIN — Peptides Advanced","nome":"NAD+ IV","dose":"500-1000 mg","frequencia":"1x/sem","periodo":"tarde","dias_semana":"qui","modo":"em clínica especializada apenas; infusão lenta 1-2h","ciclo":"4-8 sessões por ciclo; espaçar","observacao":"Apenas em ambiente clínico; evidência humana para anti-aging cutâneo ainda limitada; estudos focam em adição e neurodegenerativos","fonte":"⚠️ Frontiers Aging 2026 (PMC12907335, 4 dias 500mg pilot); Grant 2019 (PMC6751327 PK study); evidência cosmética indireta","evidence":"promising"},{"categoria":"SKIN — Peptides Advanced","nome":"Melanotan I (afamelanotide / Scenesse)","dose":"implante 16 mg","frequencia":"1x a cada 2 meses","periodo":"manha","dias_semana":"conforme agenda médica","modo":"implante subcutâneo na região supra-ilíaca, inserido por médico especializado; anestesia local opcional","ciclo":"3-4 implantes por ano","observacao":"FDA-aprovado APENAS para Eritropoiética Protoporfiria (EPP); uso estético é off-label; custo elevado (~$50K USD por implante); requer médico; hiperpigmentação sistêmica e aumento de nevos podem ocorrer; exame dermatológico de corpo inteiro 2x/ano recomendado","fonte":"⚠️ Langendonk 2015 NEJM 373(1):48-59 (Phase 3 EPP); Lim 2015 JAMA Dermatology (vitiligo + NB-UVB); FDA approval 2019; EMA approval 2014; >12.000 usos pós-marketing sem eventos graves","evidence":"promising"}],"fat":[{"categoria":"FAT — Routines","nome":"Jejum intermitente 16/8","dose":"janela alimentar 8h","frequencia":"diario","periodo":"manha","dias_semana":"diario","modo":"fechar janela 20h, abrir 12h; eletrólitos durante o jejum; ÚNICO jejum por dia","ciclo":"contínuo","observacao":"Combinar com déficit calórico para perda de gordura; sem benefício adicional vs restrição calórica isolada","fonte":"✅ Huang 2022 Food Sci Nutr meta (8 RCTs, MD -1.48kg, PMC10002957); Su 2025 SR mulheres (n=612, WMD -1.927kg, PMID 41036194); Sutton 2018 Cell Metab eTRF","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Déficit calórico moderado","dose":"300-500 kcal/dia abaixo do TDEE","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"calcular TDEE (BMR × fator atividade), reduzir 300-500 kcal; reavaliar a cada 2-4 semanas; mínimo 1.2g proteína/kg","ciclo":"contínuo até meta + manutenção","observacao":"Déficits >500 kcal/dia aumentam perda de massa magra (>25% do peso perdido); RT+proteína alta preserva FFM","fonte":"✅ Resistance training preserves FFM (PMC12851882, n=304); Longland 2016 AJCN (alta proteína 2.4g/kg+RT durante déficit); meta lean mass sparing PMC9012799","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Sono restaurador 7-9 horas","dose":"7-9 horas","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"blackout total, 18-20°C, horário fixo; sem telas 1h antes; evitar álcool noturno","ciclo":"contínuo","observacao":"Sono <6h reduz leptina em 15.5% e eleva grelina em 14.9%, aumentando apetite","fonte":"✅ Taheri 2004 PLOS Med (Wisconsin Cohort n=1024, PMC535701); Spiegel 2004; Egmond 2023 Obesity RCT; St-Onge 2016 J Clin Sleep Med","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Tracking corporal semanal","dose":"peso + medidas + fotos","frequencia":"1x/sem","periodo":"manha","dias_semana":"seg","modo":"mesmo horário, em jejum, após ir ao banheiro; medir cintura/quadril/coxa; fotos frontal/lateral mesma iluminação","ciclo":"contínuo","observacao":"Auto-monitoramento é um dos preditores mais consistentes de manutenção de peso a longo prazo","fonte":"✅ Burke 2011 J Am Diet Assoc SR; National Weight Control Registry estudos longitudinais","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Hidratação 35 ml/kg + 1g sal","dose":"30-40 ml/kg de água + eletrólitos","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"1g de sal Celta/Himalaia no primeiro copo em jejum; mais em treino/calor; checar cor da urina (clara)","ciclo":"contínuo","observacao":"Água pré-refeição (500ml) reduz ingestão calórica em 13% em adultos com sobrepeso","fonte":"✅ Dennis 2010 Obesity (n=48 RCT, PMID 19661958); Vij 2013 J Clin Diagn Res (water 1.5L/dia, BMI redução)","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Café da manhã proteico","dose":"30-40g proteína","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"30-40g de proteína completa (ovos, whey, queijo cottage); dentro de 60 min após acordar","ciclo":"contínuo","observacao":"Café proteico reduz fome e ingestão de doces; melhora controle glicêmico do dia","fonte":"✅ Leidy 2013 Am J Clin Nutr (n=20, breakfast 35g protein reduziu evening snacking); Wang 2015 (high protein breakfast vs cereal RCT)","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Caminhada pós-refeição","dose":"10-15 min","frequencia":"2-3x/dia","periodo":"tarde,noite","dias_semana":"diario","modo":"ritmo leve a moderado, iniciando 10-15 min após cada refeição principal","ciclo":"contínuo","observacao":"Reduz pico glicêmico pós-prandial em ~12-37%; mecanismo direto sobre captação de glicose muscular","fonte":"✅ Engeroff 2023 Sports Med meta-análise (PMC10036272, 8 RCTs); Buffey 2022 Sports Med; Reynolds 2016 Diabetologia","evidence":"validated"},{"categoria":"FAT — Routines","nome":"10.000 passos/dia","dose":"8000-10000 passos","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"distribuído ao longo do dia; mínimo 6000 para >60 anos, 8000 para <60 anos","ciclo":"contínuo","observacao":"Mortalidade reduz progressivamente até 6-8K passos (>60a) ou 8-10K (<60a); efeito linear em peso modesto","fonte":"✅ Paluch 2022 Lancet Public Health meta (15 cohorts, n≈50K, PMC9289978); Banach 2023 Eur J Prev Cardiol (1000 passos = -15% mortalidade); Kraus 2019 Med Sci Sports Exerc","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Higiene digital noturna","dose":"1h sem telas antes de dormir","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"substituir por leitura/alongamento; filtro de luz azul (>460nm) se necessário usar telas","ciclo":"contínuo","observacao":"Luz azul à noite suprime melatonina, atrasa início do sono, prejudica metabolismo glicêmico e leptina","fonte":"✅ Höhn 2020 SLEEP Advances meta; Frontiers Neurology 2025 SR; van der Lely 2015 J Adolesc Health (RCT blue light blocking glasses)","evidence":"validated"},{"categoria":"FAT — Routines","nome":"Mouth taping noturno","dose":"1 fita 3M Micropore vertical","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"fita vertical pequena sobre os lábios; testar tolerância gradual; APENAS se via nasal desobstruída","ciclo":"contínuo após adaptação","observacao":"Apenas com via nasal desobstruída; NÃO usar com obstrução nasal/OSA moderada-severa — risco de asfixia","fonte":"⚠️ Rhee 2025 PLOS One SR (10 estudos, n=213); benefício documentado apenas em ronco/OSA leve","evidence":"promising"},{"categoria":"FAT — Nutrition","nome":"Proteína 1.6-2.2 g/kg distribuída","dose":"1.6-2.2 g/kg em 4 refeições","frequencia":"4x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"0.4 g/kg por refeição (mínimo 25-30g por refeição) em 4 refeições; durante déficit calórico priorizar limite superior","ciclo":"contínuo","observacao":"Plateau de síntese proteica muscular em 1.6 g/kg/dia; limite superior 2.2 g/kg em treinados/déficit","fonte":"✅ Morton 2018 BJSM meta (plateau 1.6, upper 95%CI 2.2); Schoenfeld/Aragon 2018 JISSN (0.4g/kg/refeição em 4 refeições, PMC5828430)","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Whey protein isolado","dose":"25-30 g por dose","frequencia":"1-2x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"pós-treino e/ou substituindo refeição lanche; misturar em água ou leite vegetal","ciclo":"contínuo","observacao":"Efeito modesto em composição corporal isolado; potencializa RT em mulheres (lean mass +0.37kg)","fonte":"✅ Sepandi 2022 Clin Nutr ESPEN meta (35 RCTs n=1902, BMI -0.156, WC -0.448, PMID 36038997); Bergia 2018 (women lean mass)","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Carbs complexos pré-treino","dose":"30-50 g 1-2h antes de treino","frequencia":"1x/dia treino","periodo":"tarde","dias_semana":"seg,qua,sex","modo":"aveia, batata doce, arroz integral, frutas; baixo IG para evitar pico/queda glicêmica durante treino","ciclo":"contínuo, apenas em dias de treino intenso","observacao":"Glicogênio adequado preserva performance e massa magra; déficit extremo de carbs reduz intensidade de RT","fonte":"✅ ACSM/ISSN Position Stand 2017 nutrient timing; Kerksick 2017 JISSN (PMC5596471)","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Ômega-3 EPA/DHA","dose":"2-3 g (EPA+DHA combinados)","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição que contenha gordura; >2:1 ratio EPA:DHA preferível para inflamação","ciclo":"contínuo","observacao":"Reduz inflamação sistêmica, preserva massa magra em idosos; modesto efeito direto em gordura visceral","fonte":"✅ Smith 2015 Clin Sci (n=44, lean mass preservation); Du 2015 PLoS One meta (omega-3 + RT); Bender 2014 Nutr Reviews","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Fibras 25-35 g/dia (foco solúvel)","dose":"25-35 g totais; 10-15g solúvel","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"vegetais, frutas, leguminosas, aveia, psyllium; aumentar gradualmente para tolerância","ciclo":"contínuo","observacao":"Cada 14g de fibra reduz ingestão calórica em ~10%; aumenta saciedade via CCK, PYY, GLP-1","fonte":"✅ Howarth 2001 Nutr Rev meta (22 estudos); Reynolds 2019 Lancet (fiber high quality, MASS evidence); Stewart 2009","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Psyllium pré-refeição","dose":"10-15 g antes de refeição principal","frequencia":"1-2x/dia","periodo":"tarde,noite","dias_semana":"diario","modo":"dissolver em 300ml de água; tomar 15-30 min antes da refeição; aumentar consumo de água ao longo do dia","ciclo":"contínuo","observacao":"10.8g/dia pré-refeição reduz peso, BMI e WC em sobrepeso/obesos em meta-análise","fonte":"✅ Brum 2016 Appetite (PMC P&G clinical data); meta-análise 2025 (psyllium 10.8g/dia, link.springer.com 10.1186/s41043-025-01103-x); Pal 2011","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Ordem da refeição (vegetais/proteína antes)","dose":"vegetais → proteína → carbo","frequencia":"3x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"consumir vegetais e proteína primeiro; carboidratos por último; intervalo de 10-15 min entre componentes ideal","ciclo":"contínuo","observacao":"Reduz iAUC pós-prandial em 73% em T2D; benefício também em normoglicêmicos e GDM","fonte":"✅ Shukla 2015 Diabetes Care (n=11 T2D, PMID 26106234); Imai 2014; Tricò 2016 (T2D); meta SR 2026 e-cnr","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Redução de ultraprocessados","dose":"<20% das calorias totais","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"priorizar alimentos in natura ou minimamente processados (NOVA categoria 1); identificar UPF por longo de lista de ingredientes/aditivos","ciclo":"contínuo","observacao":"Mesma composição de macros: UPF causa +508 kcal/dia ad libitum vs unprocessed, +0.9kg em 2 semanas","fonte":"✅ Hall 2019 Cell Metab RCT NIH (n=20 crossover metabolic ward, PMC6953886); Hall 2025 dados Cell preliminares; Monteiro 2019 NOVA classification","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Café/chá verde como pré-treino","dose":"200-400 mg cafeína OU 300mg EGCG","frequencia":"1x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"café preto, chá verde matcha, ou cápsula de cafeína anidra 30-60 min pré-treino","ciclo":"contínuo (pausa 1 semana a cada 8 semanas)","observacao":"Cafeína 3-6 mg/kg eleva fat oxidation; combo cafeína+EGCG potencializa termogênese diária","fonte":"✅ Guest 2021 ISSN position stand caffeine (PMC7777221); Hursel 2009 meta green tea -1.31kg (PMID 19597519); Acheson 1980 thermogenesis","evidence":"validated"},{"categoria":"FAT — Nutrition","nome":"Álcool: redução ou eliminação","dose":"0-7 drinks/semana","frequencia":"controle","periodo":"noite","dias_semana":"fim-de-semana ou eliminação","modo":"se consumir, vinho seco ou destilados puros; evitar misturas açucaradas; nunca em dia de treino intenso ou primeira refeição do dia","ciclo":"contínuo","observacao":"Álcool fornece 7 kcal/g, suprime oxidação de gordura por 6+h, aumenta cortisol, prejudica sono profundo e síntese proteica","fonte":"⚠️ Suter 2005 Forum Nutr; Parr 2014 PLoS One (alcohol + post-exercise reduz MPS 24%); WHO/AHA guidelines","evidence":"promising"},{"categoria":"FAT — Topical Basics","nome":"Cafeína tópica anti-celulite","dose":"5-10% creme/gel","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"massagear 3-5 min em movimentos circulares em coxas, glúteos, abdômen; após banho","ciclo":"contínuo","observacao":"Evidência clínica modesta; melhores resultados em formulações combinadas (cafeína+retinol+forskolina+L-carnitina); nenhum tópico aprovado como tratamento médico","fonte":"⚠️ Dupont 2014 Clin Cosmet Investig Dermatol RCT (PMC3933246, 81% melhora active combo vs 32% placebo); MDPI Cosmetics 2026 13/1/35; Velasco 2008","evidence":"promising"},{"categoria":"FAT — Topical Basics","nome":"Aminofilina tópica","dose":"0.5-2% creme","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"massagear em coxas, glúteos, abdômen; pode causar irritação em pele sensível; teste de patch primeiro","ciclo":"12 semanas, reavaliar","observacao":"Evidência preliminar com sample sizes pequenos; efeito mais consistente em circunferência de coxa que em fat mass","fonte":"⚠️ Frontiers Endocrinol 2023 SR aminophylline (5 sub-trials, n=117); Greenway 1995 patent; mecanismo PDE inhibitor","evidence":"promising"},{"categoria":"FAT — Topical Basics","nome":"L-carnitina tópica","dose":"1-3% creme","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"geralmente em formulações combinadas com cafeína; massagear áreas-alvo","ciclo":"contínuo","observacao":"Pouca evidência isolada; quase sempre em combo lipolytic; resultados modestos","fonte":"⚠️ Escalante 2019 JCD (lipoxyderm combo); MDPI Cosmetics 2026 review (L-carnitine + caffeine combo)","evidence":"promising"},{"categoria":"FAT — Topical Advanced","nome":"Yohimbina tópica","dose":"0.2-0.5% creme","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"aplicar pré-treino aeróbico em áreas com gordura teimosa (coxas, abdômen baixo, lombar); alpha-2 antagonista local","ciclo":"8-12 semanas, ciclos","observacao":"Off-label; sem aprovação FDA para uso tópico; evidência em pequenos RCTs com formulações combinadas","fonte":"⚠️ Escalante 2019 J Cosmet Dermatol (lipoxyderm); Greenway 1995 patent (US4588724); McCarty 2002 Med Hypotheses","evidence":"promising"},{"categoria":"FAT — Topical Advanced","nome":"Centella asiática tópica","dose":"extrato titulado 1-7%","frequencia":"2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"creme ou gel em áreas afetadas por celulite; massagear até absorção","ciclo":"contínuo, mínimo 3-4 meses","observacao":"85% melhora em celulite em estudo com Madecassol 4x/dia por 4 meses; mais bem-estabelecido em wound healing","fonte":"⚠️ Bylka 2013 (cellulite revisão); Brinkhaus 2000 (Madecassol n=60 4 meses); Witkowska 2024 Pharmaceutics PMC11510310 (wound healing)","evidence":"promising"},{"categoria":"FAT — Topical Advanced","nome":"Escina (castanha-da-índia)","dose":"1-2% creme/gel","frequencia":"2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"aplicar em pernas para reduzir aparência de varizes superficiais e edema; massagear de baixo para cima","ciclo":"contínuo","observacao":"Evidência mais robusta para insuficiência venosa crônica (uso oral); tópico para edema/celulite menos validado","fonte":"⚠️ Pittler 2012 Cochrane SR (escina oral para CVI eficaz); MDPI Cosmetics 2026 13/1/35 (escin in cellulite formulations)","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Ultrassom portátil cavitacional","dose":"15-20 min por área","frequencia":"2x/sem","periodo":"noite","dias_semana":"ter,sab","modo":"frequência 1-3 MHz; aplicar gel condutor; movimentos circulares; APENAS dispositivos com certificação adequada","ciclo":"8-12 sessões por ciclo","observacao":"Dispositivos home menos potentes que profissionais; pequenas reduções de circunferência em estudos clínicos","fonte":"⚠️ Moreno-Moraga 2007 Lasers Surg Med (HIFU profissional); home devices têm evidência limitada","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Massagem vibratória corporal","dose":"10-15 min","frequencia":"3-5x/sem","periodo":"noite","dias_semana":"seg,qua,sex","modo":"dispositivos manuais ou plataformas vibratórias; áreas com celulite/retenção; pressão moderada","ciclo":"contínuo","observacao":"Estimula drenagem linfática local; sem evidência robusta de redução de gordura per se; melhora aparência de celulite","fonte":"⚠️ Sañudo 2013 J Sports Med Phys Fitness (vibração corporal); Milanese 2013 Clin Physiol Funct Imaging","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Escova seca (dry brushing)","dose":"3-5 min antes do banho","frequencia":"diario","periodo":"manha","dias_semana":"diario","modo":"escova de cerdas naturais; movimentos longos do pé em direção ao coração; em pele seca antes do banho","ciclo":"contínuo","observacao":"Estimula circulação local e drenagem linfática superficial; sem evidência de efeito direto em gordura","fonte":"⚠️ Sem RCT publicado; uso histórico e tradição ayurveda; evidência mecanicista apenas","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Radiofrequência corporal portátil","dose":"15-20 min por área","frequencia":"2x/sem","periodo":"noite","dias_semana":"seg,qui","modo":"movimentos circulares com gel condutor; ~40-42°C; em abdômen, coxas, glúteos; evitar áreas com implantes metálicos","ciclo":"8-12 sessões por ciclo","observacao":"RF corporal tem evidência de redução de circunferência e melhora de celulite; home devices < profissionais","fonte":"✅ Sadick 2016 J Cosmet Laser Ther; Mlosek 2014 (Vela Shape); home RF Ai 2024 JCD facial extrapolável","evidence":"validated"},{"categoria":"FAT — Devices","nome":"Ventosa anti-celulite (cupping)","dose":"5-10 min por área","frequencia":"2-3x/sem","periodo":"noite","dias_semana":"seg,qua,sex","modo":"ventosa de silicone deslizante com óleo; movimentos do pé em direção ao coração; pressão moderada","ciclo":"contínuo","observacao":"Estimula circulação local; pode causar hematomas; sem evidência robusta de redução de gordura subcutânea","fonte":"⚠️ Mostafa 2013 (vacuum massage anti-cellulite RCT); evidência preliminar com sample pequeno","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Foam roller","dose":"10-15 min","frequencia":"3-5x/sem","periodo":"manha,noite","dias_semana":"diario","modo":"rolar todos os grupos musculares grandes; 30-60 seg por área; pressão tolerável","ciclo":"contínuo","observacao":"Reduz dor muscular tardia (DOMS), melhora ROM e recuperação; sem efeito direto em gordura","fonte":"✅ Wiewelhove 2019 Front Physiol meta-análise (n=21 estudos, foam rolling); MacDonald 2014 Med Sci Sports Exerc","evidence":"validated"},{"categoria":"FAT — Devices","nome":"Bota de compressão pneumática","dose":"20-30 min","frequencia":"3-5x/sem","periodo":"noite","dias_semana":"seg,qua,sex,dom","modo":"uso após treino; pressão sequencial dos pés ao quadril; melhora retorno venoso e drenagem","ciclo":"contínuo, pós-treino","observacao":"Acelera remoção de metabólitos pós-exercício; sem evidência de redução de gordura per se","fonte":"⚠️ Sands 2014 J Strength Cond Res; uso popular em recuperação, evidência clínica preliminar","evidence":"promising"},{"categoria":"FAT — Devices","nome":"EMS abdominal/corporal","dose":"20-30 min","frequencia":"3-5x/sem","periodo":"manha,tarde","dias_semana":"seg,ter,qua,qui,sex","modo":"eletrodos sobre grupos musculares; intensidade tolerável; combinar com exercício ativo para melhor resultado","ciclo":"12 semanas, reavaliar","observacao":"Redução modesta de cintura em obesos; melhor com RF combinado (-19.6% fat reduction)","fonte":"⚠️ Choi 2018 JNMA RCT (n=60 12sem, PMID 31065133); EMS+RF combo PMC11333964; whole-body EMS Kemmler 2018","evidence":"promising"},{"categoria":"FAT — Devices","nome":"Sauna infravermelha","dose":"15-30 min","frequencia":"3-4x/sem","periodo":"tarde","dias_semana":"seg,qua,sex,sab","modo":"60-80°C; hidratar com eletrólitos antes e depois; evitar 2h antes do sono","ciclo":"contínuo","observacao":"Reduz mortalidade cardiovascular; efeito em peso modesto via perda de água; benefício metabólico via HSP","fonte":"✅ Laukkanen 2015 JAMA Intern Med (KIHD n=2315, 4-7x/sem -63% morte súbita); Patrick 2017 Mayo Clin Proc","evidence":"validated"},{"categoria":"FAT — Devices","nome":"Banho frio corporal","dose":"2-5 min","frequencia":"3x/sem","periodo":"manha","dias_semana":"seg,qua,sex","modo":"água a 10-15°C; respiração calma; entrada gradual; evitar imediatamente pós-treino de força (atenua hipertrofia)","ciclo":"contínuo","observacao":"Ativa BAT, aumenta norepinefrina e dopamina; efeito em gordura corporal modesto em humanos","fonte":"✅ Šrámek 2000 Eur J Appl Physiol; Soberg 2021 Cell Rep Med; van der Lans 2013 JCI cold acclimation (BAT recruitment)","evidence":"validated"},{"categoria":"FAT — Devices","nome":"Cold plunge / imersão fria","dose":"1-3 min","frequencia":"3-5x/sem","periodo":"manha","dias_semana":"seg,ter,qua,qui,sex","modo":"água a 5-10°C; mergulho do pescoço para baixo; respiração diafragmática; sair antes de tremer descontrolado","ciclo":"contínuo após adaptação","observacao":"Ativa BAT e nonshivering thermogenesis; van der Lans 2013 mostrou recrutamento de BAT em 10 dias de cold exposure","fonte":"✅ Cypess 2012 PNAS (cold > sympathomimetics for BAT); van der Lans 2013 JCI (PMC4213359); Yoneshiro 2011 Obesity","evidence":"validated"},{"categoria":"FAT — Supplements","nome":"Berberina HCL","dose":"500 mg, 3x/dia (1500 mg total)","frequencia":"3x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"1 cápsula com cada refeição principal; ciclos de 8-12 semanas com pausas de 4 semanas","ciclo":"8-12 semanas, pausar 4 semanas","observacao":"Reduz glicemia, triglicerídeos, cintura (-3.27 cm) e BMI (-0.435); efeito comparável a metformina em pré-DM","fonte":"✅ Liu 2025 Front Pharmacol meta (PMC12307485, PMID 40740996); Lan 2015 J Ethnopharmacol meta; Yin 2008 Metabolism","evidence":"validated"},{"categoria":"FAT — Supplements","nome":"Cromo picolinato","dose":"200-400 mcg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição; mais eficaz em pessoas com resistência à insulina ou pré-DM","ciclo":"contínuo, reavaliar 3 meses","observacao":"Modesta perda de peso (-1.1 a -1.2 kg em 10-13 semanas); efeito robusto apenas em pré-DM/IR","fonte":"⚠️ Pittler 2003 Int J Obes meta (10 RCTs); Onakpoya 2013 Obes Rev; FDA qualified health claim 2005; Lpi.oregonstate.edu","evidence":"promising"},{"categoria":"FAT — Supplements","nome":"Magnésio bisglicinato","dose":"200-400 mg","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"antes de dormir (também auxilia sono); bisglicinato tem alta biodisponibilidade e menos efeito laxativo","ciclo":"contínuo","observacao":"Melhora sensibilidade à insulina; efeito direto em peso modesto, indireto via sono e glicemia","fonte":"⚠️ Veronese 2021 Pharmacol Res meta (PMC8619199, T2D ou risco); Mooren 2011 (RCT 6mo, n=52 normomagnesemia, PMID 21205110); Simental-Mendía 2016","evidence":"promising"},{"categoria":"FAT — Supplements","nome":"L-carnitina oral","dose":"1500-2000 mg","frequencia":"1-2x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"tomar com refeição contendo carboidrato (insulina aumenta captação muscular)","ciclo":"12 semanas, pausar 4 semanas","observacao":"Perda de peso modesta (-1.21 kg em meta de 37 RCTs, n=2292); dose-resposta máxima em 2000 mg/dia","fonte":"⚠️ Pooyandjoo 2016 Obes Rev meta (PMID 31743774); Talenezhad 2020 Clin Nutr ESPEN (37 RCTs); Askarpour 2020","evidence":"promising"},{"categoria":"FAT — Supplements","nome":"EGCG / chá verde extrato","dose":"300-500 mg EGCG","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"tomar com refeição que contenha carboidrato; evitar em jejum (hepatotoxicidade hepática rara); ciclar","ciclo":"12 semanas, pausar 4 semanas","observacao":"Efeito pequeno mas consistente em meta-análise (-1.31kg); melhor combinado com cafeína; cuidado hepatotoxicidade >800mg","fonte":"⚠️ Hursel 2009 meta (PMID 19597519, n=49 estudos); Gholami 2024 JISSN (PMC11445908); EFSA 2018 segurança >800mg/dia","evidence":"promising"},{"categoria":"FAT — Supplements","nome":"Probióticos Akkermansia muciniphila","dose":"10^9-10^10 CFU","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"tomar à noite em jejum ou antes de dormir; pode ser na forma pasteurizada (postbiotic) ou viva","ciclo":"12 semanas, reavaliar","observacao":"Próxima geração de probiótico; redução de peso e BMI em RCT recente; evidência humana ainda limitada","fonte":"⚠️ You 2025 Food Sci Hum Wellness RCT (8 semanas); animal meta -10.4% peso ganho (PMC11510203); Depommier 2019 Nat Med (n=32 obese, segurança)","evidence":"promising"},{"categoria":"FAT — Supplements","nome":"Ômega-3 EPA/DHA 2-3g","dose":"2-3 g EPA+DHA combinados","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; forma de óleo de peixe purificado ou alga (vegetariano)","ciclo":"contínuo","observacao":"Preserva massa magra em idosos; modesto em redução de gordura; benefício cardiovascular comprovado","fonte":"✅ Smith 2015 Clin Sci (n=44, lean mass); Bender 2014 Nutr Reviews; AHA Diet Guidelines","evidence":"validated"},{"categoria":"FAT — Supplements","nome":"Cafeína anidra pré-treino","dose":"3-6 mg/kg","frequencia":"1x/dia","periodo":"manha,tarde","dias_semana":"treino","modo":"30-60 min pré-treino; 200-400mg típico; evitar após 14h se sensível ao sono","ciclo":"contínuo (pausa 1 semana a cada 8 semanas)","observacao":"Padrão-ouro como ergogênico; aumenta fat oxidation em exercício submáximo; mantém performance em déficit","fonte":"✅ Guest 2021 ISSN position stand (PMC7777221); Goldstein 2010; meta-analysis fat oxidation 2022 (PMID, IJSNEM)","evidence":"validated"},{"categoria":"FAT — Supplements","nome":"Glucomanano (konjac)","dose":"1-2 g antes de refeição","frequencia":"3x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"tomar com 300ml de água 15-30 min antes da refeição; aumentar consumo de água ao longo do dia","ciclo":"contínuo","observacao":"Fibra solúvel de alta viscosidade; aumenta saciedade; FDA reconhece para colesterol; modesto efeito em peso","fonte":"⚠️ Sood 2008 Am J Clin Nutr meta; Onakpoya 2014 J Am Coll Nutr; EFSA 2010 health claim","evidence":"promising"},{"categoria":"FAT — Exercise","nome":"Treino de força 3-4x/semana","dose":"45-60 min por sessão","frequencia":"3-4x/sem","periodo":"manha,tarde,noite","dias_semana":"seg,ter,qui,sex","modo":"exercícios compostos (agachamento, levantamento terra, supino, remada); 3-5 séries de 6-12 reps; carga progressiva","ciclo":"contínuo","observacao":"Preserva e aumenta massa magra durante déficit calórico; aumenta gasto metabólico de repouso","fonte":"✅ Wewege 2021 Sports Med meta (RT vs AT vs CT body fat); PMC12851882 (n=304 RT preserva FFM em déficit); Longland 2016 AJCN","evidence":"validated"},{"categoria":"FAT — Exercise","nome":"HIIT 2-3x/semana","dose":"20-30 min por sessão","frequencia":"2-3x/sem","periodo":"manha,tarde","dias_semana":"ter,qui,sab","modo":"intervalos de 30-60 seg a 85-95% FCmax + 60-90 seg de recuperação ativa; bike, esteira, elíptico","ciclo":"contínuo","observacao":"Reduz BF% (-1.53%) e FM (-1.86kg); EPOC mantém gasto elevado horas pós-treino; cycling > treadmill","fonte":"✅ Wewege 2017 Obes Rev meta (PMC10054577); Khalafi 2024 Sports Med umbrella; Maillard 2018 Sports Med","evidence":"validated"},{"categoria":"FAT — Exercise","nome":"Zona 2 cardio (LISS)","dose":"30-60 min","frequencia":"3-4x/sem","periodo":"manha,tarde","dias_semana":"seg,qua,sex,dom","modo":"intensidade onde se mantém conversação confortável (60-70% FCmax); caminhada rápida, bike leve, natação leve","ciclo":"contínuo","observacao":"Eleva fat oxidation em sedentários; em treinados, efeito limitado vs HIIT; aderência alta","fonte":"⚠️ Storoschuk 2024 Sports Med narrative review; Granata meta (intensidade <60% não aumenta mitochondrial density em untrained)","evidence":"promising"},{"categoria":"FAT — Exercise","nome":"Sol matinal","dose":"10-20 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"primeiras 2h após acordar; sem proteção solar nesse momento; pele e olhos expostos (não olhar direto)","ciclo":"contínuo","observacao":"Sincroniza ritmo circadiano, regulando cortisol/melatonina; melhora composição corporal via sono e horário das refeições","fonte":"✅ Scheer/Buijs 1999 J Clin Endocrinol Metab 84:3395; Jung/Lockley/Czeisler 2010 J Biol Rhythms; Wright 2013 Curr Biol","evidence":"validated"},{"categoria":"FAT — Exercise","nome":"Respiração 4-7-8 / diafragmática","dose":"5-10 min","frequencia":"2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"inspirar pelo nariz 4 seg, segurar 7 seg, expirar pela boca 8 seg; 4-8 ciclos","ciclo":"contínuo","observacao":"Ativa parassimpático; reduz cortisol agudo; modesto efeito em HRV; aderência alta como prática de estresse","fonte":"⚠️ Magnon 2021 Sci Rep (slow breathing HRV); Russo 2017 Breathe (slow breathing review); Jerath 2006 Med Hypotheses","evidence":"promising"},{"categoria":"FAT — Exercise","nome":"CGM educativo","dose":"sensor por 14 dias","frequencia":"fase educativa","periodo":"manha,tarde,noite","dias_semana":"diario por 2-4 semanas","modo":"usar 1-2 sensores (14-28 dias) para mapear resposta glicêmica individual; identificar gatilhos; APENAS uso educativo curto, não monitoramento contínuo","ciclo":"2-4 semanas, fase educativa","observacao":"Não há evidência robusta de benefício clínico em não-diabéticos; útil em pré-DM e fase educativa curta","fonte":"⚠️ JHU Bloomberg 2026 (publichealth.jhu.edu); VCU Health 2024; Mass Gen Brigham 2025 (correlação com HbA1c desaparece em não-DM); Klonoff 2020 J Diabetes Sci Technol","evidence":"promising"},{"categoria":"FAT — Exercise","nome":"HRV monitoring matinal","dose":"1-2 min ao acordar","frequencia":"diario","periodo":"manha","dias_semana":"diario","modo":"ao acordar, antes de levantar; anel/relógio/peito; registrar tendência de 7 dias, não dia isolado","ciclo":"contínuo","observacao":"Útil para detectar overtraining e impacto de estresse/sono em treino; correlação com peso modesta","fonte":"⚠️ Barbell Medicine HRV review; Düking 2020 Int J Sports Physiol Perform; Plews 2013 Sports Med (HRV-guided training)","evidence":"promising"},{"categoria":"FAT — Peptides Advanced","nome":"Semaglutide (Wegovy/Ozempic)","dose":"0.25-2.4 mg/sem SC","frequencia":"1x/sem","periodo":"manha,tarde,noite","dias_semana":"conforme prescrição médica","modo":"iniciar 0.25 mg/sem e escalar conforme tolerância gastrointestinal; aplicar abdomen, coxa ou braço; supervisão médica obrigatória","ciclo":"contínuo enquanto sob supervisão médica","observacao":"FDA-aprovado Wegovy para obesidade (2021); -13.7% peso em 72 semanas (SURMOUNT-5); supervisão obrigatória","fonte":"✅ Wilding 2021 NEJM STEP-1 (n=1961, -14.9% 68wk); FDA Wegovy 2021; SURMOUNT-5 vs tirzepatide","evidence":"validated"},{"categoria":"FAT — Peptides Advanced","nome":"Tirzepatide (Zepbound/Mounjaro)","dose":"2.5-15 mg/sem SC","frequencia":"1x/sem","periodo":"manha,tarde,noite","dias_semana":"conforme prescrição médica","modo":"iniciar 2.5 mg/sem e escalar mensalmente; aplicar abdomen, coxa ou braço; supervisão médica obrigatória","ciclo":"contínuo enquanto sob supervisão médica","observacao":"FDA-aprovado Zepbound Nov 2023; -20.2% peso em 72 semanas; superior a semaglutide head-to-head; aprovado também para OSA","fonte":"✅ Jastreboff 2022 NEJM SURMOUNT-1 (-22.5% 72wk); SURMOUNT-5 NEJM 2026 (vs sema); FDA Zepbound Nov 2023; SURMOUNT-OSA 2024","evidence":"validated"},{"categoria":"FAT — Peptides Advanced","nome":"Tesamorelin (Egrifta SV/WR)","dose":"2 mg/dia SC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"aplicar antes de dormir; FDA-aprovado APENAS para HIV-lipodistrofia; uso em não-HIV é off-label","ciclo":"contínuo enquanto sob supervisão médica","observacao":"FDA-aprovado para visceral fat em HIV-lipodistrofia (2010, F8 WR Mar 2025); off-label para visceral fat em não-HIV","fonte":"✅ Falutz 2007 NEJM (Phase 3 HIV); Stanley 2014 JAMA (HIV); FDA Egrifta SV 2010 + Egrifta WR March 2025; off-label em não-HIV","evidence":"validated"},{"categoria":"FAT — Peptides Advanced","nome":"Retatrutide (investigacional)","dose":"1-12 mg/sem SC","frequencia":"1x/sem","periodo":"manha,tarde,noite","dias_semana":"ainda não disponível clinicamente","modo":"ainda em fase 3; expectativa de FDA approval 2026; supervisão médica obrigatória se disponível em research","ciclo":"ainda não definido (em desenvolvimento)","observacao":"Triplo agonista GLP-1/GIP/glucagon; ainda investigacional; WADA Prohibited; mais potente classe em desenvolvimento","fonte":"⚠️ Jastreboff 2023 NEJM Phase 2 (24.2% em 48wk, PMID 37296898); TRIUMPH-4 Dec 2025 (28.7% em 68wk); FDA approval esperado 2026","evidence":"promising"},{"categoria":"FAT — Peptides Advanced","nome":"AOD-9604","dose":"300-500 mcg SC","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"subcutâneo em jejum; supervisão médica obrigatória","ciclo":"12 semanas, pausa 4 semanas","observacao":"Off-label; resultados modestos em Phase IIb (-2.6kg em 12wk vs -0.8kg placebo); desenvolvimento comercial terminado; WADA Prohibited","fonte":"⚠️ Heffernan 2001 Endocrinology (animal); Metabolic Pharmaceuticals Phase IIb terminada; WADA Prohibited List S2; sem aprovação FDA","evidence":"promising"},{"categoria":"FAT — Peptides Advanced","nome":"CJC-1295 + Ipamorelin","dose":"100-300 mcg cada SC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"subcutâneo antes de dormir em jejum noturno; supervisão médica obrigatória; monitorar IGF-1","ciclo":"12 semanas, pausa 4 semanas","observacao":"Off-label; nenhum aprovado pela FDA; CJC-1295 com dados Teichman 2006 (PK em humanos); resultados em composição corporal anedóticos","fonte":"⚠️ Teichman 2006 JCEM (CJC-1295 PK humano); FDA não-aprovado; investigacional; WADA Prohibited","evidence":"promising"},{"categoria":"FAT — Peptides Advanced","nome":"BPC-157","dose":"250-500 mcg SC","frequencia":"1-2x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"subcutâneo em área próxima a lesão se uso para recuperação; supervisão médica obrigatória","ciclo":"6-8 semanas, pausa 4 semanas","observacao":"Off-label sem aprovação FDA; evidência humana muito limitada; ~200 estudos quase todos do mesmo grupo (Sikiric)","fonte":"⚠️ opss.org review; STAT News 2026; WADA Prohibited List S0; FDA não-aprovado; quase toda evidência pré-clínica","evidence":"promising"},{"categoria":"FAT — Peptides Advanced","nome":"MOTS-c","dose":"5-15 mg/sem SC","frequencia":"1-2x/sem","periodo":"manha","dias_semana":"seg,qui","modo":"peptídeo mitocondrial; supervisão médica obrigatória; ainda não aprovado","ciclo":"8-12 semanas, pausa 4 semanas","observacao":"Off-label sem aprovação FDA; evidência humana mínima; estudos pré-clínicos promissores em metabolismo de glicose","fonte":"⚠️ Lee 2015 Cell Metab (descoberta MOTS-c, ratos); Reynolds 2021 Aging Cell (humano correlacional); investigacional","evidence":"promising"}],"muscle":[{"categoria":"MUSCLE — Routines","nome":"Treino de força fundamental 3-4x/sem","dose":"45-75 min por sessão","frequencia":"3-4x/sem","periodo":"manha,tarde,noite","dias_semana":"seg,ter,qui,sex","modo":"exercícios compostos (agachamento, levantamento terra, supino, remada, military press); 3-5 séries de 6-12 reps; carga progressiva","ciclo":"contínuo","observacao":"Frequência 2-3x/semana por grupo muscular é ótima para hipertrofia; 4-6x para avançados; cada grupo trabalhado pelo menos 2x/sem para volume","fonte":"✅ Schoenfeld 2016 Sports Med meta (PMID 27102172); Schoenfeld 2017 J Sports Sci dose-response volume (~0.37% hipertrofia/set); meta-regressão SportRxiv 2024","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Volume semanal por grupo muscular","dose":"10-20 séries semanais","frequencia":"3-4x/sem","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"começar em 10 séries/semana por grupo; aumentar progressivamente até 15-20; dividir em 2+ sessões","ciclo":"contínuo com deload a cada 4-8 semanas","observacao":"Relação dose-resposta: 10+ séries/sem superior a <5; ganhos diminuem em retornos com volumes muito altos; recovery limita","fonte":"✅ Schoenfeld 2017 J Sports Sci meta (15 estudos); Krieger meta 2010 (séries/exercício); Baz-Valle 2021 J Strength Cond Res SR","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Progressão de carga (overload)","dose":"+2-5% carga ou +1-2 reps por semana","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"uma vez que se completa todas as séries no topo do range de reps com boa forma, adicionar uma série ou aumentar carga em 2-5%","ciclo":"contínuo","observacao":"Princípio fundamental para hipertrofia; sem progressão sistemática, ganhos param em 8-12 semanas","fonte":"✅ Plotkin 2022 PeerJ (overload methods); Schoenfeld 2021 Sports Med (mechanical tension primary driver); NSCA Essentials of Strength Training","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Tempo de execução (TUT) controlado","dose":"2-4 seg excêntrica, 1-2 seg concêntrica","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"controlar fase excêntrica (descida) por 2-4 segundos; concêntrica explosiva mas controlada","ciclo":"contínuo","observacao":"Excêntrica controlada (TUT) aumenta MPS via maior tempo sob tensão; reps <10seg eficazes; >10seg podem prejudicar","fonte":"✅ Schoenfeld 2015 J Strength Cond Res tempo de execução SR; Burd 2012 PLoS One TUT 6s vs 1s; Wilk 2020 meta (PMID, eccentric tempo)","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Deload programado","dose":"1 semana a cada 4-8 semanas","frequencia":"1 semana/ciclo","periodo":"manha,tarde,noite","dias_semana":"a cada 4-8 semanas","modo":"reduzir volume em 30-50% (menos séries) mantendo intensidade e frequência similares; OU reduzir intensidade mantendo volume","ciclo":"cíclico","observacao":"Hipertrofia preservada com deloads; força pode ser ligeiramente afetada; reseta fadiga acumulada","fonte":"✅ Coleman 2024 Front Physiol RCT 9wk deload vs traditional (PMC10809978, PMID 38274324); Bell 2025 Sports Med practical approach","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Sono restaurador 7-9 horas","dose":"7-9 horas","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"blackout total, 18-20°C, horário fixo; sem telas 1h antes; cobertor pesado opcional","ciclo":"contínuo","observacao":"GH pulsa em sono profundo (SWS); sono curto reduz IGF-1 e testosterona, eleva cortisol, prejudica MPS e força","fonte":"✅ Chennaoui 2020 Sleep Med Rev GH/IGF-1 axis (PMID 31778942); Van Cauter 2000; Dattilo 2011 Med Hypotheses (sleep & MPS)","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Hidratação 35 ml/kg + 1g sal","dose":"30-40 ml/kg + eletrólitos","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"1g sal Celta/Himalaia no primeiro copo em jejum; +500ml por hora de treino intenso; checar cor da urina","ciclo":"contínuo","observacao":"Desidratação >2% reduz força em 5-10% e MPS; eletrólitos preservam contractilidade e volume celular","fonte":"✅ ACSM Position Stand Fluid Replacement (PMID 17277604); Judelson 2007 Med Sci Sports Exerc (dehydration & strength)","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Tracking corporal semanal","dose":"peso + medidas + fotos","frequencia":"1x/sem","periodo":"manha","dias_semana":"seg","modo":"mesmo horário, em jejum, após banheiro; circunferências (braço, peito, coxa, panturrilha); fotos frontal/lateral/posterior","ciclo":"contínuo","observacao":"Auto-monitoramento é preditor consistente de aderência e progresso de longo prazo","fonte":"✅ Burke 2011 J Am Diet Assoc SR; National Weight Control Registry; ACSM monitoring guidelines","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Caminhada / cardio de baixa intensidade","dose":"30-45 min Zona 2","frequencia":"2-3x/sem","periodo":"manha,tarde","dias_semana":"ter,qui,sab","modo":"60-70% FCmax; bike leve, esteira ou ar livre; em dias de descanso ou pós-treino de força","ciclo":"contínuo","observacao":"Não interfere em hipertrofia se Zona 2; melhora recuperação e capacidade aeróbica; cardio intenso pode prejudicar gains","fonte":"✅ Wilson 2012 J Strength Cond Res concurrent training meta (interference modest); Murach 2016 Front Physiol (concurrent OK if moderate)","evidence":"validated"},{"categoria":"MUSCLE — Routines","nome":"Sol matinal","dose":"10-20 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"primeiras 2h após acordar; sem proteção solar nesse momento; pele e olhos expostos (não olhar direto)","ciclo":"contínuo","observacao":"Sincroniza ritmo circadiano (cortisol/melatonina); vitamina D endógena; melhora sono profundo (GH/IGF-1)","fonte":"✅ Scheer/Buijs 1999 J Clin Endocrinol Metab; Jung/Lockley/Czeisler 2010 J Biol Rhythms; Holick 2007 NEJM vitamin D","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Superávit calórico leve em fase de massa","dose":"+200-500 kcal acima do TDEE","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"calcular TDEE (BMR × fator atividade); adicionar 200-300 kcal para iniciantes/intermediários; 300-500 para off-season","ciclo":"fase de massa (8-16 semanas) + recomp","observacao":"Superávit excessivo (>500 kcal) aumenta ganho de gordura sem benefício adicional em hipertrofia","fonte":"✅ Slater 2019 Int J Sports Physiol Perform (recomp/bulking review); Garthe 2013 Int J Sport Nutr Exerc Metab (slow vs fast lean gain RCT)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Proteína 1.6-2.2 g/kg distribuída","dose":"1.6-2.2 g/kg dividida em 4 refeições","frequencia":"4-5x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"0.4-0.55 g/kg por refeição (mínimo 25-40g por refeição); 4-5 refeições espaçadas por 3-4h","ciclo":"contínuo","observacao":"Plateau de MPS em 1.6 g/kg/dia em treinados; limite superior 2.2 g/kg em fase de cutting/idosos","fonte":"✅ Morton 2018 BJSM meta (plateau 1.6, upper CI 2.2); Schoenfeld/Aragon 2018 JISSN (0.4g/kg/refeição em 4x, PMC5828430)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Carboidratos complexos peri-treino","dose":"1-3 g/kg por dia","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"aveia, batata doce, arroz integral, frutas, leguminosas; concentrar maior parte ao redor do treino","ciclo":"contínuo","observacao":"Glicogênio adequado preserva intensidade e MPS; déficit severo de carbs reduz performance e força","fonte":"✅ ACSM/ISSN Position Stand 2017 nutrient timing (PMC5596471); Burke 2011 J Sports Sci; Kerksick 2018 JISSN nutrient timing","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Gorduras boas 0.8-1.2 g/kg","dose":"0.8-1.2 g/kg","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"azeite extra-virgem, abacate, nozes, peixes gordurosos, ovo inteiro; mínimo 20% das calorias","ciclo":"contínuo","observacao":"Gorduras <20% das calorias reduz testosterona; ômega-3 reduz inflamação e melhora MPS","fonte":"✅ Volek 1997 J Appl Physiol (PMID, fat intake & testosterone); Wang 2005 (low-fat diet reduce androgens)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Whey protein isolado","dose":"25-40 g por dose","frequencia":"1-2x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"pós-treino (dentro de 1-2h) e/ou substituindo refeição lanche; misturar em água ou leite","ciclo":"contínuo","observacao":"Maior leucina entre fontes proteicas (~11%); maior MPS aguda vs caseína/soja; conveniente para atingir totais diários","fonte":"✅ Tang 2009 J Appl Physiol (whey > casein > soja MPS); Sepandi 2022 Clin Nutr ESPEN meta (35 RCTs n=1902); Witard 2014 (20g leucina threshold)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Caseína pré-sono","dose":"30-40 g","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"30 min antes de dormir; em água, leite ou iogurte grego; pode adicionar manteiga de amendoim para gorduras","ciclo":"contínuo","observacao":"Liberação lenta de aminoácidos durante o sono; aumenta MPS noturna em 22%","fonte":"✅ Res 2012 Med Sci Sports Exerc (n=16, 40g casein pre-sleep); Snijders 2015 J Nutr (RCT 12wk pre-sleep protein +hypertrophy); Trommelen 2026 Sports Med SR","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Colágeno hidrolisado + vitamina C","dose":"15 g colágeno + 500 mg vit C","frequencia":"1x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"30-60 min pré-treino para tecido conectivo; em água/café","ciclo":"contínuo, mínimo 12 semanas","observacao":"Especialmente útil para suporte a tendões/ligamentos; complementar à proteína completa (não substituir)","fonte":"✅ Zdzieblik 2015 BJN (n=53 sarcopenic men, 15g/dia 12wk + RT, PMC4594048); Shaw 2017 AJCN (collagen + vit C tendon)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Creatina monohidratada","dose":"3-5 g/dia","frequencia":"1x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"tomar em qualquer horário (timing irrelevante); dissolver em água ou com refeição; loading 20g/5dias opcional","ciclo":"contínuo","observacao":"Único suplemento com evidência consistente em hipertrofia e força; +0.5-1kg massa magra; +5-15% força","fonte":"✅ Kreider 2017 JISSN position stand creatine (PMC5469049); Chilibeck 2017 Open Access J Sports Med; meta PeerJ 2025 (PMC12665265, low-dose+intensity)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Beta-alanina","dose":"3.2-6.4 g/dia","frequencia":"2-3x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"doses divididas (1-2g cada) para evitar parestesia; tomar com refeição; mínimo 4-8 semanas para saturação","ciclo":"8-12 semanas, pausa 4 semanas","observacao":"Aumenta carnosina muscular em 30-60%; eficácia maior em exercícios 30 seg-10 min duração; eficácia limitada em força máxima","fonte":"✅ ISSN position stand 2015 beta-alanine; Saunders 2017 Br J Sports Med meta; Dolan 2020 Front Physiol Bayesian Emax (PMC7456894)","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Citrulina malato pré-treino","dose":"6-8 g, 60 min pré-treino","frequencia":"1x/dia","periodo":"manha,tarde","dias_semana":"treino","modo":"dissolver em água; 60 min antes do treino; combinar com cafeína se desejar pré-workout","ciclo":"contínuo (pausa 1 semana a cada 8 semanas)","observacao":"Aumenta NO via conversão a L-arginina; melhora desempenho em alta-rep (53% mais reps na 2ª metade do treino); reduz DOMS","fonte":"✅ Pérez-Guisado 2010 J Strength Cond Res (n=41 RCT, 8g pre-leg session); Glenn 2016 J Diet Suppl meta; Trexler 2019 J Strength Cond Res","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"Cafeína anidra pré-treino","dose":"3-6 mg/kg","frequencia":"1x/dia","periodo":"manha,tarde","dias_semana":"treino","modo":"30-60 min pré-treino; 200-400mg típico; evitar após 14h se sensível ao sono","ciclo":"contínuo (pausa 1 semana a cada 8 semanas)","observacao":"Padrão-ouro como ergogênico; aumenta força máxima, performance em alta-rep e foco neural","fonte":"✅ Guest 2021 ISSN position stand (PMC7777221); Goldstein 2010; Polito 2016 Strength Cond J review","evidence":"validated"},{"categoria":"MUSCLE — Nutrition","nome":"BCAA / EAA","dose":"5-10 g BCAA OU 10-15 g EAA","frequencia":"1x/dia treino","periodo":"manha,tarde","dias_semana":"treino","modo":"intra-treino ou em jejum se treinar de manhã antes do café; pouco benefício se proteína total já adequada","ciclo":"uso situacional, não obrigatório","observacao":"Reduz DOMS modestamente (-1.34 a -1.82 ES); efeito em hipertrofia limitado se proteína total adequada; preferir EAA completo","fonte":"⚠️ Salem 2024 Sports Med-Open meta (18 RCTs, PMC11021390); Wolfe 2017 JISSN (BCAA isolados insuficientes para MPS máxima)","evidence":"promising"},{"categoria":"MUSCLE — Nutrition","nome":"Glutamina","dose":"5-10 g/dia","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"pós-treino e antes de dormir; em água ou shake; mais relevante em situações de catabolismo extremo","ciclo":"contínuo se necessário","observacao":"Benefício limitado em hipertrofia em treinados; útil em recuperação intestinal e catabolismo severo (UTI, trauma)","fonte":"⚠️ Candow 2001 Eur J Appl Physiol (n=31 RCT, sem efeito em massa magra); revisões Cruzat 2018 Nutrients","evidence":"promising"},{"categoria":"MUSCLE — Nutrition","nome":"HMB (β-Hidroxi β-Metilbutirato)","dose":"3 g/dia","frequencia":"3x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"1g com cada refeição; forma livre (HMB-FA) > calcium-HMB para biodisponibilidade","ciclo":"contínuo","observacao":"Reduz catabolismo proteico; benefício maior em iniciantes ou déficit calórico; resultado modesto em treinados","fonte":"⚠️ Wilkinson 2018 Clin Nutr (HMB-FA n=16, modesto); Nissen 1996 J Appl Physiol (HMB Ca, original); Rowlands 2009 Sports Med review","evidence":"promising"},{"categoria":"MUSCLE — Supplements","nome":"Vitamina D3 + K2","dose":"2000-5000 UI D3 + 100-200 mcg K2","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa (lipossolúvel); ajustar dose conforme 25(OH)D (alvo 40-60 ng/mL)","ciclo":"contínuo","observacao":"Apenas em deficiência (<25 nmol/L) há ganho de força com suplementação; D3+K2 para direcionamento ao osso","fonte":"✅ Stockton 2011 Osteoporos Int meta (deficiente → ganho força); Holick 2007 NEJM; Owens 2018 Sports Med (atletas)","evidence":"validated"},{"categoria":"MUSCLE — Supplements","nome":"Magnésio bisglicinato","dose":"300-400 mg","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"antes de dormir (também auxilia sono); bisglicinato tem alta biodisponibilidade e menos efeito laxativo","ciclo":"contínuo","observacao":"Essencial para síntese proteica, contração muscular, produção de ATP; deficiência reduz força e recuperação","fonte":"✅ Wang 2017 Magnes Res meta athletes; Cinar 2011 Biol Trace Elem Res (Mg & strength); Volpe 2015 Adv Nutr","evidence":"validated"},{"categoria":"MUSCLE — Supplements","nome":"Zinco quelado","dose":"15-30 mg elementar","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"com refeição (evitar estômago vazio); evitar com cálcio na mesma refeição (competição)","ciclo":"contínuo (reavaliar a cada 3 meses)","observacao":"Cofator para testosterona; deficiência reduz T livre; suplementação restaura mas não eleva acima do normal","fonte":"✅ Prasad 1996 Nutrition (zinc deficiency & T); Kilic 2011 Neuro Endocrinol Lett athletes; NIH ODS Zinc fact sheet","evidence":"validated"},{"categoria":"MUSCLE — Supplements","nome":"Ômega-3 EPA/DHA 2-3g","dose":"2-3 g EPA+DHA combinados","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; ratio 2:1 EPA:DHA preferível para inflamação muscular","ciclo":"contínuo","observacao":"Aumenta MPS em ~30% em idosos (anabolic resistance); preserva massa magra em desuso; reduz DOMS","fonte":"✅ Smith 2011 Clin Sci (n=16 idosos, +30% MPS, PMID 21501117); Smith 2015 AJCN (older adults RCT); Cornish 2022 meta sarcopenia","evidence":"validated"},{"categoria":"MUSCLE — Supplements","nome":"Multivitamínico","dose":"1 cápsula/dia","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com café da manhã; escolher fórmula sem ferro (a menos que mulher pré-menopausa) e com forma metilada B12/folato","ciclo":"contínuo","observacao":"Insurance policy para micronutrientes; não substitui dieta; pouco benefício direto em hipertrofia se dieta adequada","fonte":"⚠️ Beck 2015 Int J Sport Nutr Exerc Metab (athletes & micronutrients); ISSN Position Stand on multivitamins limitado","evidence":"promising"},{"categoria":"MUSCLE — Supplements","nome":"Ashwagandha (Withania somnifera)","dose":"300-600 mg extrato KSM-66","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"extrato padronizado KSM-66 ou Sensoril; com refeição; pode causar sonolência","ciclo":"8-12 semanas, pausa 4 semanas","observacao":"Modesto aumento de força e massa magra em meta de RCTs; reduz cortisol; possível leve aumento de testosterona","fonte":"⚠️ Wankhede 2015 JISSN (RCT n=57 8wk RT + 600mg, +force/mass); Bonilla 2021 J Funct Morphol Kinesiol SR; Smith 2023 Int J Med Sci meta","evidence":"promising"},{"categoria":"MUSCLE — Supplements","nome":"Tongkat Ali (Eurycoma longifolia)","dose":"200-400 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"extrato padronizado em quassinóides 1-2%; com refeição; uso matinal","ciclo":"contínuo","observacao":"Eleva T livre em homens com hipogonadismo; benefício em treinados eugonadais é modesto","fonte":"⚠️ Tambi 2012 Andrologia (RCT n=76 hypogondaal); Henkel 2014 Phytother Res (men 200mg); evidência preliminar","evidence":"promising"},{"categoria":"MUSCLE — Supplements","nome":"Fadogia agrestis","dose":"300-600 mg","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"extrato padronizado; tomar com refeição","ciclo":"8 semanas, pausa 4 semanas (segurança em humanos limitada)","observacao":"Quase toda evidência é pré-clínica (ratos); estudos humanos quase ausentes; preocupação com hepato/testotoxicidade em ratos","fonte":"⚠️ Yakubu 2005 Asian J Androl (rats only); sem RCT humano publicado; cuidado em uso prolongado","evidence":"promising"},{"categoria":"MUSCLE — Devices","nome":"Faixas elásticas (resistance bands)","dose":"20-40 min","frequencia":"complementar","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"aquecimento, ativação muscular, treino acessório; complemento a pesos livres (não substituto)","ciclo":"contínuo","observacao":"Eficazes em hipertrofia quando levadas à fadiga; útil para travel/home gym; tensão variável","fonte":"✅ Lopes 2019 J Sport Health Sci meta (bands vs weights similar gains); Iversen 2017 Phys Ther Sport SR","evidence":"validated"},{"categoria":"MUSCLE — Devices","nome":"EMS (eletroestimulação muscular)","dose":"20-30 min","frequencia":"1-2x/sem","periodo":"tarde,noite","dias_semana":"ter,sex","modo":"complementar ao treino, não substituto; eletrodos sobre grupos musculares; intensidade tolerável","ciclo":"8-12 semanas, reavaliar","observacao":"EMS isolado < RT tradicional; combinado com RT pode amplificar hipertrofia; útil em reabilitação","fonte":"⚠️ Filipovic 2012 J Strength Cond Res meta (EMS + training); Kemmler 2018 Front Physiol whole-body EMS","evidence":"promising"},{"categoria":"MUSCLE — Devices","nome":"BFR (Blood Flow Restriction)","dose":"20-30 min","frequencia":"2-3x/sem","periodo":"tarde","dias_semana":"ter,qui","modo":"cuffs proximais nos membros; pressão individualizada (40-80% LOP); cargas leves (20-30% 1RM); 30-15-15-15 reps","ciclo":"contínuo","observacao":"Hipertrofia comparável a HL-RT com cargas leves; útil em rehab, idosos, dias de baixo volume; ganho de força inferior a HL-RT","fonte":"✅ Centner 2019 Sports Med meta idosos (PMC6349784, ES hypertrophy 0.21 = HL); Cui 2024 Sports Med-Open meta athletes (PMC11595635)","evidence":"validated"},{"categoria":"MUSCLE — Devices","nome":"Massagem percussiva (massage gun)","dose":"5-10 min por grupo","frequencia":"diario","periodo":"tarde,noite","dias_semana":"diario","modo":"pós-treino ou pré-treino para mobilidade; 2000-3000 rpm; evitar áreas ósseas e nervos","ciclo":"contínuo","observacao":"Reduz DOMS percebido; aumenta ROM agudo; sem evidência de aumento direto em hipertrofia ou força","fonte":"⚠️ Konrad 2020 Sports (massage gun acute ROM); Sams 2023 Int J Sports Phys Ther review; sample pequena","evidence":"promising"},{"categoria":"MUSCLE — Devices","nome":"Foam roller","dose":"10-15 min","frequencia":"diario","periodo":"manha,noite","dias_semana":"diario","modo":"rolar todos grupos musculares grandes; 30-60 seg por área; pressão tolerável","ciclo":"contínuo","observacao":"Reduz DOMS, melhora ROM e recuperação; não substitui aquecimento dinâmico; sem efeito direto em ganhos","fonte":"✅ Wiewelhove 2019 Front Physiol meta (n=21 estudos); MacDonald 2014 Med Sci Sports Exerc","evidence":"validated"},{"categoria":"MUSCLE — Devices","nome":"Bota de compressão pneumática","dose":"20-30 min","frequencia":"3-5x/sem pós-treino","periodo":"noite","dias_semana":"seg,qua,sex,sab","modo":"pressão sequencial dos pés ao quadril; pós-treino; pressão tolerável","ciclo":"contínuo, pós-treino","observacao":"Acelera remoção de metabólitos pós-treino; reduz DOMS percebido; sem efeito direto em hipertrofia","fonte":"⚠️ Sands 2014 J Strength Cond Res; uso popular em recuperação, evidência clínica preliminar","evidence":"promising"},{"categoria":"MUSCLE — Devices","nome":"Sauna infravermelha pós-treino","dose":"15-30 min","frequencia":"3-4x/sem","periodo":"tarde,noite","dias_semana":"seg,qua,sex,sab","modo":"60-80°C; idealmente 30+ min pós-treino; hidratar com eletrólitos antes e depois","ciclo":"contínuo","observacao":"Reduz mortalidade CV; HSP up-regulation pode preservar massa muscular em desuso; melhora recuperação","fonte":"✅ Laukkanen 2015 JAMA Intern Med (KIHD n=2315); Patrick 2017 Mayo Clin Proc; Selsby 2007 (HSP & muscle)","evidence":"validated"},{"categoria":"MUSCLE — Devices","nome":"Banho frio pós-treino","dose":"1-3 min","frequencia":"controle","periodo":"tarde,noite","dias_semana":"evitar em dias de força","modo":"água 10-15°C; APENAS em dias de cardio/recuperação, NÃO imediatamente pós-treino de força (atenua hipertrofia)","ciclo":"uso situacional","observacao":"Cold water imersão pós-RT reduz adaptações hipertróficas em 20-30%; OK 4-6h após treino ou em dias de descanso","fonte":"✅ Roberts 2015 J Physiol (CWI atenua hipertrofia n=21); Fyfe 2019 Med Sci Sports Exerc meta; Petersen 2021 J Physiol","evidence":"validated"},{"categoria":"MUSCLE — Biohacking","nome":"Jejum intermitente 14-16h","dose":"janela alimentar 8-10h","frequencia":"diario","periodo":"noite","dias_semana":"diario","modo":"fechar 20-21h, abrir 11-13h; eletrólitos durante jejum; idealmente treinar próximo ao quebra do jejum","ciclo":"contínuo","observacao":"Compatível com hipertrofia se proteína total/dia adequada (1.6+ g/kg); pode prejudicar gains em janelas <6h","fonte":"✅ Moro 2016 J Transl Med (TRE 16/8 8wk em treinados, n=34); Tinsley 2017 Eur J Sport Sci RCT; Stratton 2020 Nutrients meta","evidence":"validated"},{"categoria":"MUSCLE — Biohacking","nome":"Respiração nasal diurna","dose":"consciente durante atividades","frequencia":"diario","periodo":"tarde,noite","dias_semana":"diario","modo":"boca fechada durante exercício leve e atividades de baixa intensidade; nasal breathing aumenta NO sistêmico","ciclo":"contínuo","observacao":"Aumenta NO nasal em >50%; melhora vasodilação, captação de O2 e recuperação muscular pós-exercício","fonte":"✅ Yasuda 1997 (PMID 9504133); Lundberg 1995/2002 Eur Respir J; MDPI Sports 2025 PMC12567944 (nasal breathing & recovery)","evidence":"validated"},{"categoria":"MUSCLE — Biohacking","nome":"Higiene digital noturna","dose":"1h sem telas antes de dormir","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"substituir por leitura/alongamento; filtro de luz azul (>460nm) se necessário usar telas","ciclo":"contínuo","observacao":"Luz azul à noite suprime melatonina, reduz GH/IGF-1 pulse durante SWS, prejudica recuperação muscular","fonte":"✅ Höhn 2020 SLEEP Advances meta; Frontiers Neurology 2025 SR; Chennaoui 2020 Sleep Med Rev","evidence":"validated"},{"categoria":"MUSCLE — Biohacking","nome":"Sol matinal e luz vermelha","dose":"10-20 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"primeiras 2h após acordar; pele e olhos expostos; complementar com LED vermelho 660+850nm para mitocôndrias","ciclo":"contínuo","observacao":"Luz vermelha/NIR pode melhorar recuperação muscular e força via citocromo c oxidase mitocondrial","fonte":"✅ Ferraresi 2016 Lasers Med Sci review PBM & muscle; Leal-Junior 2015 meta PBM; Vanin 2020 Lasers Med Sci","evidence":"validated"},{"categoria":"MUSCLE — Biohacking","nome":"Higiene de cortisol matinal","dose":"rotina pós-acordar estruturada","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"luz solar + hidratação + cafeína 90-120 min após acordar (não imediatamente) para alinhar com pico natural de cortisol","ciclo":"contínuo","observacao":"Pico CAR (cortisol awakening response) natural 30-45 min pós-acordar; cafeína muito cedo amplifica desnecessariamente","fonte":"⚠️ Clow 2010 Stress (CAR review); Lovallo 2014 (cafeína + cortisol); evidência mecanística mais que outcome-based","evidence":"promising"},{"categoria":"MUSCLE — Biohacking","nome":"HRV monitoring matinal","dose":"1-2 min ao acordar","frequencia":"diario","periodo":"manha","dias_semana":"diario","modo":"ao acordar, antes de levantar; anel/relógio/peito; registrar tendência de 7 dias, não dia isolado","ciclo":"contínuo","observacao":"Útil para detectar overtraining; HRV baixa persistente sugere reduzir volume/intensidade; correlação com hipertrofia indireta","fonte":"⚠️ Plews 2013 Sports Med (HRV-guided training); Düking 2020 Int J Sports Physiol Perform; correlação com performance variável","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"TRT (Reposição de Testosterona) — homens hipogonadais","dose":"100-200 mg/sem testosterona enantato IM/SC","frequencia":"1-2x/sem","periodo":"manha,tarde,noite","dias_semana":"conforme prescrição médica","modo":"APENAS em hipogonadismo confirmado (T total <300 ng/dL com sintomas); SC ou IM; supervisão médica obrigatória; monitorar hematócrito, PSA, estradiol","ciclo":"contínuo enquanto sob supervisão médica","observacao":"FDA-aprovado APENAS para hipogonadismo confirmado; uso recreativo é doping/anabolizante; supraphysio doses 600mg/sem produzem +3-6kg massa magra (Bhasin 1996 NEJM)","fonte":"✅ Bhasin 1996 NEJM 335:1-7 (n=43, 600mg/sem); Snyder 2016 NEJM Testosterone Trials; AUA Guidelines hypogonadism 2018; FDA TRT approved","evidence":"validated"},{"categoria":"MUSCLE — Peptides Advanced","nome":"DHEA (em homens/mulheres com baixos níveis)","dose":"25-50 mg/dia oral","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"tomar pela manhã; APENAS em DHEA-S baixo confirmado por exame; supervisão médica","ciclo":"contínuo enquanto sob supervisão médica","observacao":"Modesto aumento de massa magra em mulheres pós-menopausa com baixo DHEA; sem benefício em jovens eugonadais","fonte":"⚠️ Jankowski 2006 AJP-Endocrinol (RCT + RT em idosos); Jankowski 2019 Clin Endocrinol pooled analysis; ineficaz em jovens","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"CJC-1295 + Ipamorelin","dose":"100-300 mcg cada SC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"subcutâneo antes de dormir em jejum noturno; supervisão médica; monitorar IGF-1","ciclo":"12 semanas, pausa 4 semanas","observacao":"Off-label; nenhum aprovado pela FDA; eleva GH/IGF-1 transitoriamente; resultados em hipertrofia em humanos saudáveis anedóticos","fonte":"⚠️ Teichman 2006 JCEM (CJC-1295 PK humano); Raun 1998 Eur J Endocrinol (Ipamorelin); FDA não-aprovado; WADA Prohibited","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"Sermorelin","dose":"100-500 mcg/dia SC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"subcutâneo antes de dormir; supervisão médica; era FDA-aprovado para deficiência de GH em crianças (descontinuado 2008)","ciclo":"12 semanas, pausa 4 semanas","observacao":"Análogo GHRH (1-29); meia-vida muito curta; previamente aprovado FDA (Geref) para crianças com deficiência GH; hoje off-label","fonte":"⚠️ Walker 2009 Endocrine Reviews; Geref FDA approval 1990s (descontinuado); uso atual é off-label","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"MK-677 (Ibutamoren)","dose":"10-25 mg/dia oral","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"oralmente antes de dormir; pode causar retenção hídrica, aumento de apetite e fome noturna; supervisão médica","ciclo":"12 semanas, pausa 4-8 semanas","observacao":"Eleva GH/IGF-1 cronicamente; aumenta massa magra (predominantemente água); pode reduzir sensibilidade à insulina; off-label","fonte":"⚠️ Nass 2008 Ann Intern Med (n=65 elderly, +1.1kg LBM 2yr); FDA não-aprovado; WADA Prohibited","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"Tesamorelin (Egrifta SV/WR)","dose":"1-2 mg/dia SC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"aplicar antes de dormir; FDA-aprovado APENAS para HIV-lipodistrofia; uso em não-HIV é off-label","ciclo":"contínuo enquanto sob supervisão médica","observacao":"Análogo GHRH FDA-aprovado para visceral fat em HIV; uso em hipertrofia em não-HIV é off-label sem RCT robusto","fonte":"✅ FDA approved 2010 (Egrifta SV) + 2025 (Egrifta WR); off-label em não-HIV; Falutz 2007 NEJM (HIV)","evidence":"validated"},{"categoria":"MUSCLE — Peptides Advanced","nome":"SARMs (Ostarine/LGD-4033)","dose":"10-25 mg/dia oral","frequencia":"1x/dia","periodo":"manha,tarde,noite","dias_semana":"ainda não disponível clinicamente","modo":"investigacional; supervisão médica obrigatória se uso experimental; monitorar enzimas hepáticas, lipídios, HPTA","ciclo":"ainda não definido (em desenvolvimento)","observacao":"Nenhum SARM aprovado pela FDA; relatos de hepatotoxicidade, cardiotoxicidade, supressão de HPTA; WADA Prohibited; FDA Warning","fonte":"⚠️ Labban 2024 Cureus (case DILI LGD-4033, PMC11485217); FDA warning 2017+; WADA Prohibited List S1.2; USADA","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"BPC-157","dose":"250-500 mcg SC","frequencia":"1-2x/dia","periodo":"manha,tarde","dias_semana":"diario","modo":"subcutâneo em área próxima a lesão se uso para recuperação; supervisão médica obrigatória","ciclo":"6-8 semanas, pausa 4 semanas","observacao":"Off-label sem aprovação FDA; ~200 estudos quase todos de um único grupo (Sikiric); evidência humana extremamente limitada","fonte":"⚠️ opss.org review; STAT News 2026; WADA Prohibited List S0; FDA não-aprovado","evidence":"promising"},{"categoria":"MUSCLE — Peptides Advanced","nome":"TB-500 (Thymosin Beta-4)","dose":"2-2.5 mg/sem SC","frequencia":"2x/sem","periodo":"manha,tarde","dias_semana":"ter,sex","modo":"subcutâneo; supervisão médica obrigatória","ciclo":"6-8 semanas, pausa 4 semanas","observacao":"Off-label; evidência majoritariamente pré-clínica; sem RCT humano publicado para hipertrofia","fonte":"⚠️ Dados pré-clínicos; sem aprovação FDA; WADA Prohibited; sem estudos humanos publicados para hypertrofia","evidence":"promising"}],"longevity":[{"categoria":"LONGEVITY — Routines","nome":"Treino de força para preservação muscular","dose":"3-4x/sem, 30-60 min","frequencia":"3-4x/sem","periodo":"manha,tarde,noite","dias_semana":"seg,ter,qui,sex","modo":"exercícios compostos com carga progressiva; foco em manter massa magra e força após os 35 anos","ciclo":"contínuo (vitalício)","observacao":"Sarcopenia inicia ~30 anos, acelera após 60; força preserva independência funcional e reduz mortalidade","fonte":"✅ Wu 2017 J Am Med Dir Assoc meta (n=3M, grip strength & mortality HR 1.41); Andersen 2024 J Cachexia Sarcopenia Muscle (28 países); KFACS PMC11692973","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Zona 2 (cardio aeróbico moderado)","dose":"150-200 min/sem em Zona 2","frequencia":"3-4x/sem","periodo":"manha,tarde","dias_semana":"ter,qui,sab,dom","modo":"60-70% FCmax; conversação possível mas com leve esforço; bike, corrida leve, esteira inclinada, caminhada rápida","ciclo":"contínuo","observacao":"Constrói densidade mitocondrial e VO2max basal; cada +1 ml/kg/min de VO2max reduz mortalidade em 3.7-15%","fonte":"✅ Mandsager 2018 JAMA Netw Open (n=122,007, fitness & mortality); Laukkanen 2018 JACC (46-yr follow-up); Brawner 2020 JAMA Netw Open","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"VO2max training (intervalos de alta intensidade)","dose":"1-2x/sem, 20-30 min","frequencia":"1-2x/sem","periodo":"manha,tarde","dias_semana":"qua,sab","modo":"intervalos 4x4 min (4 min alta + 3 min ativa) OU 30/30 (30 seg sprint, 30 seg easy); 90-95% FCmax","ciclo":"contínuo","observacao":"VO2max é o preditor mais forte de all-cause mortality (mais que tabagismo, HAS, DM); zona 5 é critica","fonte":"✅ Mandsager 2018 JAMA Netw Open; Wisløff 4x4 protocol; Helgerud 2007 Med Sci Sports Exerc; Attia Outlive 2023","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Caminhada diária 7-10k passos","dose":"7000-10000 passos/dia","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"distribuir ao longo do dia; pelo menos uma sequência de 30+ min; pode incluir escadas","ciclo":"contínuo","observacao":"Redução não-linear de mortalidade até ~7500-10000 passos; benefício platôs após","fonte":"✅ Paluch 2022 Lancet Public Health meta (n=47,471, dose-response); Saint-Maurice 2020 JAMA NHANES; Banach 2023 Eur J Prev Cardiol meta","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Sono restaurador 7-9 horas","dose":"7-9 horas","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"horário fixo, blackout total, 18-20°C; sem álcool 3h antes; sem cafeína após 14h","ciclo":"contínuo","observacao":"Sono <6h ou >9h aumenta mortalidade em forma de U; sono profundo (SWS) é onde GH/IGF-1 pulsa e cérebro é limpo (glymphatic)","fonte":"✅ Cappuccio 2010 Sleep meta (n=1.4M); Yin 2017 JAHA meta sleep & mortality; Iliff 2012 Sci Transl Med (glymphatic)","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Higiene digital noturna","dose":"1h sem telas antes de dormir","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"telefones fora do quarto; substituir por leitura ou alongamento; filtro luz azul se necessário","ciclo":"contínuo","observacao":"Luz azul à noite suprime melatonina, atrasa fase circadiana, prejudica sono profundo onde GH/IGF-1 pulsam","fonte":"✅ Höhn 2020 SLEEP Advances meta; Chang 2015 PNAS (eReaders & sleep); Tähkämö 2019 Chronobiol Int review","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Sol matinal 10-20 min","dose":"10-20 min","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"primeiras 2h após acordar; sem proteção solar nesse momento; pele e olhos expostos (não olhar direto)","ciclo":"contínuo","observacao":"Ancora ritmo circadiano (cortisol AM, melatonina PM); produção endógena de vitamina D; melhora SWS","fonte":"✅ Scheer 1999 J Clin Endocrinol Metab; Lockley/Czeisler 2010 J Biol Rhythms; Holick 2007 NEJM vitamin D","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Conexão social diária","dose":"≥1 interação significativa/dia","frequencia":"diario","periodo":"tarde,noite","dias_semana":"diario","modo":"moai/círculo fixo de 4-6 amigos; refeições em família; voluntariado; clube ou grupo regular","ciclo":"contínuo (vitalício)","observacao":"Isolamento social = +26% mortalidade (≈ smoking); strong ties = +50% sobrevivência vs weak ties","fonte":"✅ Holt-Lunstad 2010 PLOS Med meta (n=308k); Holt-Lunstad 2015 Perspect Psychol Sci; Buettner Blue Zones; Harvard Study Adult Development","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Propósito de vida (ikigai)","dose":"definição clara + prática diária","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"escrever propósito; alocar 30+ min/dia em atividade alinhada; revisar a cada 3 meses","ciclo":"contínuo","observacao":"Senso de propósito previne mortalidade em ~17-26% e reduz declínio cognitivo independentemente de outros fatores","fonte":"✅ Alimujiang 2019 JAMA Netw Open (n=6985, life purpose & mortality); Hill 2014 Psychol Sci; Boyle 2010 Arch Gen Psychiatry","evidence":"validated"},{"categoria":"LONGEVITY — Routines","nome":"Stress management estruturado (meditação/HRV)","dose":"10-20 min/dia","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"respiração box (4-4-4-4), Wim Hof, meditação guiada, HRV biofeedback; mínimo 10 min/dia","ciclo":"contínuo","observacao":"Stress crônico acelera epigenetic age (GrimAge), eleva CRP, encurta telômeros; meditação pode reverter parte","fonte":"✅ Goyal 2014 JAMA Intern Med meta; Black 2016 Psychoneuroendocrinology meta inflammation; Epel 2013 Brain Behav Immun","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Dieta Mediterrânea / Padrão Blue Zone","dose":"predominantemente vegetal + peixe","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"azeite extra-virgem 2-4 colheres/dia, vegetais 5-9 porções, leguminosas diárias, peixes 2-3x/sem, carne vermelha 1-2x/sem, vinho moderado opcional","ciclo":"contínuo (vitalício)","observacao":"Padrão alimentar com maior evidência em redução mortalidade e disease-span; reduz mortalidade CV em 25-30%","fonte":"✅ Estruch 2018 NEJM PREDIMED RCT (n=7447); Trichopoulou 2003 NEJM EPIC; Sofi 2014 Public Health Nutr meta umbrella","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Restrição calórica moderada (10-15%)","dose":"10-15% abaixo do TDEE","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"manter peso saudável OU reduzir ligeiramente em fase de longevidade; nunca abaixo de 80% TDEE por longos períodos","ciclo":"intermitente ou contínuo","observacao":"CR de 12% por 2 anos no CALERIE reduziu pace of aging em 2-3% (DunedinPACE), equivalente a 10-15% menor mortalidade","fonte":"✅ Waziry 2023 Nat Aging CALERIE (n=197 RCT); Ravussin 2015 J Gerontol; Belsky 2023 Columbia analysis","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Jejum intermitente 14-16h","dose":"janela alimentar 8-10h","frequencia":"diario","periodo":"noite","dias_semana":"diario","modo":"fechar 20-21h, abrir 11-13h; eletrólitos e café preto/chá durante jejum; flexibilizar em dias sociais","ciclo":"contínuo ou cíclico","observacao":"Ativa autofagia, AMPK, reduz mTOR sustenido; melhora metabólico; eficácia em longevidade humana ainda em estudo","fonte":"✅ Moro 2016 J Transl Med (TRE em treinados); Stratton 2020 Nutrients meta; Hatori 2012 Cell Metab","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Proteína 1.2-1.6 g/kg após 40 anos","dose":"1.2-1.6 g/kg","frequencia":"4x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"0.3-0.4 g/kg por refeição; distribuir em 3-4 refeições; foco em fontes whole-food (peixe, ovos, leguminosas)","ciclo":"contínuo","observacao":"Anabolic resistance pós-40 requer proteína mais alta que RDA (0.8g/kg) para preservar massa magra; balance com longevidade","fonte":"✅ Bauer 2013 J Am Med Dir Assoc PROT-AGE; Phillips 2016 Appl Physiol Nutr Metab; Morton 2018 BJSM meta","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Fibras 25-35 g/dia + fermentados","dose":"25-35 g fibras + 1-2 porções fermentados","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"fibras de aveia, leguminosas, vegetais, frutas, sementes; fermentados como kefir, iogurte, kimchi, chucrute","ciclo":"contínuo","observacao":"Fibras e diversidade microbiana correlacionam com longevidade; cada +10g fibra/dia = -10% mortalidade","fonte":"✅ Reynolds 2019 Lancet meta (n=4635 RCTs); Sonnenburg 2014 Cell Host Microbe; Wastyk 2021 Cell (fermented foods)","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Ômega-3 EPA/DHA 2-3g/dia","dose":"2-3 g EPA+DHA","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"via peixes gordos 2-3x/sem (sardinha, salmão, anchovas) OU suplemento; ratio 2:1 EPA:DHA","ciclo":"contínuo","observacao":"Cada +1% Omega-3 Index reduz mortalidade em ~13%; redução em CV mortality, inflamação, declínio cognitivo","fonte":"✅ Harris 2021 Nat Commun (n=2240, Omega-3 Index & mortality); GISSI-Prevenzione 1999 Lancet; ASCEND 2018 NEJM","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Hidratação 30-40 ml/kg + eletrólitos","dose":"30-40 ml/kg + sal Celta/Himalaia","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"água em jejum ao acordar com 1g sal; espalhar ao longo do dia; café/chá contam parcialmente","ciclo":"contínuo","observacao":"Hidratação serum sodium nas faixas 135-146 mmol/L associadas com menor mortalidade e disease-span maior","fonte":"✅ Dmitrieva 2023 eBioMedicine (NIH ARIC n=11,255, hydration & aging); ACSM Position Stand 2007","evidence":"validated"},{"categoria":"LONGEVITY — Nutrition","nome":"Polifenóis variados (frutas vermelhas, cacau, chá verde, azeite)","dose":"diversidade > quantidade","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"berries 1 xícara/dia, cacau ≥70%, chá verde 2-3 xícaras/dia, azeite extra-virgem 2-4 colheres","ciclo":"contínuo","observacao":"Polifenóis modulam mTOR, AMPK, sirtuinas; reduzem inflamação crônica e stress oxidativo","fonte":"✅ Tresserra-Rimbau 2014 Nutr Metab CV Dis (PREDIMED polyphenols); Del Bo 2019 Nutrients review; Khoo 2017 J Funct Foods","evidence":"validated"},{"categoria":"LONGEVITY — Supplements","nome":"Vitamina D3 + K2","dose":"2000-5000 UI D3 + 100-200 mcg K2 MK-7","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com refeição gordurosa; ajustar dose a 25(OH)D alvo 40-60 ng/mL; K2 evita calcificação vascular","ciclo":"contínuo","observacao":"Deficiência de D associada com mortalidade, infecções, cancer; K2 direciona Ca ao osso (não vaso)","fonte":"✅ Bouillon 2019 Lancet D & Health (review); Geleijnse 2004 J Nutr Rotterdam K2 study; Stockton 2011 Osteoporos Int meta","evidence":"validated"},{"categoria":"LONGEVITY — Supplements","nome":"Magnésio bisglicinato","dose":"300-400 mg","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"antes de dormir (também auxilia sono); bisglicinato tem alta biodisponibilidade e baixo efeito laxativo","ciclo":"contínuo","observacao":"Essencial em 300+ reações enzimáticas; deficiência associada com mortalidade CV e diabetes","fonte":"✅ Wu 2017 BMJ Open Mg & mortality (n=388,000 cohort); Volpe 2015 Adv Nutr; Rosanoff 2012 Nutr Rev","evidence":"validated"},{"categoria":"LONGEVITY — Supplements","nome":"Creatina monohidratada","dose":"3-5 g/dia","frequencia":"1x/dia","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"qualquer horário; dissolver em água ou café; benefício neurocognitivo e muscular em envelhecimento","ciclo":"contínuo","observacao":"Não só ergogênico mas também neurocognitivo em idosos; preserva força e função cognitiva","fonte":"✅ Kreider 2017 JISSN Position Stand; Chilibeck 2017 Open Access J Sports Med (older adults RT+creatine); Forbes 2022 Nutrients (cognition)","evidence":"validated"},{"categoria":"LONGEVITY — Supplements","nome":"Ômega-3 EPA/DHA suplemento","dose":"2-3 g/dia se não há ingestão dietética suficiente","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"qualidade: triglicerídeo > etil-éster; checar TOTOX <26; armazenar refrigerado","ciclo":"contínuo","observacao":"Ver MUSCLE e NUTRITION; cada +1% Omega-3 Index = -13% all-cause mortality","fonte":"✅ Harris 2021 Nat Commun (n=2240); Smith 2011 Clin Sci (PMID 21501117); GISSI 1999","evidence":"validated"},{"categoria":"LONGEVITY — Supplements","nome":"Glycine + NAC (precursores glutationa)","dose":"3g glicina + 600 mg NAC","frequencia":"1x/dia","periodo":"noite","dias_semana":"diario","modo":"antes de dormir; glicina também melhora qualidade de sono; restaura glutationa em idosos","ciclo":"contínuo","observacao":"Em idosos, GlyNAC restaurou glutationa e reverteu múltiplas hallmarks of aging em pequeno trial","fonte":"⚠️ Kumar 2023 J Gerontol GlyNAC (n=24 idosos vs n=12 jovens, RCT); evidência preliminar; trials maiores necessários","evidence":"promising"},{"categoria":"LONGEVITY — Supplements","nome":"Curcumina + piperina","dose":"500-1000 mg + 5-10 mg piperina","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"com refeição gordurosa; piperina aumenta biodisponibilidade em 20x; preferir formulação fitossomal","ciclo":"contínuo","observacao":"Reduz inflamação crônica (CRP, IL-6); preserva função cognitiva e cardiometabólica","fonte":"⚠️ Hewlings 2017 Foods curcumin review; Small 2018 Am J Geriatr Psychiatry RCT cognition; bioavailability é limitação","evidence":"promising"},{"categoria":"LONGEVITY — Supplements","nome":"Multivitamínico abrangente","dose":"1 cápsula/dia","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"com café da manhã; escolher fórmula sem ferro (a menos que mulher pré-menopausa)","ciclo":"contínuo","observacao":"Cocoa-Lab COSMOS-Mind RCT: multivitamínico modestamente preservou cognição em 60+ ao longo de 3 anos","fonte":"⚠️ Baker 2023 Am J Clin Nutr COSMOS-Mind (n=2262 RCT); benefício modesto, controverso vs whole-food","evidence":"promising"},{"categoria":"LONGEVITY — Supplements","nome":"NMN ou NR (precursores NAD+)","dose":"250-500 mg/dia","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"NMN sublingual ou NR oral; com refeição; monitorar resposta subjetiva (energia, recuperação)","ciclo":"contínuo, reavaliar a cada 3-6 meses","observacao":"Eleva NAD+ em humanos; benefício clínico em longevidade ainda preliminar; trials humanos limitados","fonte":"⚠️ Martens 2018 Nat Commun NR healthy adults (PMC5876407); Elhassan 2019 Cell Rep elderly muscle (PMC6702140); ainda investigacional","evidence":"promising"},{"categoria":"LONGEVITY — Supplements","nome":"Spermidina (germe de trigo / suplemento)","dose":"1-6 mg/dia","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"via dieta (germe de trigo, soja, cogumelos, queijos envelhecidos) OU suplemento","ciclo":"contínuo","observacao":"Induz autofagia; correlação observacional com mortalidade reduzida; RCT humano limitado","fonte":"⚠️ Kiechl 2018 Am J Clin Nutr Bruneck (observacional); SmartAge trial 2022 (cognição, modesto); SCS trial em andamento","evidence":"promising"},{"categoria":"LONGEVITY — Supplements","nome":"Pterostilbene / Resveratrol","dose":"100-250 mg pterostilbene OU 500 mg resveratrol","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"pterostilbene tem ~80% biodisponibilidade vs ~20% resveratrol; com refeição gordurosa","ciclo":"contínuo","observacao":"Ativador SIRT1 in vitro; benefício humano em longevidade não comprovado em RCT; pterostilbene melhor PK","fonte":"⚠️ Riche 2014 J Toxicol pterostilbene safety; resveratrol trials mistos; Mankowski 2020 Aging Cell critique","evidence":"promising"},{"categoria":"LONGEVITY — Devices","nome":"Wearable HRV / sleep tracker","dose":"uso contínuo","frequencia":"diario","periodo":"manha,tarde,noite","dias_semana":"diario","modo":"Oura/Whoop/Garmin/Apple Watch; HRV de 7 dias > leitura isolada; sono total + estágios + tempo de sono profundo","ciclo":"contínuo","observacao":"HRV baixa crônica preditor de mortalidade; tracking permite intervenção precoce (overtraining, stress)","fonte":"✅ Hillebrand 2013 Europace HRV & mortality meta; Plews 2013 Sports Med (HRV-guided); Tsuji 1996 Circulation Framingham","evidence":"validated"},{"categoria":"LONGEVITY — Devices","nome":"CGM (Continuous Glucose Monitor)","dose":"2 semanas, repetir 1-2x/ano","frequencia":"1-2x/ano por 2 semanas","periodo":"manha,tarde,noite","dias_semana":"contínuo durante o período","modo":"Libre/Dexcom/Stelo; monitorar TIR (time in range), GMI, glucose variability; identificar alimentos espigadores","ciclo":"ciclos de 14 dias","observacao":"Glycemic variability associada com mortalidade e disease-span; mesmo em não-diabéticos, picos preditem CV","fonte":"⚠️ Hall 2018 PLOS Biol (variabilidade em não-diabéticos); ATTD/Battelino 2019 Diab Care TIR consensus; uso recreacional ainda em validação","evidence":"promising"},{"categoria":"LONGEVITY — Devices","nome":"Smart scale (impedância)","dose":"1x/sem ao acordar","frequencia":"1x/sem","periodo":"manha","dias_semana":"seg","modo":"mesmo horário, em jejum, após banheiro; tracking de massa magra, gordura, água; tendência > dia isolado","ciclo":"contínuo","observacao":"Composição corporal preserva massa magra ao longo da vida é central para longevidade funcional","fonte":"✅ Wells 2014 Int J Obes BIA validation; National Weight Control Registry; uso para tendência, não medida absoluta","evidence":"validated"},{"categoria":"LONGEVITY — Devices","nome":"Tonômetro arterial (BP cuff em casa)","dose":"1-2x/dia","frequencia":"diario","periodo":"manha,noite","dias_semana":"diario","modo":"manhã e noite, sentado, após 5 min de repouso; média de 2-3 medidas; alvo <120/80 mmHg","ciclo":"contínuo","observacao":"BP otimizada (<120/80) reduz mortalidade CV; SPRINT trial mostrou benefício de target <120 em alto risco","fonte":"✅ SPRINT 2015 NEJM (n=9361); Whelton 2018 J Am Coll Cardiol AHA/ACC Guidelines; tracking domiciliar","evidence":"validated"},{"categoria":"LONGEVITY — Devices","nome":"Sauna infravermelha ou tradicional","dose":"20-30 min, 4-7x/sem","frequencia":"4-7x/sem","periodo":"tarde,noite","dias_semana":"diario ou alternado","modo":"80-100°C tradicional OU 60°C IR; hidratação com eletrólitos; pós-treino ou à noite","ciclo":"contínuo","observacao":"≥4x/sem reduz all-cause mortality em 40% e CV em 50% em homens finlandeses (KIHD)","fonte":"✅ Laukkanen 2015 JAMA Intern Med (KIHD n=2315); Laukkanen 2018 BMC Med review; Patrick 2017 Mayo Clin Proc","evidence":"validated"},{"categoria":"LONGEVITY — Devices","nome":"Cold plunge / ice bath","dose":"1-3 min, 10-15°C, 2-4x/sem","frequencia":"2-4x/sem","periodo":"manha,tarde","dias_semana":"alternado","modo":"10-15°C, 1-3 min; pós-cardio OK; evitar pós-treino de força imediato (atenua hipertrofia)","ciclo":"contínuo","observacao":"Eleva norepinefrina; melhora glicemia, mood, recuperação; impacto em mortalidade ainda em estudo","fonte":"⚠️ Tipton 2017 Exp Physiol cold immersion review; Søberg 2021 Cell Rep Med (brown adipose); evidência mecanística > outcome","evidence":"promising"},{"categoria":"LONGEVITY — Biohacking","nome":"Respiração nasal diurna + Wim Hof matinal","dose":"5-10 min/dia","frequencia":"1x/dia","periodo":"manha","dias_semana":"diario","modo":"respiração nasal durante atividades; ciclos Wim Hof (30 respirações + retenção) ao acordar","ciclo":"contínuo","observacao":"Nasal breathing aumenta NO; HRV training melhora função autonômica e reduz inflamação","fonte":"✅ Lundberg 2002 Eur Respir J (nasal NO); Kox 2014 PNAS (Wim Hof method & inflammation); Goldsby 2022 Front Psychol meta-review","evidence":"validated"},{"categoria":"LONGEVITY — Biohacking","nome":"Higiene térmica (sauna + cold contrast)","dose":"alternado","frequencia":"2-4x/sem","periodo":"tarde,noite","dias_semana":"alternado","modo":"sauna 15-20 min seguido de cold plunge 1-2 min; repetir 2-3 ciclos; sempre terminar com aquecimento","ciclo":"contínuo","observacao":"Hormetic stress eleva HSPs, BDNF, ativação parasimpática; modula inflamação crônica","fonte":"✅ Laukkanen 2015 JAMA Intern Med; Tipton 2017 Exp Physiol; Selsby 2007 J Appl Physiol (HSP & muscle)","evidence":"validated"},{"categoria":"LONGEVITY — Biohacking","nome":"Light hygiene (sol AM + bloqueio PM)","dose":"10-20 min manhã + 0 lux noite","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"sol direto pela manhã; após pôr-do-sol minimizar luz artificial e usar bulbs vermelhas/baixa","ciclo":"contínuo","observacao":"Sincronização circadiana correta otimiza GH, melatonina, cortisol; correlação com biomarcadores de envelhecimento","fonte":"✅ Wright 2013 Curr Biol (camping reset circadian); Burgess 2017 J Biol Rhythms; Vetter 2018 Annu Rev Nutr","evidence":"validated"},{"categoria":"LONGEVITY — Biohacking","nome":"Mindfulness / meditação consistente","dose":"20 min/dia","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"diario","modo":"MBSR, Vipassana, Loving-Kindness, ou apps (Calm/Waking Up); consistência > duração","ciclo":"contínuo","observacao":"Reduz CRP, encurta GrimAge acceleration, preserva telômeros; meditadores Long-term mostram epigenetic deceleration","fonte":"✅ Chaix 2017 Brain Behav Immun (meditators epigenetic); Black 2016 Psychoneuroendocrinology meta; Epel 2013 Brain Behav Immun","evidence":"validated"},{"categoria":"LONGEVITY — Biohacking","nome":"Tracking corporal trimestral (panel + DXA)","dose":"1x/trimestre","frequencia":"1x/trimestre","periodo":"manha","dias_semana":"1x/3 meses","modo":"labs completos (CBC, metabólico, lipídio, HbA1c, hsCRP, vit D, B12, ferritina, omega-3 index); DXA composição corporal anual","ciclo":"contínuo","observacao":"Biomarkers permite intervenção precoce; PhenoAge calculável de labs básicos (Levine 2018)","fonte":"✅ Levine 2018 Aging PhenoAge formula; Liu 2018 PLOS Med PhenoAge validation; Attia Outlive 2023","evidence":"validated"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"Rapamicina (sirolimus) low-dose off-label","dose":"5-8 mg/sem oral","frequencia":"1x/sem","periodo":"manha,tarde","dias_semana":"domingo (sob supervisão médica)","modo":"APENAS sob supervisão médica; off-label para longevidade; monitorar lipídios, glicemia, contagem celular, mucosite","ciclo":"contínuo com pausas, sob supervisão","observacao":"Mais replicado lifespan-extender em mamíferos; humano: evidência clínica em longevidade ainda preliminar; PEARL trial 2025 sem efeito significativo","fonte":"⚠️ PEARL trial 2025 (n=114 RCT 48 weeks, primário negativo); Mannick 2014 Sci Transl Med (everolimus & immune); Hands 2025 Aging review (PMC12422820)","evidence":"promising"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"Metformina off-label longevidade","dose":"500-1500 mg/dia","frequencia":"1-2x/dia","periodo":"manha,noite","dias_semana":"com refeições","modo":"APENAS sob supervisão médica; XR forma reduz GI; monitorar B12 anual; off-label em não-diabéticos","ciclo":"contínuo, supervisão médica","observacao":"Animal: extensão lifespan; humano: TAME trial ainda em recrutamento; MILES (n=14 pequeno) sugere transcriptomic anti-aging","fonte":"⚠️ Kulkarni 2020 Lancet Healthy Longev; TAME trial protocol (Barzilai); Kulkarni 2025 Cell Metab AMPK review (PMC11689588); ainda investigacional","evidence":"promising"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"Senolíticos Dasatinib + Quercetina","dose":"100mg D + 1000mg Q","frequencia":"2 dias consecutivos, mensal","periodo":"manha","dias_semana":"1x/mês","modo":"2 dias por mês; sob supervisão médica (dasatinib é quimio); monitorar plaquetas, edema, mucosite","ciclo":"ciclos mensais","observacao":"Pilot studies em humanos mostram clearance de células senescentes; impacto clínico em longevidade humana ainda em validação","fonte":"⚠️ Hickson 2019 EBioMedicine (DKD pilot); Justice 2019 EBioMedicine IPF pilot; Lee 2024 Aging epigenetic effects mistos (PMC205581)","evidence":"promising"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"Fisetina senolítico","dose":"100-500 mg, 2-3 dias consecutivos/mês","frequencia":"2-3 dias consecutivos, mensal","periodo":"manha","dias_semana":"1x/mês","modo":"extrato natural; tomar com refeição gordurosa; supervisão médica recomendada","ciclo":"ciclos mensais","observacao":"Animal: senolítico potente; humano: trials em andamento (LIFEMAX, AFFIRM); evidência clínica em longevidade humana ainda preliminar","fonte":"⚠️ Yousefzadeh 2018 EBioMedicine (mice); Mayo AFFIRM trial (LGD-4033 senolytic); resultados humanos pendentes","evidence":"promising"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"TRT (Reposição de Testosterona)","dose":"100-200 mg/sem em homens hipogonadais","frequencia":"1-2x/sem","periodo":"manha,tarde,noite","dias_semana":"conforme prescrição médica","modo":"APENAS em hipogonadismo confirmado (T total <300 ng/dL com sintomas); SC ou IM; supervisão obrigatória","ciclo":"contínuo enquanto sob supervisão","observacao":"Em homens hipogonadais: melhora composição corporal, força, energia, função sexual; benefício longevidade direto não comprovado","fonte":"✅ Bhasin 1996 NEJM (n=43 supraphysio); Snyder 2016 NEJM Testosterone Trials; AUA Guidelines hypogonadism 2018","evidence":"validated"},{"categoria":"LONGEVITY — Pharma Advanced","nome":"Estrogênio MHT/HRT (mulheres pós-menopausa)","dose":"0.5-1 mg estradiol + progesterona","frequencia":"diario","periodo":"manha,noite","dias_semana":"conforme prescrição médica","modo":"APENAS em pós-menopausa sintomática; iniciar idealmente <10 anos da menopausa (window of opportunity); via transdérmica preferida","ciclo":"contínuo enquanto sob supervisão","observacao":"MHT iniciada <60 anos ou <10y menopausa: redução de mortalidade, fraturas, declínio cognitivo; risco/benefício individualizado","fonte":"✅ Manson 2017 JAMA WHI long-term follow-