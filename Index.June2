    <div class="q-sub" data-i18n="s6.q_sub">Defina a profundidade do seu protocolo.</div>

    <!-- Plan cards (kept from existing structure) -->
    <div class="plans">
      <div class="plan-card" id="plan-essentials" onclick="selectPlan('essentials',this)">
        <div class="plan-eyebrow" data-i18n="s5.plan.essentials.name">Fundamentais</div>
