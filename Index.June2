  const shelfText = formatShelfForPrompt(shelf, false); // no peptides at free tier
  const blockerCtx = buildBlockerContext(p.blockers, isEn);
  const axesCtx = buildAxesContext(p.scores, p.topAxes, isEn);

  if(isEn){
    return `You are the Beauty Intel by Wealthness system.

⚠️ CRITICAL: Write entire JSON in fluent English. Translate Portuguese shelf items into English. Do NOT use Portuguese words (except system keys: manha/tarde/noite/diario/seg/ter/qua/qui/sex/sab/dom).

PROFILE:
- ${p.gender}, ${p.age} years old
- Main goal: ${p.objective}${p.focus ? ' (focus: ' + p.focus + ')' : ''}${p.secondaryGoal ? ' | Secondary: ' + p.secondaryGoal : ''}
- Archetype: ${p.archetypeName} — ${p.archetypeDesc}
- Training level: ${p.training}
- Plan: ${p.plan} | Openness: ${p.openness} | Consistency: ${p.consistency}

${blockerCtx}

${axesCtx}

OBJECTIVE SHELF (${p.objective}):
${shelfText}

TASK — Generate the FREE TIER (2 quick-win actions):
Following the 4-layer logic:
1. If blockers exist, action #1 MUST address the most severe blocker
2. Remaining actions: pick from objective shelf items most relevant to top axes
3. All 2 actions must work synergistically

CRITICAL RULES:
- Choose 2 actions ONLY from the shelf above
- COPY exact dose/timing from shelf (separate "dose" and "frequencia")
- Each action should give visible result in 2-4 weeks
- Prioritize free, simple, accessible actions

Return ONLY valid JSON, single-line strings in English:
{"causa_raiz":"2-3 sentences in second person. Educational but conversational — explain what is happening in your body and how this protocol fixes the root cause. Avoid heavy jargon.","sinergia_free":"STRICT MAX 15 WORDS. ONE short snappy sentence. How the 2 actions work together. Plain conversational language, no jargon.","blocker_priority":"${p.blockers.length > 0 ? '1 sentence about the main blocker and why addressing it first is critical' : ''}","acoes_free":[{"nome":"","dose":"","frequencia":"","periodo":"","modo":"","dias_semana":"","por_que":"","ciclo":""},{"nome":"","dose":"","frequencia":"","periodo":"","modo":"","dias_semana":"","por_que":"","ciclo":""}]}`;
  }
  return `Você é o sistema Beauty Intel by Wealthness.

⚠️ CRÍTICO: Escreva JSON inteiro em português fluente.

PERFIL:
- ${p.gender}, ${p.age} anos
- Objetivo principal: ${p.objective}${p.focus ? ' (foco: ' + p.focus + ')' : ''}${p.secondaryGoal ? ' | Secundário: ' + p.secondaryGoal : ''}
- Arquétipo: ${p.archetypeName} — ${p.archetypeDesc}
- Nível de treino: ${p.training}
- Plano: ${p.plan} | Abertura: ${p.openness} | Consistência: ${p.consistency}

${blockerCtx}

${axesCtx}

PRATELEIRA DO OBJETIVO (${p.objective}):
${shelfText}

TAREFA — Gerar TIER FREE (2 ações de impacto rápido):
Seguindo lógica de 4 camadas:
1. Se há blockers, a ação #1 DEVE endereçar o blocker mais severo
2. Demais ações: escolher itens da prateleira mais relevantes aos top eixos
3. As 2 ações devem trabalhar em sinergia

REGRAS CRÍTICAS:
- Escolher 2 ações APENAS da prateleira acima
- COPIAR dose/timing exato da prateleira (separar "dose" e "frequencia")
- Cada ação deve dar resultado visível em 2-4 semanas
- Priorizar ações gratuitas, simples e acessíveis

Retorne APENAS JSON válido, strings em linha única:
{"causa_raiz":"2-3 frases em segunda pessoa. Educacional mas conversacional — explicar o que está acontecendo no seu corpo e como esse protocolo resolve a causa raiz. Evitar jargão pesado.","sinergia_free":"MÁX RIGOROSO 15 PALAVRAS. UMA frase curta e direta. Como as 2 ações trabalham juntas. Linguagem conversacional simples, sem jargão.","blocker_priority":"${p.blockers.length > 0 ? '1 frase sobre o blocker principal e por que endereçá-lo primeiro é crítico' : ''}","acoes_free":[{"nome":"","dose":"","frequencia":"","periodo":"","modo":"","dias_semana":"","por_que":"","ciclo":""},{"nome":"","dose":"","frequencia":"","periodo":"","modo":"","dias_semana":"","por_que":"","ciclo":""}]}`;
}

// ── ESSENTIALS prompt (Layer 1 + 2 + 3) ────────────────────────────────────
function buildEssentialsPrompt(arch, p, alreadyUsed){
  const isEn = _currentLang === 'en';
  const shelf = getShelfForObjective(p.objective);
  const shelfText = formatShelfForPrompt(shelf, false); // basic shelf
