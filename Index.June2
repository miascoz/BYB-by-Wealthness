}



// ═══════════════════════════════════════════════════════════════════════════
// VIRTUAL CALENDAR + PRINTABLE CALENDAR
// ═══════════════════════════════════════════════════════════════════════════

const CAL_DAYS = ['seg','ter','qua','qui','sex','sab','dom'];

function getProtocolItems(){
  // Normalize for comparison — lowercase, no accents, no punctuation
  const normalize = (str) => {
    return (str || '')
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9 ]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  };

  // Extract canonical "concept" from a name — only the FIRST significant word
  // This is aggressive: "Sol matinal sem protetor" and "Sol matinal" → both "sol"
  // "Sauna infravermelha" repeated in different periods → both "sauna"
  // "LED vermelho/NIR" and "Red light therapy" → "led" vs "light" (still differ, OK)
  const extractCore = (str) => {
    const n = normalize(str);
    if(!n) return '';
    // Filler words to skip when picking the "core" first word
    const filler = new Set([
      'sem','protetor','solar','direta','exposicao','exposure','direct','no','sunscreen',
      'matinal','morning','afternoon','tarde','noite','night','de','do','da','dos','das',
      'pela','pelo','com','infravermelho','infravermelha','at','to','by','of','for','with',
      'minutes','minuto','min','minutos','hour','hora','hours','horas','session','sessao',
      'a','o','as','os','um','uma','the','an','and','daily','diario','semanal','weekly',
      'pre','pos','post','treino','training','workout','antes','depois','before','after',
      'red','vermelho','vermelha','light','luz','therapy','terapia','para'
    ]);
    const words = n.split(' ').filter(w => w.length > 2 && !filler.has(w));
    // Use first 2 significant words as concept key
    return words.slice(0, 2).join(' ') || n;
  };

  // Substring match — catches cases where one name is a prefix/extension of another
  const isSimilar = (a, b) => {
    if(!a || !b) return false;
    if(a === b) return true;
    if(a.length > 4 && b.includes(a)) return true;
    if(b.length > 4 && a.includes(b)) return true;
    // Check if first 3 significant words match
    const wa = a.split(' ').slice(0, 3).join(' ');
    const wb = b.split(' ').slice(0, 3).join(' ');
    if(wa === wb && wa.length > 4) return true;
    return false;
  };

  // Score how complete an item is
  const completeness = (a) => ['dose','frequencia','periodo','modo','dias_semana','ciclo','por_que']
    .reduce((n,k) => n + (a[k] ? 1 : 0), 0);

  // Collect all items with their priority
  const allItems = [];
  if(_cachedEssentials){
    (_cachedEssentials.acoes_essentials || []).forEach(a => allItems.push({...a, _priority: 3}));
    (_cachedEssentials.acoes_elite || []).forEach(a => allItems.push({...a, _priority: 2}));
  }
  if(_protocolData){
    (_protocolData.acoes_essentials || []).forEach(a => allItems.push({...a, _priority: 3}));
    (_protocolData.acoes_elite || []).forEach(a => allItems.push({...a, _priority: 2}));
    (_protocolData.acoes_free || []).forEach(a => allItems.push({...a, _priority: 1}));
  }

  // Group by core concept; within each group, pick the best item
  const groups = {};
  allItems.forEach(item => {
    if(!item.nome) return;
    const core = extractCore(item.nome);
    if(!core) return;

    // Look for similar existing keys (substring match) before creating new group
    let matchKey = core;
    for(const existingKey of Object.keys(groups)){
      if(isSimilar(core, existingKey)){
        matchKey = existingKey;
        break;
      }
    }

    const existing = groups[matchKey];
    if(!existing){
      groups[matchKey] = item;
    } else {
      // Higher priority wins
      if(item._priority > existing._priority){
        groups[matchKey] = item;
      } else if(item._priority === existing._priority){
        if(completeness(item) > completeness(existing)){
          groups[matchKey] = item;
        }
      }
    }
  });

  const unique = Object.values(groups);
  console.log('Calendar items count:', unique.length, 'sample:', unique[0]);
  return unique;
}

function parseDays(diasStr){
  // Returns array of day codes that this item applies to
  if(!diasStr || diasStr === '') return [...CAL_DAYS]; // default: every day
  const s = String(diasStr).toLowerCase().trim();
  if(!s) return [...CAL_DAYS];
  // Daily keywords (PT + EN)
  if(/^(diario|diário|daily|todos|every\s*day|all\s*days|every)/.test(s)) return [...CAL_DAYS];
  // Parse comma/space separated
  const days = s.split(/[,\s/;]+/).map(d => d.trim()).filter(Boolean);
  const map = {
    // EN full
    monday:'seg', tuesday:'ter', wednesday:'qua', thursday:'qui', friday:'sex', saturday:'sab', sunday:'dom',
    // EN short
    mon:'seg', tue:'ter', tues:'ter', wed:'qua', thu:'qui', thur:'qui', thurs:'qui', fri:'sex', sat:'sab', sun:'dom',
    // PT full
    'segunda':'seg', 'terça':'ter', 'terca':'ter', 'quarta':'qua', 'quinta':'qui', 'sexta':'sex', 'sábado':'sab', 'sabado':'sab', 'domingo':'dom',
    // PT short already covered by CAL_DAYS check
  };
  const result = days.map(d => map[d] || d).filter(d => CAL_DAYS.includes(d));
  return result.length > 0 ? result : [...CAL_DAYS];
}

function parsePeriods(periodoStr, modoStr){
  const tryDetect = (str) => {
    if(!str) return [];
    const s = String(str).toLowerCase();
    const periods = [];
    if(/manha|manhã|morning|am\b|a\.m\.|breakfast|wake|acordar|cedo|pela manha/.test(s)) periods.push('morning');
    if(/tarde|afternoon|lunch|almoço|almoco/.test(s)) periods.push('afternoon');
    if(/noite|night|evening|dormir|sleep|bed|antes de dormir|p\.m\.|pm\b|jantar|dinner/.test(s)) periods.push('night');
    return periods;
  };

  // Primary: periodo field
  let periods = tryDetect(periodoStr);

  // Fallback: extract from modo
  if(periods.length === 0) periods = tryDetect(modoStr);

  // Last resort: morning
  return periods.length > 0 ? periods : ['morning'];
}

function getTodayCode(){
  // 0=Sun, 1=Mon ... in JS Date
  const d = new Date().getDay();
  return ['dom','seg','ter','qua','qui','sex','sab'][d];
}

function getCalendarStorageKey(){
  return 'wealthness_cal_' + (_ca?.nameKey || 'default');
}

function loadCalendarMarks(){
  try{
    const raw = localStorage.getItem(getCalendarStorageKey());
    return raw ? JSON.parse(raw) : {};
  }catch{ return {}; }
}

function saveCalendarMarks(marks){
  try{
    localStorage.setItem(getCalendarStorageKey(), JSON.stringify(marks));
  }catch{}
}

let _activeDayTab = null;

function openVirtualCalendar(){
  const modal = document.getElementById('cal-modal');
  if(!modal) return;
  modal.classList.add('active');
  _activeDayTab = getTodayCode();
  renderCalendarTabs();
  renderCalendarDay(_activeDayTab);
}

function closeVirtualCalendar(){
  const modal = document.getElementById('cal-modal');
  if(modal) modal.classList.remove('active');
}

function renderCalendarTabs(){
  const tabs = document.getElementById('cal-day-tabs');
  if(!tabs) return;
  const today = getTodayCode();
  tabs.innerHTML = CAL_DAYS.map(d => {
    const label = t('cal.day_short.' + d);
    const isActive = d === _activeDayTab ? 'active' : '';
    const isToday = d === today ? 'today' : '';
    return '<button class="cal-day-tab ' + isActive + ' ' + isToday + '" onclick="switchCalendarDay(\'' + d + '\')">' + label + '</button>';
  }).join('');

  // Update header with full day name + date
  const headerEl = document.querySelector('.cal-header-title');
  if(headerEl){
    const dayName = t('cal.day.' + _activeDayTab);
    const isTodayActive = _activeDayTab === today;
    const now = new Date();
    const dateStr = now.toLocaleDateString(_currentLang === 'en' ? 'en-US' : 'pt-BR', {day: 'numeric', month: 'short'});
    if(isTodayActive){
      headerEl.innerHTML = dayName + ' <span style="opacity:.5;font-size:13px;font-style:normal;">· ' + (_currentLang === 'en' ? 'today' : 'hoje') + ' · ' + dateStr + '</span>';
    } else {
      headerEl.innerHTML = dayName;
    }
  }
}

function switchCalendarDay(day){
  _activeDayTab = day;
  renderCalendarTabs();
  renderCalendarDay(day);
}

function renderCalendarDay(day){
  const container = document.getElementById('cal-day-content');
  if(!container) return;

  const items = getProtocolItems();
  const marks = loadCalendarMarks();

  // Build per-period lists for this day
  const byPeriod = { morning: [], afternoon: [], night: [] };

  items.forEach((a, idx) => {
    const days = parseDays(a.dias_semana);
    if(!days.includes(day)) return;
    const periods = parsePeriods(a.periodo, a.modo);
    periods.forEach(p => {
      byPeriod[p].push({ ...a, _idx: idx, _period: p });
    });
  });

  let totalForDay = 0, completedForDay = 0;
  ['morning','afternoon','night'].forEach(p => {
    byPeriod[p].forEach(it => {
      totalForDay++;
      const markKey = day + '|' + p + '|' + it._idx;
      if(marks[markKey]) completedForDay++;
    });
  });

  // Update progress
  const pct = totalForDay > 0 ? Math.round(completedForDay / totalForDay * 100) : 0;
  document.getElementById('cal-progress-fill').style.width = pct + '%';
  const today = getTodayCode();
  const todayLabel = day === today ? ' ' + t('cal.today') : '';
  const actionLabel = totalForDay === 1 ? t('cal.action_single') : t('cal.action_plural');
  document.getElementById('cal-progress-text').textContent = completedForDay + '/' + totalForDay + ' ' + actionLabel + todayLabel;

  // Build sections
  let html = '';
  const periodIcons = { morning: '☀', afternoon: '🌤', night: '☾' };
  ['morning','afternoon','night'].forEach(p => {
    const list = byPeriod[p];
    if(list.length === 0) return;
    html += '<div class="cal-period">';
    html += '<div class="cal-period-label">' + periodIcons[p] + ' ' + t('cal.period.' + p) + '</div>';
    list.forEach(it => {
      const markKey = day + '|' + p + '|' + it._idx;
      const checked = marks[markKey] ? 'checked' : '';
      const checkedClass = marks[markKey] ? 'checked' : '';
      html += '<div class="cal-item ' + checkedClass + '">';
      html += '<div class="cal-item-check ' + checked + '" onclick="toggleCalendarMark(\'' + markKey + '\')"></div>';
      html += '<div class="cal-item-content">';
      html += '<div class="cal-item-name">' + (it.nome || '') + '</div>';
      const dose = [it.dose, it.frequencia].filter(Boolean).join(' · ');
      if(dose) html += '<div class="cal-item-dose">' + dose + '</div>';
      if(it.modo) html += '<div class="cal-item-mode">' + it.modo + '</div>';
      html += '</div></div>';
    });
    html += '</div>';
  });

  if(totalForDay === 0){
    html = '<div class="cal-empty">' + t('cal.empty') + '</div>';
  }

  container.innerHTML = html;
}

function toggleCalendarMark(key){
  const marks = loadCalendarMarks();
  marks[key] = !marks[key];
  saveCalendarMarks(marks);
  renderCalendarDay(_activeDayTab);
}

function clearCalendarMarks(){
  if(confirm(t('cal.clear_confirm'))){
    saveCalendarMarks({});
    renderCalendarDay(_activeDayTab);
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// PRINTABLE CALENDAR — landscape HTML, opens in new window for printing
// ═══════════════════════════════════════════════════════════════════════════

function downloadPrintCalendar(){
  const items = getProtocolItems();
  const archName = _ca ? _ca.name : '';
  const isEn = _currentLang === 'en';

  const dayLabels = CAL_DAYS.map(d => t('cal.day_short.' + d).toUpperCase());
  const periodLabels = {
    morning: t('cal.period.morning'),
    afternoon: t('cal.period.afternoon'),
    night: t('cal.period.night')
  };
  const periodIcons = { morning: '☀', afternoon: '🌤', night: '☾' };

  // Group items by period and day: grid[period][day] = [items]
  const grid = {};
  ['morning','afternoon','night'].forEach(p => {
    grid[p] = {};
    CAL_DAYS.forEach(d => { grid[p][d] = []; });
  });

  items.forEach(a => {
    const days = parseDays(a.dias_semana);
    const periods = parsePeriods(a.periodo, a.modo);
    periods.forEach(p => {
      days.forEach(d => {
        grid[p][d].push(a);
      });
    });
  });

  // Helper: render a single item row
  const renderItem = (it) => {
    const dose = [it.dose, it.frequencia].filter(Boolean).join(' · ');
    return `<div style="margin-bottom:8px;font-size:10px;line-height:1.35;">
      <span style="display:inline-block;width:14px;height:14px;border:1.5px solid #31251D;margin-right:6px;vertical-align:middle;"></span>
      <span style="color:#31251D;font-weight:500;">${it.nome || ''}</span>${dose ? `<span style="color:#8B8178;"> · ${dose}</span>` : ''}
    </div>`;
  };

  // Build period rows (one row per period, with all 7 day columns)
  let periodRows = '';
  ['morning','afternoon','night'].forEach(p => {
    const periodLabel = periodLabels[p].toUpperCase();
    const icon = periodIcons[p];
    let row = `<tr>
      <td style="background:#E7D9C8;padding:12px 10px;font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:600;color:#31251D;border:1px solid #4A443E;text-align:center;">
        <div style="font-size:22px;margin-bottom:4px;"><span style="color:#F5F1EB;">${icon}</span></div>
        <div style="font-size:10px;letter-spacing:2px;font-family:'DM Sans',sans-serif;font-weight:500;">${periodLabel}</div>
      </td>`;

    CAL_DAYS.forEach(d => {
      const list = grid[p][d];
      row += `<td style="border:1px solid #4A443E;padding:8px;vertical-align:top;height:auto;min-width:60px;">`;
      if(list.length === 0){
        row += '&nbsp;';
      } else {
        list.forEach(it => { row += renderItem(it); });
      }
      row += `</td>`;
    });

    row += '</tr>';
    periodRows += row;
  });

  // Day header cells
  const dayHeaders = dayLabels.map(label =>
    `<th style="background:#31251D;color:#fff;padding:10px 8px;font-size:10px;letter-spacing:2px;font-weight:500;text-align:center;">${label}</th>`
  ).join('');

  // Current month/year for header
  const now = new Date();
  const monthName = now.toLocaleDateString(isEn ? 'en-US' : 'pt-BR', {month: 'long', year: 'numeric'});

  const archetypeLabel = isEn ? 'Archetype:' : 'Arquétipo:';

  const printHtml = `<!DOCTYPE html><html lang="${isEn ? 'en' : 'pt-BR'}"><head><meta charset="UTF-8">
  <title>${t('cal.print.title')}</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    @page { size: landscape; margin: 15mm; }
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'DM Sans',sans-serif;background:#fff;color:#31251D;padding:30px;max-width:1100px;margin:0 auto}
    .header{margin-bottom:24px;padding-bottom:16px;border-bottom:2px solid #31251D;display:flex;justify-content:space-between;align-items:flex-end;}
    .logo{font-family:'Cormorant Garamond',serif;font-size:11px;letter-spacing:3px;color:#8B8178;text-transform:uppercase;margin-bottom:4px}
    .title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;color:#31251D}
    .title em{font-style:italic;color:#F5F1EB}
    .meta{text-align:right;font-size:10px;letter-spacing:2px;color:#8B8178;text-transform:uppercase;line-height:1.8}
    .footer{margin-top:24px;padding-top:12px;border-top:1px solid #4A443E;font-size:9px;color:#8D857C;line-height:1.5}
  </style></head><body>
  <div class="header">
    <div>
      <div class="logo">Beauty Intel · By Wealthness</div>
      <div class="title">${t('cal.print.title_main')} <em>${t('cal.print.title_main_em')}</em></div>
    </div>
    <div class="meta">
      ${archName ? archetypeLabel + ' ' + archName + '<br>' : ''}${monthName}
    </div>
  </div>
  <table style="width:100%;border-collapse:collapse;table-layout:fixed;">
    <thead>
      <tr>
        <th style="background:#31251D;color:#fff;padding:10px 8px;font-size:10px;letter-spacing:2px;font-weight:500;text-align:center;width:14%;">&nbsp;</th>
        ${dayHeaders}
      </tr>
    </thead>
    <tbody>
      ${periodRows}
    </tbody>
  </table>
  <div class="footer">${t('cal.print.footer')}</div>
  </body></html>`;

  // Download via blob (works on iOS without popup blocker)
  const blob = new Blob([printHtml], {type: 'text/html;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = (isEn ? 'weekly-calendar' : 'calendario-semanal') + '.html';
  document.body.appendChild(a);
  a.click();
  setTimeout(() => {
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }, 200);
}



// Toggle the "Why this?" explanation per protocol item
function toggleWhy(btn){
  const wrapper = btn.parentElement;
  const content = wrapper.querySelector('.why-content');
  const warning = wrapper.querySelector('.why-warning');
  const isOpen = btn.classList.contains('open');
  if(isOpen){
    btn.classList.remove('open');
    if(content) content.classList.remove('open');
    if(warning) warning.classList.remove('open');
  } else {
    btn.classList.add('open');
    if(content) content.classList.add('open');
    if(warning) warning.classList.add('open');
  }
}

// ── Initialize i18n on load ────────────────────────────────────────────────
(function initI18n(){
  function init(){
    applyTranslations();
    updateLangToggles();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
  window.addEventListener('load', init);
})();

</script>
</body>
</html>
