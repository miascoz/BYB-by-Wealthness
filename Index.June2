const answers={};

// ═══════════════════════════════════════════════════════════════════════════
// SCORING ENGINE v2 — 8 Axes + Blockers + Dynamic Archetype
// ═══════════════════════════════════════════════════════════════════════════

const AGE_FACTOR = {'18-24':1.0, '25-34':1.1, '35-44':1.3, '45-54':1.5, '55+':1.8};

// Eight axes split into Root / Support / Output
const ROOT_AXES = ['inflammation', 'cortisol', 'glycemia', 'hormonal', 'microbiome'];
const SUPPORT_AXES = ['sleep', 'lymphatic'];
const OUTPUT_AXES = ['structural'];
const ALL_AXES = [...ROOT_AXES, ...SUPPORT_AXES, ...OUTPUT_AXES];

// Weights per response per axis. Each entry is a partial score (0–3 typical).
// Calibrated based on the 3 mapas (skin/fat/muscle) + clinical evidence.
const AXIS_WEIGHTS = {

  // ── SLIDE 3 — Visual Symptoms ────────────────────────────────────────────
  visual_symptoms: {
    pele_opaca:         { inflammation: 1, glycemia: 2, structural: 2, microbiome: 1 },
    pele_inflamada:     { inflammation: 3, microbiome: 2, structural: 1, hormonal: 1 },
    rosto_inchado:      { cortisol: 3, lymphatic: 3, glycemia: 1, sleep: 1 },
    flacidez_rugas:     { structural: 3, cortisol: 1, inflammation: 1 },
    cabelo_caindo:      { hormonal: 3, microbiome: 1, structural: 2, cortisol: 1 },
    gordura_abdominal:  { cortisol: 3, glycemia: 3, hormonal: 1, inflammation: 1 },
    gordura_localizada: { hormonal: 2, lymphatic: 2, glycemia: 1, inflammation: 1 },
    falta_definicao:    { hormonal: 2, structural: 2, sleep: 1 },
    aparencia_cansada:  { sleep: 3, cortisol: 2, inflammation: 1, lymphatic: 1 }
  },

  // ── SLIDE 4 — Internal Signals ───────────────────────────────────────────
  internal_signals: {
    energia_oscilante:  { glycemia: 3, cortisol: 2, microbiome: 1 },
    cansaco_dormindo:   { sleep: 3, cortisol: 2, hormonal: 1, inflammation: 1 },
    sono_leve:          { sleep: 3, cortisol: 3, hormonal: 1 },
    inchaco:            { lymphatic: 3, microbiome: 2, glycemia: 1 },
    desejo_acucar:      { glycemia: 3, microbiome: 2, cortisol: 1 },
    libido_baixa:       { hormonal: 3, cortisol: 2, sleep: 1 },
    estresse_alto:      { cortisol: 3, sleep: 2, inflammation: 2, hormonal: 1 },
    ciclos:             { hormonal: 3, inflammation: 1 }
  },

  // ── SLIDE 5 — Lifestyle (multi-select) ───────────────────────────────────
  // Negative items push axis scores up (they indicate problems)
  // Positive items reduce a "deficit" — handled separately
  lifestyle: {
    bad_sleep:       { sleep: 3, cortisol: 3, inflammation: 2, hormonal: 1 },
    chronic_stress:  { cortisol: 3, sleep: 2, inflammation: 2, hormonal: 1, glycemia: 1 },
    alcohol:         { inflammation: 2, sleep: 1, hormonal: 1, microbiome: 1 },
    smoke:           { inflammation: 3, structural: 2, lymphatic: 1 },
    eat_well:        { } // positive lifestyle — no penalty
  },

  // ── SLIDE 5 — Training level (modifies multiple axes) ────────────────────
  training: {
    sedentary: { lymphatic: 2, structural: 2, glycemia: 1, sleep: 1 },
    light:     { lymphatic: 1, structural: 1 },
    moderate:  { },
    athlete:   { sleep: 1 } // higher recovery demand
  }
};

// ═══════════════════════════════════════════════════════════════════════════
// BLOCKER DETECTION — these override everything in protocol generation
// ═══════════════════════════════════════════════════════════════════════════

const BLOCKER_DEFS = {
  smoke:          { severity: 3, key: 'blocker.smoke' },
  bad_sleep:      { severity: 3, key: 'blocker.bad_sleep' },
  chronic_stress: { severity: 2, key: 'blocker.chronic_stress' },
  alcohol:        { severity: 2, key: 'blocker.alcohol' },
  sedentary:      { severity: 2, key: 'blocker.sedentary' }
};

function detectBlockers(){
  const blockers = [];
  const lifestyle = answers['lifestyle'] || [];
  const training = answers['training'];

  if(lifestyle.includes('smoke'))         blockers.push({id:'smoke',         severity:3});
  if(lifestyle.includes('bad_sleep'))     blockers.push({id:'bad_sleep',     severity:3});
  if(lifestyle.includes('chronic_stress'))blockers.push({id:'chronic_stress',severity:2});
  if(lifestyle.includes('alcohol'))       blockers.push({id:'alcohol',       severity:2});
  if(training === 'sedentary')            blockers.push({id:'sedentary',     severity:2});

  // Sort by severity descending
  blockers.sort((a,b)=>b.severity-a.severity);
  return blockers;
}

// ═══════════════════════════════════════════════════════════════════════════
// CALCULATE 8-AXIS SCORES
// ═══════════════════════════════════════════════════════════════════════════

function calculateScores(){
  const af = AGE_FACTOR[answers['age']] || 1.0;

  // Initialize all axes at 0
  const sc = {};
  ALL_AXES.forEach(a => sc[a] = 0);

  // 1. Visual symptoms (slide 3 — answers[2])
  const visualSymptoms = Array.isArray(answers[2]) ? answers[2] : [];
  visualSymptoms.forEach(symptom => {
    const weights = AXIS_WEIGHTS.visual_symptoms[symptom] || {};
    for(const [axis, weight] of Object.entries(weights)){
      sc[axis] = (sc[axis] || 0) + weight;
    }
  });

  // 2. Internal signals (slide 4 — answers[3])
  const internalSignals = Array.isArray(answers[3]) ? answers[3] : [];
  internalSignals.forEach(signal => {
    const weights = AXIS_WEIGHTS.internal_signals[signal] || {};
    for(const [axis, weight] of Object.entries(weights)){
      sc[axis] = (sc[axis] || 0) + weight;
    }
  });

  // 3. Lifestyle (slide 5 — answers['lifestyle'])
  const lifestyle = answers['lifestyle'] || [];
  lifestyle.forEach(item => {
    const weights = AXIS_WEIGHTS.lifestyle[item] || {};
    for(const [axis, weight] of Object.entries(weights)){
      sc[axis] = (sc[axis] || 0) + weight;
    }
  });

  // 4. Training level (slide 5 — answers['training'])
  const trainingWeights = AXIS_WEIGHTS.training[answers['training']] || {};
  for(const [axis, weight] of Object.entries(trainingWeights)){
    sc[axis] = (sc[axis] || 0) + weight;
  }

  // 5. Apply age factor (older → higher inflammation/structural/hormonal baseline)
  sc.inflammation *= af;
  sc.structural *= af;
  sc.hormonal *= af;

  // Round all scores
  for(const axis of ALL_AXES){
    sc[axis] = Math.round((sc[axis] || 0) * 10) / 10;
  }

  return sc;
}

// ═══════════════════════════════════════════════════════════════════════════
// DOMINANT AXIS — top scoring axis (excluding output axis "structural")
// ═══════════════════════════════════════════════════════════════════════════

function getDominantAxis(scores){
  // Prioritize root axes; if no clear root winner, fall back to support
  const rootScores = ROOT_AXES.map(a => [a, scores[a] || 0]);
  rootScores.sort((a,b) => b[1] - a[1]);

  // If top root score is above threshold, use it
  if(rootScores[0][1] >= 3){
    return rootScores[0][0];
  }

  // Otherwise check support axes
  const supportScores = SUPPORT_AXES.map(a => [a, scores[a] || 0]);
  supportScores.sort((a,b) => b[1] - a[1]);
  if(supportScores[0][1] >= 3){
    return supportScores[0][0];
  }

  // Fallback to highest root regardless of threshold
  return rootScores[0][0];
}

function getTopAxes(scores, n=3){
  const sorted = ALL_AXES.map(a => [a, scores[a] || 0]).sort((a,b) => b[1] - a[1]);
  return sorted.slice(0, n).map(([a,_]) => a);
}

// ═══════════════════════════════════════════════════════════════════════════
// DYNAMIC ARCHETYPE GENERATION
// Archetype = Objective + Dominant Axis (e.g., "Inflammatory Skin")
// ═══════════════════════════════════════════════════════════════════════════

function getArchetype(scores){
  const goals = answers['goals'] || [];
  const objective = goals[0] || 'skin'; // fallback if empty
  const focus = answers['focus'];
  const dominantAxis = getDominantAxis(scores);
  const topAxes = getTopAxes(scores, 3);
  const blockers = detectBlockers();

  // Build i18n keys for archetype name + description
  const nameKey = `arch.${objective}.${dominantAxis}`;
  const descKey = `arch.${objective}.${dominantAxis}.desc`;

  return {
    objective,
    focus,
    dominantAxis,
    topAxes,
    blockers,
    scores,
    nameKey,
    descKey,
    name: t(nameKey),
    desc: t(descKey)
  };
}

function buildPillarCtx(arch){
  const d={
    skin_aesthetics:'Pele & Estética: hidratação, inflamação, colágeno, acne, elasticidade, brilho.',
    body_composition:'Composição Corporal: massa muscular, perda de gordura, forma física.',
    hormonal_alignment:'Hormônios: cortisol, insulina, tireoide, ciclo, equilíbrio energético.',
    metabolic_efficiency:'Metabolismo: glicemia, timing alimentar, saciedade, flexibilidade metabólica.',
    sleep_recovery:'Sono & Recuperação: qualidade do sono, recuperação, reparo noturno.',
    nervous_system:'Sistema Nervoso: estresse, burnout, regulação emocional.',
    environment_input:'Ambiente: exposição à luz, toxinas, qualidade da água e do ar.',
    cellular_longevity:'Longevidade Celular: inflamação, oxidação, qualidade tecidual.'
  };
  return(arch.pilares||[]).map(p=>d[p]).filter(Boolean).join('\n');
}

// NAV
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0); if(typeof applyTranslations === 'function') applyTranslations();}
function startOnboarding(){showScreen('screen-0');}
function nextScreen(n){showScreen('screen-'+n);}

function restartApp(){
  Object.keys(answers).forEach(k=>delete answers[k]);
  document.querySelectorAll('.option').forEach(o=>o.classList.remove('selected'));
  document.querySelectorAll('.plan-card').forEach(o=>o.classList.remove('selected'));
  document.querySelectorAll('.btn-primary').forEach(b=>b.disabled=true);
  // Reset focus section visibility on slide 2
  const focusSection = document.getElementById('focus-section');
  if(focusSection){ focusSection.style.display = 'none'; }
  // Reset cached protocol data
  _protocolData = null;
  _cachedEssentials = null;
  document.getElementById('protocol-output').innerHTML='<div class="protocol-loading"><div class="protocol-spinner"></div><span>Gerando seu protocolo...</span></div>';
  document.getElementById('error-box').style.display='none';
  document.getElementById('paid-layer').style.display='none';
  _cs=null;_ca=null;
  showScreen('screen-welcome');
}

// SELECTORS
// ── ONBOARDING SELECTORS & HELPERS (Etapa A/B) ────────────────────────────
function selectGoal(value, el){
  if(!answers['goals']) answers['goals'] = [];
  const list = answers['goals'];
  const idx = list.indexOf(value);
  if(idx >= 0){
    list.splice(idx, 1);
    el.classList.remove('selected');
  } else {
    if(list.length >= 2){
      // Replace second selection
      const oldVal = list[1];
      list[1] = value;
      document.querySelectorAll('#opts-goal .option.selected').forEach(b => {
        const onClick = b.getAttribute('onclick') || '';
        if(onClick.includes("'" + oldVal + "'")) b.classList.remove('selected');
      });
      el.classList.add('selected');
    } else {
      list.push(value);
      el.classList.add('selected');
    }
  }
  updateFocusSection();
  bridgeGoalsToLegacy();
  updateContinueButton(1);
}

function updateFocusSection(){
  const focusSection = document.getElementById('focus-section');
  const focusOpts = document.getElementById('opts-focus');
  if(!focusSection || !focusOpts) return;

  const goals = answers['goals'] || [];
  if(goals.length === 0){
    focusSection.style.display = 'none';
    answers['focus'] = null;
    return;
  }

  const dominant = goals[0];
  focusSection.style.display = 'block';

  const focusOptions = {
    skin:   [['face','s2.focus.skin.face'], ['body','s2.focus.skin.body'], ['hair','s2.focus.skin.hair']],
    fat:    [['abdominal','s2.focus.fat.abdominal'], ['general','s2.focus.fat.general'], ['localized','s2.focus.fat.localized']],
    muscle: [['hypertrophy','s2.focus.muscle.hypertrophy'], ['strength','s2.focus.muscle.strength'], ['specific','s2.focus.muscle.specific']]
  };

  const opts = focusOptions[dominant] || [];
  focusOpts.innerHTML = opts.map(function(pair){
    const val = pair[0], key = pair[1];
    const label = (typeof t === 'function') ? t(key) : key;
    return '<button class="option" onclick="selectFocus(\''+val+'\',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="'+key+'">'+label+'</span></button>';
  }).join('');

  answers['focus'] = null;

  if(typeof applyTranslations === 'function') applyTranslations();
}

function selectFocus(value, el){
  answers['focus'] = value;
  document.querySelectorAll('#opts-focus .option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  updateContinueButton(1);
}

function selectTraining(value, el){
  answers['training'] = value;
  document.querySelectorAll('#opts-training .option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  updateContinueButton(4);
}

function updateContinueButton(slideIdx){
  const btn = document.getElementById('btn-' + slideIdx);
  if(!btn) return;
  let valid = false;
  if(slideIdx === 0){
    valid = !!(answers[0] && answers['age']);
  } else if(slideIdx === 1){
    valid = !!(answers['goals'] && answers['goals'].length >= 1 && answers['focus']);
  } else if(slideIdx === 2){
    valid = !!(answers[2] && answers[2].length >= 1);
  } else if(slideIdx === 3){
    valid = !!(answers[3] && answers[3].length >= 1);
  } else if(slideIdx === 4){
    valid = !!(answers['training']);
  } else if(slideIdx === 5){
    valid = !!(answers[5] && answers['openness'] && answers['consistency']);
  }
  btn.disabled = !valid;
}

function bridgeGoalsToLegacy(){
  // Used by buildProtocol context — derives a legacy goals array for downstream code
  const goals = answers['goals'] || [];
  const focus = answers['focus'];
  const legacy = [];
  goals.forEach(g => {
    if(g === 'skin'){
      if(focus === 'face') legacy.push('rosto');
      else if(focus === 'hair') legacy.push('cabelo');
      else legacy.push('pele');
    } else if(g === 'fat'){ legacy.push('gordura'); }
      else if(g === 'muscle'){ legacy.push('muscular'); }
  });
  answers[1] = legacy;
}

function animateLoading(){
  const status = document.getElementById('loading-status');
  if(!status) return;
  const isEn = (typeof _currentLang !== 'undefined') && _currentLang === 'en';
  const messages = isEn
    ? ['Identifying biological signals...', 'Mapping 8 biological axes...', 'Detecting blockers...', 'Selecting archetype and synergies...']
    : ['Identificando sinais biológicos...', 'Mapeando 8 eixos biológicos...', 'Detectando blockers...', 'Selecionando arquétipo e sinergias...'];
  let i = 0;
  status.textContent = messages[0];
  const interval = setInterval(function(){
    i++;
    if(i >= messages.length){ clearInterval(interval); return; }
    status.textContent = messages[i];
  }, 700);
}

function selectGender(v,el){answers[0]=v;document.querySelectorAll('#opts-gender .option').forEach(o=>o.classList.remove('selected'));el.classList.add('selected');updateContinueButton(0);}
function selectAge(v,el){answers['age']=v;document.querySelectorAll('#opts-age .option').forEach(o=>o.classList.remove('selected'));el.classList.add('selected');updateContinueButton(0);}
function selectPlan(v,el){
  answers[5]=v;
  document.querySelectorAll('#plan-essentials, #plan-elite').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  updateContinueButton(5);
}
function selectOpenness(v,el){
  answers['openness']=v;
  document.querySelectorAll('#opts-openness .option').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  updateContinueButton(5);
}
function selectConsistency(v,el){
  answers['consistency']=v;
  document.querySelectorAll('#opts-consistency .option').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
  updateContinueButton(5);
}

function selectMulti(step,v,el,max){
  if(!answers[step])answers[step]=[];
  const arr=answers[step],idx=arr.indexOf(v);
  if(idx>-1){arr.splice(idx,1);el.classList.remove('selected');}
  else{
    if(arr.length>=max){const f=document.querySelector('#opts-'+step+' .option.selected');if(f){const m=f.getAttribute('onclick').match(/'([^']+)',this/);const fv=m?m[1]:null;if(fv)arr.splice(arr.indexOf(fv),1);f.classList.remove('selected');}}
    arr.push(v);el.classList.add('selected');
  }
  if(typeof step === 'number'){
    updateContinueButton(step);
  } else if(step === 'lifestyle'){
    updateContinueButton(4);
  }
}


// ═══════════════════════════════════════════════════════════════════════════
// RENDER FUNCTIONS v2
// ═══════════════════════════════════════════════════════════════════════════

let _cachedEssentials = null;
let _protocolData = null;
let _protocolIsElite = false;

function renderProtocol(data, arch, isElite){
  _protocolData = data;
  _protocolIsElite = isElite;

  let html = '';

  // BLOCKER PRIORITY (if any)
  if(data.blocker_priority && data.blocker_priority.trim()){
    html += `<div style="padding:14px 16px;margin-bottom:18px;background:rgba(220,80,80,.06);border-left:2px solid #DC5050;border-radius:2px;">
      <div style="font-size:9px;letter-spacing:2.5px;color:#DC5050;text-transform:uppercase;margin-bottom:6px;font-weight:500;">${_currentLang === 'en' ? 'Priority' : 'Prioridade'}</div>
      <div style="font-size:13px;color:rgba(231,217,200,.78);line-height:1.6;font-weight:300;">${data.blocker_priority}</div>
    </div>`;
  }

  // CAUSA RAIZ
  if(data.causa_raiz){
    html += `<div style="padding:0 0 18px;border-bottom:1px solid rgba(231,217,200,.06);margin-bottom:20px;">
      <div style="font-family:var(--serif);font-size:17px;color:rgba(231,217,200,.78);line-height:1.7;font-style:italic;">${data.causa_raiz}</div>
    </div>`;
  }

  // FREE TIER
  html += `<div style="margin-bottom:24px;">
    <div style="font-size:11px;letter-spacing:3px;color:#C8D9C0;text-transform:uppercase;margin-bottom:8px;">${(_currentLang === 'en' ? 'To start — free' : 'Para começar — grátis')}</div>
    ${data.sinergia_free ? `<div style="font-family:var(--serif);font-size:14px;color:rgba(231,217,200,.6);font-style:italic;margin-bottom:14px;">${data.sinergia_free}</div>` : ''}`;

  (data.acoes_free || []).forEach((a, i) => {
    const periodLabels = formatPeriod(a.periodo);
    const days = formatDays(a.dias_semana);
    html += `<div style="display:flex;gap:14px;padding:12px 0;border-bottom:1px solid rgba(231,217,200,.05);">
      <div style="font-family:var(--serif);font-size:20px;color:rgba(200,217,192,.65);line-height:1;flex-shrink:0;width:24px;font-style:italic;">${i+1}</div>
      <div style="flex:1;">
        <div style="font-size:16px;color:rgba(231,217,200,.95);margin-bottom:4px;font-weight:400;">${a.nome || ''}</div>
        ${renderEvidenceBadge(a.nome)}
        ${a.dose || a.frequencia ? `<div style="font-size:13px;color:#C8D9C0;opacity:1;margin-bottom:5px;font-weight:500;">${[a.dose, a.frequencia].filter(Boolean).join(' · ')}</div>` : ''}
        ${a.modo ? `<div style="font-size:12px;color:rgba(231,217,200,.72);margin-bottom:4px;">${a.modo}</div>` : ''}
        ${periodLabels ? `<div style="font-size:12px;color:rgba(231,217,200,.65);margin-bottom:4px;">${periodLabels}${days ? ' · ' + days : ''}</div>` : ''}
        ${a.ciclo ? `<div style="font-size:12px;color:rgba(231,217,200,.55);margin-bottom:4px;">↻ ${a.ciclo}</div>` : ''}
        ${a.por_que ? `<div style="margin-top:2px;"><button class="why-toggle" onclick="toggleWhy(this)"><span data-i18n="why_this">${t('why_this')}</span> <span class="chevron">▼</span></button><div class="why-content">${a.por_que}</div></div>` : ''}
      </div>
    </div>`;
  });
  html += `</div>`;

  document.getElementById('protocol-output').innerHTML = html;

  // PAID LAYER (preview button)
  const totalPaid = 6 + (isElite ? 4 : 0);
  const pl = document.getElementById('paid-layer');
  pl.style.display = 'block';
  pl.innerHTML = `<div style="margin-top:4px;padding:22px;background:rgba(231,217,200,.03);border:1px solid rgba(231,217,200,.08);border-radius:4px;position:relative;overflow:hidden;">
    <div style="position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(to right,transparent,var(--gold),transparent);"></div>
    <div style="font-family:var(--serif);font-size:20px;color:var(--white);margin-bottom:6px;">${t('result.paid.title_template', {n: totalPaid})}</div>
    <div style="font-size:12px;color:rgba(231,217,200,.32);line-height:1.6;margin-bottom:18px;">${t('result.paid.sub_default')}</div>
    <button onclick="unlockProtocol()" style="width:100%;padding:15px;background:var(--gold);color:var(--deep);border:none;font-family:var(--serif);font-size:17px;font-weight:600;cursor:pointer;border-radius:2px;transition:all .2s;">
      ${t('result.view_full')}
    </button>
  </div>`;
}

function renderFull(data, isElite){
  // Render essentials + (optional) elite into protocol-output
  let html = document.getElementById('protocol-output').innerHTML;

  // ESSENTIALS section
  html += `<div style="margin-top:32px;padding-top:24px;border-top:1px solid rgba(200,217,192,.15);">
    <div style="font-size:11px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">Complete Foundation</div>
    ${data.sinergia_essentials ? `<div style="font-family:var(--serif);font-size:14px;color:rgba(231,217,200,.6);font-style:italic;margin-bottom:14px;">${data.sinergia_essentials}</div>` : ''}`;

  (data.acoes_essentials || []).forEach((a, i) => {
    const periodLabels = formatPeriod(a.periodo);
    const days = formatDays(a.dias_semana);
    html += `<div style="display:flex;gap:14px;padding:12px 0;border-bottom:1px solid rgba(231,217,200,.05);">
      <div style="font-family:var(--serif);font-size:20px;color:rgba(200,217,192,.7);line-height:1;flex-shrink:0;width:24px;font-style:italic;">${i+1}</div>
      <div style="flex:1;">
        ${a.categoria ? `<div style="font-size:11px;letter-spacing:1.5px;color:rgba(200,217,192,.75);text-transform:uppercase;margin-bottom:3px;">${a.categoria}</div>` : ''}
        <div style="font-size:16px;color:rgba(231,217,200,.95);margin-bottom:4px;font-weight:400;">${a.nome || ''}</div>
        ${renderEvidenceBadge(a.nome)}
        ${a.dose || a.frequencia ? `<div style="font-size:13px;color:var(--gold);opacity:1;margin-bottom:5px;font-weight:500;">${[a.dose, a.frequencia].filter(Boolean).join(' · ')}</div>` : ''}
        ${a.modo ? `<div style="font-size:12px;color:rgba(231,217,200,.72);margin-bottom:4px;">${a.modo}</div>` : ''}
        ${periodLabels ? `<div style="font-size:12px;color:rgba(231,217,200,.65);margin-bottom:4px;">${periodLabels}${days ? ' · ' + days : ''}</div>` : ''}
        ${a.ciclo ? `<div style="font-size:12px;color:rgba(231,217,200,.55);margin-bottom:4px;">↻ ${a.ciclo}</div>` : ''}
        ${a.por_que ? `<div style="margin-top:2px;"><button class="why-toggle" onclick="toggleWhy(this)"><span data-i18n="why_this">${t('why_this')}</span> <span class="chevron">▼</span></button><div class="why-content">${a.por_que}</div></div>` : ''}
      </div>
    </div>`;
  });
  html += `</div>`;

  // ELITE section
  if(isElite && data.acoes_elite){
    html += `<div style="margin-top:32px;padding-top:24px;border-top:1px solid rgba(200,217,192,.25);">
      <div style="font-size:11px;letter-spacing:3px;color:var(--gold);text-transform:uppercase;margin-bottom:8px;">${_currentLang === 'en' ? 'Enhancement + Advanced' : 'Enhancement + Advanced'}</div>
      ${data.sinergia_elite ? `<div style="font-family:var(--serif);font-size:14px;color:rgba(231,217,200,.6);font-style:italic;margin-bottom:14px;">${data.sinergia_elite}</div>` : ''}`;

    data.acoes_elite.forEach((a, i) => {
      const periodLabels = formatPeriod(a.periodo);
      const days = formatDays(a.dias_semana);
      html += `<div style="display:flex;gap:14px;padding:12px 0;border-bottom:1px solid rgba(231,217,200,.05);">
        <div style="font-family:var(--serif);font-size:20px;color:rgba(200,217,192,.85);line-height:1;flex-shrink:0;width:24px;font-style:italic;">${i+1}</div>
        <div style="flex:1;">
          ${a.tipo ? `<div style="font-size:11px;letter-spacing:1.5px;color:rgba(200,217,192,.85);text-transform:uppercase;margin-bottom:3px;">${a.tipo}</div>` : ''}
          <div style="font-size:16px;color:rgba(231,217,200,.97);margin-bottom:4px;font-weight:400;">${a.nome || ''}</div>
          ${a.dose || a.frequencia ? `<div style="font-size:13px;color:var(--gold);margin-bottom:5px;font-weight:500;">${[a.dose, a.frequencia].filter(Boolean).join(' · ')}</div>` : ''}
          ${a.modo ? `<div style="font-size:12px;color:rgba(231,217,200,.72);margin-bottom:4px;">${a.modo}</div>` : ''}
          ${periodLabels ? `<div style="font-size:12px;color:rgba(231,217,200,.65);margin-bottom:4px;">${periodLabels}${days ? ' · ' + days : ''}</div>` : ''}
          ${a.ciclo ? `<div style="font-size:12px;color:rgba(231,217,200,.55);margin-bottom:4px;">↻ ${a.ciclo}</div>` : ''}
          ${(a.por_que || a.atencao) ? `<div style="margin-top:2px;"><button class="why-toggle" onclick="toggleWhy(this)"><span data-i18n="why_this">${t('why_this')}</span> <span class="chevron">▼</span></button>${a.por_que ? `<div class="why-content">${a.por_que}</div>` : ''}${a.atencao ? `<div class="why-warning">⚠ ${a.atencao}</div>` : ''}</div>` : ''}
        </div>
      </div>`;
    });
    html += `</div>`;
  }

  document.getElementById('protocol-output').innerHTML = html;

  // Hide paid layer button after unlock
  const pl = document.getElementById('paid-layer');
  if(pl) pl.style.display = 'none';

  // Show calendar buttons
  const calBtn = document.getElementById('calendar-buttons');
  if(calBtn) calBtn.style.display = 'flex';
}

async function unlockProtocol(){
  const pl = document.getElementById('paid-layer');
  pl.innerHTML = `<div style="padding:24px;display:flex;align-items:center;gap:12px;color:rgba(231,217,200,.32);font-size:13px;">
    <div style="width:16px;height:16px;border:1px solid rgba(231,217,200,.1);border-top-color:var(--gold);border-radius:50%;animation:spin .9s linear infinite;flex-shrink:0;"></div>
    <span style="font-family:var(--serif);font-style:italic;">${t('result.prep.loading')}</span>
  </div>`;

  try {
    const isElite = (answers[5] === 'elite');
    // Generate Essentials
    const essentialsData = await genFull(_cs, _ca);
    // Merge into _protocolData
    Object.assign(_protocolData, essentialsData);

    // If Elite, also generate Elite layer
    if(isElite){
      const profile = buildProfileContext(_ca, _cs);
      // Collect already-used items from free + essentials
      const usedItems = [];
      if(_protocolData){
        (_protocolData.acoes_free || []).forEach(a => a.nome && usedItems.push(a.nome));
        (_protocolData.acoes_essentials || []).forEach(a => a.nome && usedItems.push(a.nome));
      }
      const elitePrompt = buildElitePrompt(_ca, profile, usedItems);
      const eliteData = await callAI(elitePrompt);
      Object.assign(_protocolData, eliteData);
    }

    renderFull(_protocolData, isElite);
    _cachedEssentials = _protocolData;
  } catch(err){
    pl.innerHTML = `<div style="padding:20px;color:rgba(220,80,80,.8);font-size:13px;">${t('result.error')}: ${err.message}</div>`;
  }
}

// Helpers
function formatPeriod(periodo){
  if(!periodo) return '';
  const labels = { manha: t('cal.period.morning'), tarde: t('cal.period.afternoon'), noite: t('cal.period.night') };
  return periodo.split(',').map(p => labels[p.trim()]).filter(Boolean).join(' · ');
}

function formatDays(dias){
  if(!dias) return '';
  if(dias === 'diario') return _currentLang === 'en' ? 'daily' : 'diário';
  const dayLabels = {
    seg: t('cal.day_short.seg'), ter: t('cal.day_short.ter'), qua: t('cal.day_short.qua'),
    qui: t('cal.day_short.qui'), sex: t('cal.day_short.sex'), sab: t('cal.day_short.sab'),
    dom: t('cal.day_short.dom')
  };
  return dias.split(',').map(d => dayLabels[d.trim()]).filter(Boolean).join('/');
}


let _cs=null,_ca=null;


function bridgeAnswersToLegacy(){
  // New schema:
  //   answers[0] = gender
  //   answers['age'] = age
  //   answers['goals'] = ['skin','fat','muscle'] up to 2
  //   answers['focus'] = single focus value
  //   answers[2] = visual symptoms (multi up to 2) — slide 3
  //   answers[3] = internal signals (multi up to 2) — slide 4
  //   answers['training'] = single training level
  //   answers['lifestyle'] = lifestyle multi (optional)
  //   answers[5] = plan
  //   answers['openness'], answers['consistency']
  //
  // Legacy schema expected by calculateScores/getArchetype:
  //   answers[1] = goals (PT keys: pele, rosto, gordura, muscular, cabelo, glow)
  //   answers[2] = visual complaint
  //   answers[3] = body pattern
  //   answers[4] = internal signals

  // 1. Bridge goals (already done in selectGoal/bridgeGoalsToLegacy, but ensure)
  bridgeGoalsToLegacy();

  // 2. Map new visual symptoms (answers[2]) → legacy visual complaint keys
  //    new keys: pele_opaca, pele_inflamada, rosto_inchado, flacidez_rugas, cabelo_caindo,
  //              gordura_abdominal, gordura_localizada, falta_definicao, aparencia_cansada
  //    legacy keys: rosto_inchado, inflamacao_pele, gordura_localizada, falta_definicao,
  //                 corpo_sem_firmeza, pele_sem_brilho, aparencia_cansada
  const visualMap = {
    'pele_opaca': 'pele_sem_brilho',
    'pele_inflamada': 'inflamacao_pele',
    'rosto_inchado': 'rosto_inchado',
    'flacidez_rugas': 'corpo_sem_firmeza',  // closest legacy match
    'cabelo_caindo': 'pele_sem_brilho',     // proxy — affects skin/microbiome scoring
    'gordura_abdominal': 'gordura_localizada',
    'gordura_localizada': 'gordura_localizada',
    'falta_definicao': 'falta_definicao',
    'aparencia_cansada': 'aparencia_cansada'
  };
  if(answers[2] && Array.isArray(answers[2])){
    const mapped = answers[2].map(v => visualMap[v] || v).filter(Boolean);
    // Keep mapped under same key for legacy scoring
    answers[2] = mapped;
  }

  // 3. Map new internal signals (answers[3]) → legacy internal signals (answers[4])
  //    new keys: energia_oscilante, cansaco_dormindo, sono_leve, inchaco, desejo_acucar,
  //              libido_baixa, estresse_alto, ciclos
  //    legacy keys: energia_instavel, cansaco_dormindo, incha_facil, desejo_acucar,
  //                 sono_leve, baixa_energia, hormonal
  const internalMap = {
    'energia_oscilante': 'energia_instavel',
    'cansaco_dormindo': 'cansaco_dormindo',
    'sono_leve': 'sono_leve',
    'inchaco': 'incha_facil',
    'desejo_acucar': 'desejo_acucar',
    'libido_baixa': 'baixa_energia',
    'estresse_alto': 'baixa_energia',  // proxy — high stress = nervous system signal
    'ciclos': 'hormonal'
  };
  if(answers[3] && Array.isArray(answers[3])){
    const mapped = answers[3].map(v => internalMap[v] || v).filter(Boolean);
    // Move to legacy answers[4] (internal signals slot)
    answers[4] = mapped;
  }

  // 4. Body pattern (answers[3] in legacy) is now derived from training + visual symptoms
  //    Provide a sensible default
  const training = answers['training'];
  const bodyPattern = [];
  if(training === 'sedentary' || training === 'light'){
    bodyPattern.push('dificuldade_perder');
  }
  if(training === 'moderate' || training === 'athlete'){
    bodyPattern.push('dificuldade_definir');
  }
  // Use visual symptoms as additional body pattern signals
  if(answers[2]){
    if(answers[2].includes('gordura_localizada')) bodyPattern.push('retencao');
    if(answers[2].includes('falta_definicao')) bodyPattern.push('dificuldade_definir');
  }
  // Now overwrite answers[3] with body pattern for legacy scoring
  // BUT we already used answers[3] for internal signals. So save internal first, then overwrite.
  // (Done above — already moved internal to answers[4])
  answers[3] = bodyPattern.length > 0 ? bodyPattern : ['dificuldade_perder'];

  console.log('Bridged answers:', JSON.parse(JSON.stringify(answers)));
}

async function buildProtocol(){
  showScreen('screen-loading');animateLoading();
  const sc = calculateScores();
  const arch = getArchetype(sc);
  _cs = sc; _ca = arch;
  await new Promise(r => setTimeout(r, 2800));
  showScreen('screen-result');
  document.getElementById('result-name').textContent = arch.name;
  // Show dominant axis label as the "motor" replacement
  const motorEl = document.getElementById('result-motor');
  if(motorEl) motorEl.textContent = t('axis.' + arch.dominantAxis);
  renderScores(sc, arch);
  await genProtocol(sc, arch);
}

function renderScores(sc, arch){
  const c = document.getElementById('result-scores');
  if(!c) return;
  c.innerHTML = '';
  const max = Math.max(...Object.values(sc), 1);
  const dominantAxis = arch.dominantAxis;

  for(const axis of ALL_AXES){
    const v = sc[axis] || 0;
    const isDom = axis === dominantAxis;
    const label = t('axis.' + axis);
    c.innerHTML += `<div class="score-card ${isDom ? 'dominant' : ''}"><div class="score-label">${label}</div><div class="score-value">${v}</div><div class="score-bar"><div class="score-bar-fill" style="width:${Math.round(v/max*100)}%"></div></div></div>`;
  }
}

// ── AI CALL — single function used by all gen* functions ──────────────────
async function callAI(prompt, maxTokens){
  maxTokens = maxTokens || 8000;
  const isEn = (typeof _currentLang !== 'undefined') && _currentLang === 'en';
  const systemPrompt = isEn
    ? 'You are a JSON generator. Output ONLY raw JSON in English. All string values in natural English, single-line, no line breaks. No markdown, no prose.'
    : 'Você é um gerador de JSON. Responda APENAS com JSON puro em português do Brasil. Todos os valores de string em português natural, linha única, sem quebras. Sem markdown, sem prosa.';

  const response = await fetch('/api/generate', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      model: 'claude-haiku-4-5-20251001',
      max_tokens: maxTokens,
      messages: [{ role: 'user', content: systemPrompt + '\n\n' + prompt }]
    })
  });

  let data;
  try {
    data = await response.json();
  } catch(jsonErr) {
    const text = await response.text().catch(() => 'unable to read');
    console.error('Failed to parse API response as JSON. Status:', response.status, 'Body:', text.substring(0, 500));
    throw new Error('API returned non-JSON response (status ' + response.status + ')');
  }
  console.log('API response status:', response.status, 'data:', JSON.stringify(data).substring(0, 500));

  if(!response.ok || data.error){
    console.error('API error full:', JSON.stringify(data));
    const errType = data.error.type || (data.error.error && data.error.error.type) || '';
    if(errType === 'exceeded_limit' || errType === 'rate_limit_error'){
      throw new Error(isEn ? 'Usage limit reached. Please try again in a few minutes.' : 'Limite de uso atingido. Tente novamente em alguns minutos.');
    }
    if(errType === 'overloaded_error'){
      throw new Error(isEn ? 'Service temporarily overloaded. Please try again shortly.' : 'Serviço temporariamente sobrecarregado. Tente novamente em instantes.');
    }
    throw new Error(data.error.message || 'API error');
  }

  // Extract text from response
  let text = '';
  if(data.content && Array.isArray(data.content)){
    for(const block of data.content){
      if(block.type === 'text') text += block.text;
    }
  } else if(typeof data.content === 'string'){
    text = data.content;
  } else if(data.completion){
    text = data.completion;  // older format
  }

  if(!text){
    console.error('No text extracted. Full data:', JSON.stringify(data));
    throw new Error('Empty response from API');
  }

  console.log('AI raw response — length:', text.length);

  // Clean and parse JSON
  let cleaned = text.trim();
  // Strip markdown code fences if present
  cleaned = cleaned.replace(/^```json\s*/i, '').replace(/^```\s*/, '').replace(/```\s*$/, '');
  cleaned = cleaned.trim();

  try{
    return JSON.parse(cleaned);
  }catch(parseErr){
    console.error('JSON parse failed. Raw last 300 chars:', cleaned.substring(Math.max(0, cleaned.length - 300)));
    // Try to auto-close truncated JSON
    let attempt = cleaned;
    // Count open vs close braces/brackets
    const openCurly = (attempt.match(/\{/g) || []).length;
    const closeCurly = (attempt.match(/\}/g) || []).length;
    const openSq = (attempt.match(/\[/g) || []).length;
    const closeSq = (attempt.match(/\]/g) || []).length;
    // Trim trailing comma or partial string
    attempt = attempt.replace(/,\s*$/, '');
    // Add missing closes
    for(let i = 0; i < (openSq - closeSq); i++) attempt += ']';
    for(let i = 0; i < (openCurly - closeCurly); i++) attempt += '}';
    try{
      return JSON.parse(attempt);
    }catch(retryErr){
      throw new Error('Failed to parse AI response as JSON');
    }
  }
}

async function genProtocol(sc,arch){
  // Layer 1+2 (free + essentials): shown initially as "free hacks"
  const eb=document.getElementById('error-box');
  eb.style.display='none';
  try{
    const profile = buildProfileContext(arch, sc);
    const prompt = buildFreePrompt(arch, profile);
    const data = await callAI(prompt);
    renderProtocol(data, arch, false);
  }catch(err){
    eb.style.display='block';
    eb.textContent = t('result.error') + ' (' + err.message + ')';
    console.error('genProtocol error:', err);
  }
}

async function genFull(sc,arch){
  // Generate Essentials layer
  const eb=document.getElementById('error-box');
  eb.style.display='none';
  try{
    const profile = buildProfileContext(arch, sc);
    // Get already-used items from free tier
    const usedFree = (_protocolData && _protocolData.acoes_free) ? _protocolData.acoes_free.map(a => a.nome).filter(Boolean) : [];
    const prompt = buildEssentialsPrompt(arch, profile, usedFree);
    const data = await callAI(prompt);
    return data;
  }catch(err){
    eb.style.display='block';
    eb.textContent = t('result.error') + ' (' + err.message + ')';
    console.error('genFull error:', err);
    throw err;
  }
}

// Build a structured profile context that all prompts use
function buildProfileContext(arch, sc){
  const goals = answers['goals'] || [];
  const focus = answers['focus'] || '';
  const objective = arch.objective;
  const dominantAxis = arch.dominantAxis;
  const topAxes = arch.topAxes || [];
  const blockers = arch.blockers || [];
  const lifestyle = answers['lifestyle'] || [];
  const training = answers['training'] || 'moderate';

  return {
    gender: answers[0],
    age: answers['age'],
    objective,
    focus,
    secondaryGoal: goals[1] || null,
    dominantAxis,
    topAxes,
    blockers,
    scores: sc,
    lifestyle,
    training,
    plan: answers[5] || 'essentials',
    openness: answers['openness'] || 'avancado',
    consistency: answers['consistency'] || 'consistente',
    archetypeName: arch.name,
    archetypeDesc: arch.desc
  };
}

// ═══════════════════════════════════════════════════════════════════════════
// PROMPT BUILDERS v2 — 4-Layer Architecture
// Layer 1: Blockers (always first)
// Layer 2: Base protocol (objective shelf)
// Layer 3: Axis adjustments (top 3 axes)
// Layer 4: Longevity (Elite only)
// ═══════════════════════════════════════════════════════════════════════════

const FIELD_RULES_EN = `FIELD RULES (each field is separate, all values in English):
- "nome": just the name in English (e.g., "Berberine", "Magnesium threonate")
- "dose": exact amount with unit, or empty (e.g., "500mg", "10-15 min", "")
- "frequencia": how many times per day (e.g., "1x/day", "2x/day")
- "periodo": when to take — values "manha", "tarde", "noite" separated by comma (keep these Portuguese keys for the system)
- "modo": how to take in English (e.g., "with food", "fasted", "1h before sleep")
- "dias_semana": "diario" OR "seg,qua,sex" etc (keep Portuguese keys for the system)
- "por_que": MAXIMUM 25 WORDS. Educational but accessible — explain the mechanism in plain language. Avoid heavy technical jargon. Focus on what it does and why it matters for the user. Maximum 1-2 sentences.
  ✅ GOOD: "Heat from the sauna repairs damaged skin proteins, lowers stress hormones, and helps you sleep deeper — your skin recovers overnight."
  ✅ GOOD: "BPC-157 speeds up healing of inflamed gut and skin tissue, calming the inflammation that ages you faster."
  ✅ GOOD: "Calms the body-wide inflammation that triggers acne, redness, and dull skin."
  ❌ BAD: Anything over 25 words. Anything with phrases like: "addressing axis severity X", "modulates HPA axis", "senolytic clearing senescent cells", "promoting parasympathetic recovery". Don't reference axis names or scores.
- "ciclo": duration in English (e.g., "ongoing use", "8-week cycle")`;

const FIELD_RULES_PT = `REGRAS DE CAMPOS (cada campo é separado):
- "nome": apenas o nome do composto/intervenção
- "dose": quantidade exata com unidade, ou vazio (ex: "500mg", "10-15 min", "")
- "frequencia": quantas vezes por dia (ex: "1x/dia", "2x/dia")
- "periodo": quando tomar — valores "manha", "tarde", "noite" separados por vírgula
- "modo": como tomar (ex: "com comida", "em jejum", "1h antes de dormir")
- "dias_semana": "diario" OU "seg,qua,sex" etc
- "por_que": MÁXIMO 25 PALAVRAS. Educacional mas acessível — explica o mecanismo em linguagem simples. Evitar jargão técnico pesado. Focar no que faz e por que importa pra pessoa. Máximo 1-2 frases.
  ✅ BOM: "O calor da sauna repara proteínas danificadas da pele, reduz hormônios do estresse e ajuda a dormir mais profundo — sua pele recupera durante a noite."
  ✅ BOM: "BPC-157 acelera a cura de tecidos inflamados do intestino e da pele, acalmando a inflamação que envelhece mais rápido."
  ✅ BOM: "Acalma a inflamação geral do corpo que gera acne, vermelhidão e pele opaca."
  ❌ RUIM: Qualquer coisa acima de 25 palavras. Frases como: "endereçando severidade do eixo X", "modula eixo HPA", "senolítico limpando células senescentes", "promovendo recuperação parassimpática". Não mencionar nomes de eixos ou scores.
- "ciclo": duração (ex: "uso contínuo", "ciclo de 8 semanas")`;

function buildBlockerContext(blockers, isEn){
  if(!blockers || blockers.length === 0) return isEn ? 'No major lifestyle blockers detected.' : 'Sem blockers principais detectados.';
  const lines = blockers.map(b => `- ${b.id} (severity ${b.severity})`).join('\n');
  return (isEn ? 'BLOCKERS DETECTED (must address first):\n' : 'BLOCKERS DETECTADOS (devem ser endereçados primeiro):\n') + lines;
}

function buildAxesContext(scores, topAxes, isEn){
  const lines = topAxes.map(a => `- ${a}: ${scores[a] || 0}`).join('\n');
  return (isEn ? 'TOP BIOLOGICAL AXES (drive root-cause adjustments):\n' : 'TOP EIXOS BIOLÓGICOS:\n') + lines;
}

// ── FREE prompt (Layer 1 + tip of Layer 2: 3 quick wins) ───────────────────
function buildFreePrompt(arch, p){
  const isEn = _currentLang === 'en';
