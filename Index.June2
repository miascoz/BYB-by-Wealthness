function getEvidenceBadge(nome) {
  if (!nome) return 'promising';
  var key = nome.toLowerCase().trim();
  if (BYB_SHELF_LOOKUP[key]) return BYB_SHELF_LOOKUP[key];
  var keys = Object.keys(BYB_SHELF_LOOKUP);
  for (var i = 0; i < keys.length; i++) {
    var k = keys[i];
    if (key.indexOf(k) !== -1 || k.indexOf(key) !== -1) return BYB_SHELF_LOOKUP[k];
  }
  if (/bpc-157|ghk-cu|ipamorelin|cjc-1295|tb-500|epitalon|mots-c|tirzepatide|semaglutide|retatrutide|tesamorelin|aod-9604|melanotan/i.test(nome)) return 'experimental';
  return 'promising';
}

function renderEvidenceBadge(nome) {
  var level = getEvidenceBadge(nome);
  var isEn = (typeof _currentLang !== 'undefined') && _currentLang === 'en';
  var BADGE_DATA = {
    validated:    { emoji: String.fromCodePoint(0x2705), label: isEn ? 'VALIDATED' : 'VALIDADO', color: 'rgba(200,217,192,1)', bg: 'rgba(200,217,192,0.12)', border: 'rgba(200,217,192,0.35)', tip: isEn ? 'Multiple human RCTs confirm effectiveness' : 'Multiplos RCTs humanos confirmam eficacia' },
    promising:    { emoji: String.fromCodePoint(0x26A0) + String.fromCodePoint(0xFE0F), label: isEn ? 'PROMISING' : 'PROMISSOR', color: 'rgba(200,217,192,1)', bg: 'rgba(200,217,192,0.1)', border: 'rgba(200,217,192,0.35)', tip: isEn ? 'Human trials show positive results, more research needed' : 'Estudos humanos positivos, mais pesquisa necessaria' },
    experimental: { emoji: String.fromCodePoint(0x1F914), label: 'EXPERIMENTAL', color: 'rgba(180,140,255,1)', bg: 'rgba(180,140,255,0.1)', border: 'rgba(180,140,255,0.3)', tip: isEn ? 'Animal studies or self-reports only. No controlled human trials yet' : 'Apenas estudos animais ou relatos. Sem ensaios humanos controlados ainda' }
  };
  var c = BADGE_DATA[level] || BADGE_DATA.promising;
  return '<span title="' + c.tip + '" style="display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:100px;border:1px solid ' + c.border + ';background:' + c.bg + ';font-size:9px;letter-spacing:1.5px;font-weight:600;color:' + c.color + ';font-family:var(--sans);text-transform:uppercase;margin-bottom:6px;cursor:help;">' + c.emoji + ' ' + c.label + '</span>';
}

