      <span class="lang-flag">🇺🇸</span>
      <span class="lang-code">EN</span>
    </button>
    <button class="lang-btn" data-lang-btn="pt" onclick="setLanguage('pt')">
      <span class="lang-flag">🇧🇷</span>
      <span class="lang-code">PT</span>
    </button>
  </div>
  <div class="w-content">
    <div class="w-brand">
    <div class="w-title">Beauty <em>Intel</em></div>
    <div class="w-by" data-i18n="w.by">By Wealthness</div>
    </div>
    <div class="w-tags">
      <span class="w-tag" data-i18n="w.tag.beauty">Beauty</span>
      <span class="w-tag" data-i18n="w.tag.biohacking">Vitalidade</span>
      <span class="w-tag" data-i18n="w.tag.longevity">Longevidade</span>
    </div>
