    <div class="q-sub" data-i18n="s1.q_sub">Sua biologia é o ponto de partida.</div>

    <div class="group-label" data-i18n="s1.group.gender">GÊNERO</div>
    <div class="options" id="opts-gender" style="flex-direction:row;gap:8px;margin-bottom:24px;">
      <button class="option" style="flex:1;justify-content:center;" onclick="selectGender('female',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.gender.female">Mulher</span></button>
      <button class="option" style="flex:1;justify-content:center;" onclick="selectGender('male',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.gender.male">Homem</span></button>
    </div>

    <div class="group-label" data-i18n="s1.group.age">IDADE</div>
    <div class="options" id="opts-age">
      <button class="option" onclick="selectAge('18-24',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.age.18_24">18 – 24</span></button>
      <button class="option" onclick="selectAge('25-34',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.age.25_34">25 – 34</span></button>
      <button class="option" onclick="selectAge('35-44',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.age.35_44">35 – 44</span></button>
      <button class="option" onclick="selectAge('45-54',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.age.45_54">45 – 54</span></button>
      <button class="option" onclick="selectAge('55+',this)"><span class="opt-dot"><span class="opt-dot-inner"></span></span><span data-i18n="s1.age.55plus">55+</span></button>
    </div>
    <div style="margin-top:18px;font-size:10px;color:rgba(231,217,200,.28);letter-spacing:.5px;line-height:1.5;font-weight:300;" data-i18n="s1.disclaimer">Este app é destinado a adultos 18+. Ao continuar, você confirma ter 18 anos ou mais.</div>
  </div>
  <div class="screen-footer"><button class="btn-primary" id="btn-0" disabled onclick="nextScreen(1)" data-i18n="continue">Continuar</button></div>
</div>

